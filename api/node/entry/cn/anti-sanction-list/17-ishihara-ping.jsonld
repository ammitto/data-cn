  "effects": [
    {
      "effect_type": "asset_freeze",
      "scope": "full",
      "description": [
        {
          "value": "冻结其在我国境内的动产、不动产及其他各类财产",
          "lang": "zh",
          "script": "Hani",
          "is_primary": true
        },
        {
          "value": "Freeze all assets in China, including movable and immovable property and other types of assets",
          "lang": "en",
          "script": "Latn",
          "is_primary": false
        }
      ]
    },
    {
      "effect_type": "prohibit_transactions",
      "scope": "full",
      "description": [
        {
          "value": "禁止我国境内的组织、个人与其进行有关交易、合作等活动",
          "lang": "zh",
          "script": "Hani",
          "is_primary": true
        },
        {
          "value": "Prohibit organizations and individuals in China from engaging in transactions, cooperation or related activities with the entity with the individual",
          "lang": "en",
          "script": "Latn",
          "is_primary": false
        }
      ]
    },
    {
      "effect_type": "visa_ban",
      "scope": "full",
      "description": [
        {
          "value": "对其本人及直系亲属不予签发签证、不准入境（包括香港、澳门）",
          "lang": "zh",
          "script": "Hani",
          "is_primary": true
        },
        {
          "value": "Visa ban and entry prohibition for the individual and immediate family (including Hong Kong and Macao)",
          "lang": "en",
          "script": "Latn",
          "is_primary": false
        }
      ]
    }
  ],
  "reasons": [
    {
      "category": "other",
      "description": [
        {
          "value": "长期在台湾、钓鱼岛、历史、涉疆、涉藏、涉港等问题上散布谬论，公然参拜靖国神社，严重违背中日四个政治文件精神和一个中国原则，严重干涉中国内政，严重损害中国主权和领土完整。",
          "lang": "zh",
          "script": "Hani",
          "is_primary": true
        },
        {
          "value": "Long-term dissemination of fallacies on issues such as Taiwan, Diaoyu Islands, history, Xinjiang, Tibet, and Hong Kong, openly visiting the Yasukuni Shrine, seriously violating the spirit of the four political documents between China and Japan and the One-China principle, seriously interfering in China's internal affairs, and seriously damaging China's sovereignty and territorial integrity.",
          "lang": "en",
          "script": "Latn",
          "is_primary": false
        }
      ]
    }
  ],
  "period": {
    "effective_date": "2025-09-08",
    "is_indefinite": false
  },
  "status": "active",
  "reference_number": "17-ishihara-ping",
  "announcement": {
    "title": "关于对石平采取反制措施的决定",
    "url": "https://www.mfa.gov.cn/web/wjb_673085/zfxxgk_674865/gknrlb/fzcqdcs/202509/t20250908_11704050.shtml",
    "publish_date": "2025-09-08",
    "publish_time": "10:00",
    "document_type": "cn/ministry-of-foreign-affairs-order",
    "document_id": "第17号",
    "signatory": "cn/ministry-of-foreign-affairs",
    "publisher": "cn/ministry-of-foreign-affairs",
    "authority": "cn/ministry-of-foreign-affairs",
    "content": "（2025年9月8日中华人民共和国外交部令第17号公布，自2025年9月8日起施行）\n\n日本参议员石平长期在台湾、钓鱼岛、历史、涉疆、涉藏、涉港等问题上散布谬论，公然参拜靖国神社，严重违背中日四个政治文件精神和一个中国原则，严重干涉中国内政，严重损害中国主权和领土完整。依据《中华人民共和国反外国制裁法》第三条、第四条、第五条、第六条、第九条、第十五条规定，中方决定对石平采取以下反制措施：\n\n一、冻结其在我国境内的动产、不动产及其他各类财产；\n二、禁止我国境内的组织、个人与其进行有关交易、合作等活动；\n三、对其本人及直系亲属不予签发签证、不准入境（包括香港、澳门）。\n\n本决定自2025年9月8日起施行。\n",
    "language": "zh-CN"
  },
  "legal_citations": [
    {
      "legal_instrument_id": "https://www.ammitto.org/legal-instrument/cn/npc-anti-foreign-sanctions-law",
