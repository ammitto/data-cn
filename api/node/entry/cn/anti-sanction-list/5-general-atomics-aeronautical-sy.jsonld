  "reasons": [
    {
      "category": "other",
      "description": [
        {
          "value": "美国持续向中国台湾地区出售武器，严重违反一个中国原则和中美三个联合公报规定，严重干涉中国内政，严重损害中国主权和领土完整。中方决定对参与向中国台湾地区出售武器的美国企业采取反制措施。",
          "lang": "zh",
          "script": "Hani",
          "is_primary": true
        },
        {
          "value": "The US continues to sell weapons to China's Taiwan region, seriously violating the One-China principle and the three China-US joint communiqués, seriously interfering in China's internal affairs, and seriously damaging China's sovereignty and territorial integrity. China has decided to take countermeasures against US companies involved in selling weapons to China's Taiwan region.",
          "lang": "en",
          "script": "Latn",
          "is_primary": false
        }
      ]
    }
  ],
  "period": {
    "effective_date": "2024-04-11",
    "is_indefinite": false
  },
  "status": "active",
  "reference_number": "5-general-atomics-aeronautical-sy",
  "announcement": {
    "title": "关于对美国通用原子航空系统公司、通用动力陆地系统公司采取反制措施的决定",
    "url": "https://www.mfa.gov.cn/web/wjb_673085/zfxxgk_674865/gknrlb/fzcqdcs/202404/t20240411_11280056.shtml",
    "publish_date": "2024-04-11",
    "publish_time": "17:00",
    "document_type": "cn/ministry-of-foreign-affairs-order",
    "document_id": "第5号",
    "signatory": "cn/ministry-of-foreign-affairs",
    "publisher": "cn/ministry-of-foreign-affairs",
    "authority": "cn/ministry-of-foreign-affairs",
    "content": "（2024年4月11日中华人民共和国外交部令第5号公布，自2024年4月11日起施行）\n\n美国持续向中国台湾地区出售武器，严重违反一个中国原则和中美三个联合公报规定，严重干涉中国内政，严重损害中国主权和领土完整。依据《中华人民共和国反外国制裁法》第三条、第四条、第五条、第六条、第九条、第十五条规定，中方决定对参与向中国台湾地区出售武器的美国通用原子航空系统公司、通用动力陆地系统公司等后附《反制清单》列明的企业采取以下反制措施：\n\n一、冻结在我国境内的动产、不动产和其他各类财产；\n二、对高级管理人员不予签发签证、不准入境。\n\n本决定自2024年4月11日起施行。\n\n附件：反制清单\n\n外交部\n2024年4月11日\n\n附件\n反制清单\n\n一、通用原子航空系统公司（General Atomics Aeronautical Systems)\n二、通用动力陆地系统公司（General Dynamics Land Systems)\n",
    "language": "zh-CN"
  },
  "group_id": "https://www.ammitto.org/group/cn/5",
  "legal_citations": [
    {
      "legal_instrument_id": "https://www.ammitto.org/legal-instrument/cn/npc-anti-foreign-sanctions-law",
