<https://www.ammitto.org/entry/cn/unreliable-entity-list/202510-dedrone-by-axon>
  ammitto:entity_id <https://www.ammitto.org/entity/cn/202510-dedrone-by-axon> ;\n  ammitto:hasAuthority <https://www.ammitto.org/authority/cn> ;\n  ammitto:hasRegime <https://www.ammitto.org/regime/cn_unreliable_entity> ;\n  ammitto:hasEffect """{"effect_type":"prohibit_import_export","scope":"full","description":[{"value":"禁止上述实体从事与中国有关的进出口活动","lang":"zh","script":"Hani","is_primary":true},{"value":"Prohibit the entity from engaging in import and export activities related to China","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasEffect """{"effect_type":"prohibit_investment_new","scope":"full","description":[{"value":"禁止上述实体在中国境内新增投资","lang":"zh","script":"Hani","is_primary":true},{"value":"Prohibit the entity from making new investments in China","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasEffect """{"effect_type":"prohibit_transactions","scope":"full","description":[{"value":"禁止中国境内的组织、个人与上述实体进行有关交易、合作等活动，特别是向上述实体传输数据、提供敏感信息\n","lang":"zh","script":"Hani","is_primary":true},{"value":"Prohibit organizations and individuals in China from engaging in\ntransactions, cooperation, etc. with the entity, especially\ntransmitting data and providing sensitive information to the entity\n","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasReason """{"category":"other","description":[{"value":"为维护国家主权、安全和发展利益。","lang":"zh","script":"Hani","is_primary":true},{"value":"To safeguard national sovereignty, security and development interests.","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasPeriod """{"effective_date":"2025-10-09","is_indefinite":false}""" ;\n  ammitto:status "active" ;\n  ammitto:reference_number "202510-dedrone-by-axon" ;\n  ammitto:announcement """{"title":"不可靠实体清单工作机制关于将反无人机技术公司等外国实体列入不可靠实体清单的公告","url":"https://www.mofcom.gov.cn/zwgk/zcfb/art/2025/art_9b662990fa4a4d26ba3984ab5d826960.html","publish_date":"2025-10-09","publish_time":"16:00","document_type":"cn/unreliable-entity-list-working-mechanism-announcement","document_id":"〔2025〕10号","signatory":"cn/unreliable-entity-list-working-mechanism","publisher":"cn/ministry-of-commerce-industry-security-and-import-export-control","authority":"cn/unreliable-entity-list-working-mechanism","content":"为维护国家主权、安全和发展利益，根据《中华人民共和国对外贸易法》《中华人民共\n和国国家安全法》《中华人民共和国反外国制裁法》等有关法律，不可靠实体清单工作\n机制依据《不可靠实体清单规定》第二条、第八条和第十条等有关规定，决定将反无人\n机技术公司、TechInsights公司及其分支机构等外国实体列入不可靠实体清单，并采取\n以下处理措施：\n\n一、禁止上述实体从事与中国有关的进出口活动；\n\n二、禁止上述实体在中国境内新增投资；\n\n三、禁止中国境内的组织、个人与上述实体进行有关交易、合作等活动，特别是向上述实体传输数据、提供敏感信息。\n\n本公告未尽事宜，按《不可靠实体清单规定》执行。\n\n本公告自公布之日起实施。\n\n附：被列入不可靠实体清单的外国实体\n\n不可靠实体清单工作机制\n（商务部代章）\n2025年10月9日\n\n附\n\n被列入不可靠实体清单的外国实体\n\n1. 反无人机技术公司（Dedrone by Axon）\n2. 迪杰恩技术公司（DZYNE Technologies）\n3. 埃比特系统美国分公司（Elbit Systems of America, LLC）\n4. 伊比鲁斯公司（Epirus, Inc.）\n5. 宇航环境公司（AeroVironment, Inc.）\n6. Exelis公司（Exelis Inc.）\n7. 联合技术系统运营公司（Alliant Techsystems Operations LLC）\n8. 贝宜系统股份有限公司（BAE Systems, Inc.）\n9. Teledyne FLIR公司（Teledyne FLIR, LLC）\n10. VSE公司（VSE Corporation）\n11. 立方全球防务公司(Cubic Global Defense)\n12. Recorded Future公司（Recorded Future, Inc.）\n13. 哈利法克斯国际安全论坛 （Halifax International Security Forum）\n14. TechInsights公司（TechInsights Inc.）及其分支机构\n  - TechInsights Inc.\n  - TechInsights Europe Limited\n  - TechInsights Europe Sp zo.o\n  - TechInsights Japan KK\n  - TechInsights USA Inc\n  - TechInsights Korea Co. Ltd.\n  - TechInsights Market Analysis Limited\n  - SARL Strategy Analytics\n  - Strategy Analytics GmbH Market Research and Management Consulting\n  - SARI Strategy Analytics Private Limited\n","language":"zh-CN"}""" ;\n  ammitto:group_id <https://www.ammitto.org/group/cn/202510> ;\n  ammitto:legal_citations """{"legal_instrument_id":"https://www.ammitto.org/legal-instrument/cn/npc-foreign-trade-law-2025","citation_type":"legal_basis"}""" ;\n  ammitto:legal_citations """{"legal_instrument_id":"https://www.ammitto.org/legal-instrument/cn/npc-national-security-law-2015","citation_type":"legal_basis"}""" ;\n  ammitto:legal_citations """{"legal_instrument_id":"https://www.ammitto.org/legal-instrument/cn/npc-anti-foreign-sanctions-law","citation_type":"legal_basis"}""" ;\n  ammitto:legal_citations """{"legal_instrument_id":"https://www.ammitto.org/legal-instrument/cn/mofcom-unreliable-entity-list-provisions","articles":["第二条","第八条","第十条"],"citation_type":"legal_basis"}""" ;\n  ammitto:raw_source_data """{"source_format":"yaml","source_specific_fields":{"cn:list_type":"unreliable_entity","cn:sanction_list":"不可靠实体清单","cn:chinese_name":"反无人机技术公司","cn:english_name":"Dedrone by Axon"}}""" .
