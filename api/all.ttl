<https://www.ammitto.org/entry/cn/anti-sanction-list/10-matthew-marley-grimm>
  ammitto:entity_id <https://www.ammitto.org/entity/cn/10-matthew-marley-grimm> ;\n  ammitto:hasAuthority <https://www.ammitto.org/authority/cn> ;\n  ammitto:hasRegime <https://www.ammitto.org/regime/cn_anti_sanctions> ;\n  ammitto:hasEffect """{"effect_type":"asset_freeze","scope":"full","description":[{"value":"冻结在我国境内的动产、不动产和其他各类财产","lang":"zh","script":"Hani","is_primary":true},{"value":"Freeze all assets in China, including movable and immovable property and other types of assets","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasEffect """{"effect_type":"prohibit_transactions","scope":"full","description":[{"value":"禁止我国境内的组织、个人与其本人进行有关交易、合作等活动","lang":"zh","script":"Hani","is_primary":true},{"value":"Prohibit organizations and individuals in China from engaging in transactions, cooperation or related activities with the entity","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasEffect """{"effect_type":"visa_ban","scope":"full","description":[{"value":"对其本人不予签发签证、不准入境（包括香港、澳门）","lang":"zh","script":"Hani","is_primary":true},{"value":"Visa ban and entry prohibition for the individual (including Hong Kong and Macao)","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasReason """{"category":"other","description":[{"value":"美国近日再次宣布向中国台湾地区出售武器，严重违反一个中国原则和中美三个联合公报，严重干涉中国内政，严重损害中国主权和领土完整。","lang":"zh","script":"Hani","is_primary":true},{"value":"The US recently announced again the sale of weapons to China's Taiwan region, seriously violating the One-China principle and the three China-US joint communiqués.","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasPeriod """{"effective_date":"2024-07-12","is_indefinite":false}""" ;\n  ammitto:status "active" ;\n  ammitto:reference_number "10-matthew-marley-grimm" ;\n  ammitto:announcement """{"title":"关于对美国军工企业及高级管理人员采取反制措施的决定","url":"https://www.mfa.gov.cn/web/wjb_673085/zfxxgk_674865/gknrlb/fzcqdcs/202407/t20240712_11453049.shtml","publish_date":"2024-07-12","publish_time":"18:10","document_type":"cn/ministry-of-foreign-affairs-order","document_id":"第10号","signatory":"cn/ministry-of-foreign-affairs","publisher":"cn/ministry-of-foreign-affairs","authority":"cn/ministry-of-foreign-affairs","content":"（2024年7月12日中华人民共和国外交部令第10号公布，自2024年7月12日起施行）\n\n美国近日再次宣布向中国台湾地区出售武器，严重违反一个中国原则和中美三个联合公报，严重干涉中国内政，严重损害中国主权和领土完整。依据《中华人民共和国反外国制裁法》第三条、第四条、第五条、第六条、第九条、第十五条规定，中方决定对以下美国军工企业及高级管理人员采取反制措施：\n\n一、对安杜里尔公司、海上战术系统公司、环太平洋防务公司、AEVEX航天公司、LKD航天公司、顶峰科技公司等6家后附《反制清单》列明的企业，冻结在我国境内的动产、不动产和其他各类财产。\n\n二、对宇航环境公司董事长、总裁、首席执行官瓦希德·纳瓦比、宇航环境公司高级副总裁、首席财务官凯文·麦克唐奈、安杜里尔公司首席执行官布赖恩·申普夫、安杜里尔公司首席运营官马修·格里姆、安杜里尔公司负责全球防务的高级副总裁格雷戈里·考斯纳等5名后附《反制清单》列明的企业高级管理人员，冻结在我国境内的动产、不动产和其他各类财产；禁止我国境内的组织、个人与其本人进行有关交易、合作等活动；对其本人不予签发签证、不准入境（包括香港、澳门）。\n\n本决定自2024年7月12日起施行。\n\n附件：反制清单\n\n外交部\n2024年7月12日\n","language":"zh-CN"}""" ;\n  ammitto:group_id <https://www.ammitto.org/group/cn/10> ;\n  ammitto:legal_citations """{"legal_instrument_id":"https://www.ammitto.org/legal-instrument/cn/npc-anti-foreign-sanctions-law","articles":["第三条","第四条","第五条","第六条","第九条","第十五条"],"citation_type":"legal_basis"}""" ;\n  ammitto:raw_source_data """{"source_format":"yaml","source_specific_fields":{"cn:list_type":"anti_sanctions","cn:sanction_list":"反制裁清单","cn:chinese_name":"马修·格里姆","cn:english_name":"Matthew Marley Grimm"}}""" .
<https://www.ammitto.org/entry/cn/anti-sanction-list/10-gregory-michael-kausner>
  ammitto:entity_id <https://www.ammitto.org/entity/cn/10-gregory-michael-kausner> ;\n  ammitto:hasAuthority <https://www.ammitto.org/authority/cn> ;\n  ammitto:hasRegime <https://www.ammitto.org/regime/cn_anti_sanctions> ;\n  ammitto:hasEffect """{"effect_type":"asset_freeze","scope":"full","description":[{"value":"冻结在我国境内的动产、不动产和其他各类财产","lang":"zh","script":"Hani","is_primary":true},{"value":"Freeze all assets in China, including movable and immovable property and other types of assets","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasEffect """{"effect_type":"prohibit_transactions","scope":"full","description":[{"value":"禁止我国境内的组织、个人与其本人进行有关交易、合作等活动","lang":"zh","script":"Hani","is_primary":true},{"value":"Prohibit organizations and individuals in China from engaging in transactions, cooperation or related activities with the entity","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasEffect """{"effect_type":"visa_ban","scope":"full","description":[{"value":"对其本人不予签发签证、不准入境（包括香港、澳门）","lang":"zh","script":"Hani","is_primary":true},{"value":"Visa ban and entry prohibition for the individual (including Hong Kong and Macao)","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasReason """{"category":"other","description":[{"value":"美国近日再次宣布向中国台湾地区出售武器，严重违反一个中国原则和中美三个联合公报，严重干涉中国内政，严重损害中国主权和领土完整。","lang":"zh","script":"Hani","is_primary":true},{"value":"The US recently announced again the sale of weapons to China's Taiwan region, seriously violating the One-China principle and the three China-US joint communiqués.","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasPeriod """{"effective_date":"2024-07-12","is_indefinite":false}""" ;\n  ammitto:status "active" ;\n  ammitto:reference_number "10-gregory-michael-kausner" ;\n  ammitto:announcement """{"title":"关于对美国军工企业及高级管理人员采取反制措施的决定","url":"https://www.mfa.gov.cn/web/wjb_673085/zfxxgk_674865/gknrlb/fzcqdcs/202407/t20240712_11453049.shtml","publish_date":"2024-07-12","publish_time":"18:10","document_type":"cn/ministry-of-foreign-affairs-order","document_id":"第10号","signatory":"cn/ministry-of-foreign-affairs","publisher":"cn/ministry-of-foreign-affairs","authority":"cn/ministry-of-foreign-affairs","content":"（2024年7月12日中华人民共和国外交部令第10号公布，自2024年7月12日起施行）\n\n美国近日再次宣布向中国台湾地区出售武器，严重违反一个中国原则和中美三个联合公报，严重干涉中国内政，严重损害中国主权和领土完整。依据《中华人民共和国反外国制裁法》第三条、第四条、第五条、第六条、第九条、第十五条规定，中方决定对以下美国军工企业及高级管理人员采取反制措施：\n\n一、对安杜里尔公司、海上战术系统公司、环太平洋防务公司、AEVEX航天公司、LKD航天公司、顶峰科技公司等6家后附《反制清单》列明的企业，冻结在我国境内的动产、不动产和其他各类财产。\n\n二、对宇航环境公司董事长、总裁、首席执行官瓦希德·纳瓦比、宇航环境公司高级副总裁、首席财务官凯文·麦克唐奈、安杜里尔公司首席执行官布赖恩·申普夫、安杜里尔公司首席运营官马修·格里姆、安杜里尔公司负责全球防务的高级副总裁格雷戈里·考斯纳等5名后附《反制清单》列明的企业高级管理人员，冻结在我国境内的动产、不动产和其他各类财产；禁止我国境内的组织、个人与其本人进行有关交易、合作等活动；对其本人不予签发签证、不准入境（包括香港、澳门）。\n\n本决定自2024年7月12日起施行。\n\n附件：反制清单\n\n外交部\n2024年7月12日\n","language":"zh-CN"}""" ;\n  ammitto:group_id <https://www.ammitto.org/group/cn/10> ;\n  ammitto:legal_citations """{"legal_instrument_id":"https://www.ammitto.org/legal-instrument/cn/npc-anti-foreign-sanctions-law","articles":["第三条","第四条","第五条","第六条","第九条","第十五条"],"citation_type":"legal_basis"}""" ;\n  ammitto:raw_source_data """{"source_format":"yaml","source_specific_fields":{"cn:list_type":"anti_sanctions","cn:sanction_list":"反制裁清单","cn:chinese_name":"格雷戈里·考斯纳","cn:english_name":"Gregory Michael Kausner"}}""" .
<https://www.ammitto.org/entry/cn/anti-sanction-list/11-jim-mcgovern>
  ammitto:entity_id <https://www.ammitto.org/entity/cn/11-jim-mcgovern> ;\n  ammitto:hasAuthority <https://www.ammitto.org/authority/cn> ;\n  ammitto:hasRegime <https://www.ammitto.org/regime/cn_anti_sanctions> ;\n  ammitto:hasEffect """{"effect_type":"asset_freeze","scope":"full","description":[{"value":"冻结在我国境内的动产、不动产和其他各类财产","lang":"zh","script":"Hani","is_primary":true},{"value":"Freeze all assets in China, including movable and immovable property and other types of assets","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasEffect """{"effect_type":"prohibit_transactions","scope":"full","description":[{"value":"禁止我国境内的组织、个人与其本人进行有关交易、合作等活动","lang":"zh","script":"Hani","is_primary":true},{"value":"Prohibit organizations and individuals in China from engaging in transactions, cooperation or related activities with the entity","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasEffect """{"effect_type":"visa_ban","scope":"full","description":[{"value":"对其本人及其配偶、子女不予签发签证、不准入境","lang":"zh","script":"Hani","is_primary":true},{"value":"Visa ban and entry prohibition for the individual and his spouse and children","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasReason """{"category":"other","description":[{"value":"近年来频繁采取干涉中国内政、损害中国主权安全发展利益的言行。","lang":"zh","script":"Hani","is_primary":true},{"value":"Frequently engaged in actions interfering in China's internal affairs and damaging China's sovereignty, security and development interests.","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasPeriod """{"effective_date":"2024-07-31","is_indefinite":false}""" ;\n  ammitto:status "active" ;\n  ammitto:reference_number "11-jim-mcgovern" ;\n  ammitto:announcement """{"title":"关于对美国国会议员麦戈文采取反制措施的决定","url":"https://www.mfa.gov.cn/web/wjb_673085/zfxxgk_674865/gknrlb/fzcqdcs/202407/t20240731_11463924.shtml","publish_date":"2024-07-31","publish_time":"18:21","document_type":"cn/ministry-of-foreign-affairs-order","document_id":"第11号","signatory":"cn/ministry-of-foreign-affairs","publisher":"cn/ministry-of-foreign-affairs","authority":"cn/ministry-of-foreign-affairs","content":"（2024年7月31日中华人民共和国外交部令第11号公布，自2024年7月31日起施行）\n\n美国马萨诸塞州民主党联邦众议员吉姆·麦戈文近年来频繁采取干涉中国内政、损害中国主权安全发展利益的言行。依据《中华人民共和国反外国制裁法》第三条、第四条、第五条、第六条、第九条、第十五条规定，中方决定对麦戈文采取以下反制措施：\n\n一、冻结在我国境内的动产、不动产和其他各类财产；\n二、禁止我国境内的组织、个人与其本人进行有关交易、合作等活动；\n三、对其本人及其配偶、子女不予签发签证、不准入境。\n\n本决定自2024年7月31日起施行。\n\n附件：反制清单\n\n外交部\n2024年7月31日\n\n附件\n反制清单\n\n美国马萨诸塞州民主党联邦众议员吉姆·麦戈文（Jim McGovern）\n","language":"zh-CN"}""" ;\n  ammitto:legal_citations """{"legal_instrument_id":"https://www.ammitto.org/legal-instrument/cn/npc-anti-foreign-sanctions-law","articles":["第三条","第四条","第五条","第六条","第九条","第十五条"],"citation_type":"legal_basis"}""" ;\n  ammitto:raw_source_data """{"source_format":"yaml","source_specific_fields":{"cn:list_type":"anti_sanctions","cn:sanction_list":"反制裁清单","cn:chinese_name":"吉姆·麦戈文","cn:english_name":"Jim McGovern"}}""" .
<https://www.ammitto.org/entry/cn/anti-sanction-list/12-sierra-nevada-corporation>
  ammitto:entity_id <https://www.ammitto.org/entity/cn/12-sierra-nevada-corporation> ;\n  ammitto:hasAuthority <https://www.ammitto.org/authority/cn> ;\n  ammitto:hasRegime <https://www.ammitto.org/regime/cn_anti_sanctions> ;\n  ammitto:hasEffect """{"effect_type":"asset_freeze","scope":"full","description":[{"value":"冻结在我国境内的动产、不动产和其他各类财产","lang":"zh","script":"Hani","is_primary":true},{"value":"Freeze all assets in China, including movable and immovable property and other types of assets","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasEffect """{"effect_type":"prohibit_transactions","scope":"full","description":[{"value":"禁止我国境内的组织、个人与其进行有关交易、合作等活动","lang":"zh","script":"Hani","is_primary":true},{"value":"Prohibit organizations and individuals in China from engaging in transactions, cooperation or related activities with the entity","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasReason """{"category":"other","description":[{"value":"美国近日再次宣布向中国台湾地区出售武器，严重违反一个中国原则和中美三个联合公报，严重干涉中国内政，严重损害中国主权和领土完整。","lang":"zh","script":"Hani","is_primary":true},{"value":"The US recently announced again the sale of weapons to China's Taiwan region, seriously violating the One-China principle and the three China-US joint communiqués.","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasPeriod """{"effective_date":"2024-09-18","is_indefinite":false}""" ;\n  ammitto:status "active" ;\n  ammitto:reference_number "12-sierra-nevada-corporation" ;\n  ammitto:announcement """{"title":"关于对美国军工企业采取反制措施的决定","url":"https://www.mfa.gov.cn/web/wjb_673085/zfxxgk_674865/gknrlb/fzcqdcs/202409/t20240918_11492303.shtml","publish_date":"2024-09-18","publish_time":"14:43","document_type":"cn/ministry-of-foreign-affairs-order","document_id":"第12号","signatory":"cn/ministry-of-foreign-affairs","publisher":"cn/ministry-of-foreign-affairs","authority":"cn/ministry-of-foreign-affairs","content":"（2024年9月18日中华人民共和国外交部令第12号公布，自2024年9月18日起施行）\n\n美国近日再次宣布向中国台湾地区出售武器，严重违反一个中国原则和中美三个联合公报，严重干涉中国内政，严重损害中国主权和领土完整。依据《中华人民共和国反外国制裁法》第三条、第四条、第六条、第九条、第十五条规定，中方决定对美国内华达山脉公司、摇杆舵公司、立方公司、S3航空防务公司、特科姆公司、文本矿公司、扁平地球管理公司、ACT1联邦公司、埃克索维拉公司等9家后附《反制清单》列明的企业采取以下反制措施：\n\n一、冻结在我国境内的动产、不动产和其他各类财产；\n二、禁止我国境内的组织、个人与其进行有关交易、合作等活动。\n\n本决定自2024年9月18日起施行。\n\n附件：反制清单\n\n外交部\n2024年9月18日\n","language":"zh-CN"}""" ;\n  ammitto:group_id <https://www.ammitto.org/group/cn/12> ;\n  ammitto:legal_citations """{"legal_instrument_id":"https://www.ammitto.org/legal-instrument/cn/npc-anti-foreign-sanctions-law","articles":["第三条","第四条","第六条","第九条","第十五条"],"citation_type":"legal_basis"}""" ;\n  ammitto:raw_source_data """{"source_format":"yaml","source_specific_fields":{"cn:list_type":"anti_sanctions","cn:sanction_list":"反制裁清单","cn:chinese_name":"内华达山脉公司","cn:english_name":"Sierra Nevada Corporation"}}""" .
