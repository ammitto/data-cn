  ammitto:entity_id <https://www.ammitto.org/entity/cn/15-samphe-lhalungpa> ;\n  ammitto:hasAuthority <https://www.ammitto.org/authority/cn> ;\n  ammitto:hasRegime <https://www.ammitto.org/regime/cn_anti_sanctions> ;\n  ammitto:hasEffect """{"effect_type":"asset_freeze","scope":"full","description":[{"value":"冻结在我国境内的动产、不动产和其他各类财产","lang":"zh","script":"Hani","is_primary":true},{"value":"Freeze all assets in China, including movable and immovable property and other types of assets","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasEffect """{"effect_type":"prohibit_transactions","scope":"full","description":[{"value":"禁止我国境内的组织、个人与其本人进行有关交易、合作等活动","lang":"zh","script":"Hani","is_primary":true},{"value":"Prohibit organizations and individuals in China from engaging in transactions, cooperation or related activities with the entity","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasEffect """{"effect_type":"visa_ban","scope":"full","description":[{"value":"对其本人不予签发签证、不准入境（包括香港、澳门）","lang":"zh","script":"Hani","is_primary":true},{"value":"Visa ban and entry prohibition (including Hong Kong and Macao)","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasReason """{"category":"other","description":[{"value":"依据《中华人民共和国反外国制裁法》相关规定","lang":"zh","script":"Hani","is_primary":true},{"value":"According to relevant provisions of the Law of the People's Republic of China on Countering Foreign Sanctions","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasPeriod """{"effective_date":"2024-12-21","is_indefinite":false}""" ;\n  ammitto:status "active" ;\n  ammitto:reference_number "15-samphe-lhalungpa" ;\n  ammitto:announcement """{"title":"关于对加拿大机构及人员采取反制措施的决定","url":"https://www.mfa.gov.cn/web/wjb_673085/zfxxgk_674865/gknrlb/fzcqdcs/202412/t20241222_11514801.shtml","publish_date":"2024-12-21","publish_time":"16:50","document_type":"cn/ministry-of-foreign-affairs-order","document_id":"第15号","signatory":"cn/ministry-of-foreign-affairs","publisher":"cn/ministry-of-foreign-affairs","authority":"cn/ministry-of-foreign-affairs","content":"（2024年12月21日中华人民共和国外交部令第15号公布，自2024年12月21日起施行）\n\n依据《中华人民共和国反外国制裁法》第三条、第四条、第五条、第六条、第九条、第十五条规定，中方决定对以下加拿大机构及人员（详见后附反制清单）采取反制措施：\n\n一、对加拿大\"维吾尔人权倡导项目\"、\"加拿大西藏委员会\"，冻结在我国境内的动产、不动产和其他各类财产；禁止我国境内的组织、个人与其进行有关交易、合作等活动。\n二、对加拿大\"维吾尔人权倡导项目\"、\"加拿大西藏委员会\"相关人员，冻结在我国境内的动产、不动产和其他各类财产；禁止我国境内的组织、个人与其本人进行有关交易、合作等活动；对其本人不予签发签证、不准入境（包括香港、澳门）。\n\n本决定自2024年12月21日起施行。\n","language":"zh-CN"}""" ;\n  ammitto:group_id <https://www.ammitto.org/group/cn/15> ;\n  ammitto:legal_citations """{"legal_instrument_id":"https://www.ammitto.org/legal-instrument/cn/npc-anti-foreign-sanctions-law","articles":["第三条","第四条","第五条","第六条","第九条","第十五条"],"citation_type":"legal_basis"}""" ;\n  ammitto:raw_source_data """{"source_format":"yaml","source_specific_fields":{"cn:list_type":"anti_sanctions","cn:sanction_list":"反制裁清单","cn:chinese_name":"桑佩·拉隆巴","cn:english_name":"Samphe Lhalungpa"}}""" .
<https://www.ammitto.org/entry/cn/anti-sanction-list/15-luisa-durante>
  ammitto:entity_id <https://www.ammitto.org/entity/cn/15-luisa-durante> ;\n  ammitto:hasAuthority <https://www.ammitto.org/authority/cn> ;\n  ammitto:hasRegime <https://www.ammitto.org/regime/cn_anti_sanctions> ;\n  ammitto:hasEffect """{"effect_type":"asset_freeze","scope":"full","description":[{"value":"冻结在我国境内的动产、不动产和其他各类财产","lang":"zh","script":"Hani","is_primary":true},{"value":"Freeze all assets in China, including movable and immovable property and other types of assets","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasEffect """{"effect_type":"prohibit_transactions","scope":"full","description":[{"value":"禁止我国境内的组织、个人与其本人进行有关交易、合作等活动","lang":"zh","script":"Hani","is_primary":true},{"value":"Prohibit organizations and individuals in China from engaging in transactions, cooperation or related activities with the entity","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasEffect """{"effect_type":"visa_ban","scope":"full","description":[{"value":"对其本人不予签发签证、不准入境（包括香港、澳门）","lang":"zh","script":"Hani","is_primary":true},{"value":"Visa ban and entry prohibition (including Hong Kong and Macao)","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasReason """{"category":"other","description":[{"value":"依据《中华人民共和国反外国制裁法》相关规定","lang":"zh","script":"Hani","is_primary":true},{"value":"According to relevant provisions of the Law of the People's Republic of China on Countering Foreign Sanctions","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasPeriod """{"effective_date":"2024-12-21","is_indefinite":false}""" ;\n  ammitto:status "active" ;\n  ammitto:reference_number "15-luisa-durante" ;\n  ammitto:announcement """{"title":"关于对加拿大机构及人员采取反制措施的决定","url":"https://www.mfa.gov.cn/web/wjb_673085/zfxxgk_674865/gknrlb/fzcqdcs/202412/t20241222_11514801.shtml","publish_date":"2024-12-21","publish_time":"16:50","document_type":"cn/ministry-of-foreign-affairs-order","document_id":"第15号","signatory":"cn/ministry-of-foreign-affairs","publisher":"cn/ministry-of-foreign-affairs","authority":"cn/ministry-of-foreign-affairs","content":"（2024年12月21日中华人民共和国外交部令第15号公布，自2024年12月21日起施行）\n\n依据《中华人民共和国反外国制裁法》第三条、第四条、第五条、第六条、第九条、第十五条规定，中方决定对以下加拿大机构及人员（详见后附反制清单）采取反制措施：\n\n一、对加拿大\"维吾尔人权倡导项目\"、\"加拿大西藏委员会\"，冻结在我国境内的动产、不动产和其他各类财产；禁止我国境内的组织、个人与其进行有关交易、合作等活动。\n二、对加拿大\"维吾尔人权倡导项目\"、\"加拿大西藏委员会\"相关人员，冻结在我国境内的动产、不动产和其他各类财产；禁止我国境内的组织、个人与其本人进行有关交易、合作等活动；对其本人不予签发签证、不准入境（包括香港、澳门）。\n\n本决定自2024年12月21日起施行。\n","language":"zh-CN"}""" ;\n  ammitto:group_id <https://www.ammitto.org/group/cn/15> ;\n  ammitto:legal_citations """{"legal_instrument_id":"https://www.ammitto.org/legal-instrument/cn/npc-anti-foreign-sanctions-law","articles":["第三条","第四条","第五条","第六条","第九条","第十五条"],"citation_type":"legal_basis"}""" ;\n  ammitto:raw_source_data """{"source_format":"yaml","source_specific_fields":{"cn:list_type":"anti_sanctions","cn:sanction_list":"反制裁清单","cn:chinese_name":"路易莎·杜兰特","cn:english_name":"Luisa Durante"}}""" .
<https://www.ammitto.org/entry/cn/anti-sanction-list/16-insitu-inc>
  ammitto:entity_id <https://www.ammitto.org/entity/cn/16-insitu-inc> ;\n  ammitto:hasAuthority <https://www.ammitto.org/authority/cn> ;\n  ammitto:hasRegime <https://www.ammitto.org/regime/cn_anti_sanctions> ;\n  ammitto:hasEffect """{"effect_type":"asset_freeze","scope":"full","description":[{"value":"冻结在我国境内的动产、不动产和其他各类财产","lang":"zh","script":"Hani","is_primary":true},{"value":"Freeze all assets in China, including movable and immovable property and other types of assets","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasEffect """{"effect_type":"prohibit_transactions","scope":"full","description":[{"value":"禁止我国境内的组织、个人与其进行有关交易、合作等活动","lang":"zh","script":"Hani","is_primary":true},{"value":"Prohibit organizations and individuals in China from engaging in transactions, cooperation or related activities with the entity","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasReason """{"category":"other","description":[{"value":"美国近日再次宣布向中国台湾地区提供大额武器援助并出售武器，美国\"2025财年国防授权法案\"包括多项涉华消极条款，严重违反一个中国原则和中美三个联合公报，严重干涉中国内政，严重损害中国主权和领土完整。","lang":"zh","script":"Hani","is_primary":true},{"value":"The US recently announced providing large-scale weapons assistance and selling weapons to China's Taiwan region, and the US \"2025 National Defense Authorization Act\" includes multiple negative provisions related to China, seriously violating the One-China principle and the three China-US joint communiqués, seriously interfering in China's internal affairs, and seriously damaging China's sovereignty and territorial integrity.","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasPeriod """{"effective_date":"2024-12-27","is_indefinite":false}""" ;\n  ammitto:status "active" ;\n  ammitto:reference_number "16-insitu-inc" ;\n  ammitto:announcement """{"title":"关于对美国军工企业及高级管理人员采取反制措施的决定","url":"https://www.mfa.gov.cn/web/wjb_673085/zfxxgk_674865/gknrlb/fzcqdcs/202412/t20241227_11520050.shtml","publish_date":"2024-12-27","publish_time":"15:00","document_type":"cn/ministry-of-foreign-affairs-order","document_id":"第16号","signatory":"cn/ministry-of-foreign-affairs","publisher":"cn/ministry-of-foreign-affairs","authority":"cn/ministry-of-foreign-affairs","content":"（2024年12月27日中华人民共和国外交部令第16号公布，自2024年12月27日起施行）\n\n美国近日再次宣布向中国台湾地区提供大额武器援助并出售武器，美国\"2025财年国防授权法案\"包括多项涉华消极条款，严重违反一个中国原则和中美三个联合公报，严重干涉中国内政，严重损害中国主权和领土完整。\n\n依据《中华人民共和国反外国制裁法》第三条、第四条、第五条、第六条、第九条、第十五条规定，中方决定对英斯图公司、哈德森技术公司、萨罗尼克科技公司、雷神加拿大公司、雷神澳大利亚公司、爱尔康公司、国际海洋工程公司等7家后附《反制清单》列明的企业及相关高级管理人员采取以下反制措施：\n\n一、冻结在我国境内的动产、不动产和其他各类财产；\n二、禁止我国境内的组织、个人与其进行有关交易、合作等活动。\n\n本决定自2024年12月27日起施行。\n","language":"zh-CN"}""" ;\n  ammitto:group_id <https://www.ammitto.org/group/cn/16> ;\n  ammitto:legal_citations """{"legal_instrument_id":"https://www.ammitto.org/legal-instrument/cn/npc-anti-foreign-sanctions-law","articles":["第三条","第四条","第五条","第六条","第九条","第十五条"],"citation_type":"legal_basis"}""" ;\n  ammitto:raw_source_data """{"source_format":"yaml","source_specific_fields":{"cn:list_type":"anti_sanctions","cn:sanction_list":"反制裁清单","cn:chinese_name":"英斯图公司","cn:english_name":"Insitu, Inc."}}""" .
<https://www.ammitto.org/entry/cn/anti-sanction-list/16-hudson-technologies-co>
  ammitto:entity_id <https://www.ammitto.org/entity/cn/16-hudson-technologies-co> ;\n  ammitto:hasAuthority <https://www.ammitto.org/authority/cn> ;\n  ammitto:hasRegime <https://www.ammitto.org/regime/cn_anti_sanctions> ;\n  ammitto:hasEffect """{"effect_type":"asset_freeze","scope":"full","description":[{"value":"冻结在我国境内的动产、不动产和其他各类财产","lang":"zh","script":"Hani","is_primary":true},{"value":"Freeze all assets in China, including movable and immovable property and other types of assets","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasEffect """{"effect_type":"prohibit_transactions","scope":"full","description":[{"value":"禁止我国境内的组织、个人与其进行有关交易、合作等活动","lang":"zh","script":"Hani","is_primary":true},{"value":"Prohibit organizations and individuals in China from engaging in transactions, cooperation or related activities with the entity","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasReason """{"category":"other","description":[{"value":"美国近日再次宣布向中国台湾地区提供大额武器援助并出售武器，美国\"2025财年国防授权法案\"包括多项涉华消极条款，严重违反一个中国原则和中美三个联合公报，严重干涉中国内政，严重损害中国主权和领土完整。","lang":"zh","script":"Hani","is_primary":true},{"value":"The US recently announced providing large-scale weapons assistance and selling weapons to China's Taiwan region, and the US \"2025 National Defense Authorization Act\" includes multiple negative provisions related to China, seriously violating the One-China principle and the three China-US joint communiqués, seriously interfering in China's internal affairs, and seriously damaging China's sovereignty and territorial integrity.","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasPeriod """{"effective_date":"2024-12-27","is_indefinite":false}""" ;\n  ammitto:status "active" ;\n  ammitto:reference_number "16-hudson-technologies-co" ;\n  ammitto:announcement """{"title":"关于对美国军工企业及高级管理人员采取反制措施的决定","url":"https://www.mfa.gov.cn/web/wjb_673085/zfxxgk_674865/gknrlb/fzcqdcs/202412/t20241227_11520050.shtml","publish_date":"2024-12-27","publish_time":"15:00","document_type":"cn/ministry-of-foreign-affairs-order","document_id":"第16号","signatory":"cn/ministry-of-foreign-affairs","publisher":"cn/ministry-of-foreign-affairs","authority":"cn/ministry-of-foreign-affairs","content":"（2024年12月27日中华人民共和国外交部令第16号公布，自2024年12月27日起施行）\n\n美国近日再次宣布向中国台湾地区提供大额武器援助并出售武器，美国\"2025财年国防授权法案\"包括多项涉华消极条款，严重违反一个中国原则和中美三个联合公报，严重干涉中国内政，严重损害中国主权和领土完整。\n\n依据《中华人民共和国反外国制裁法》第三条、第四条、第五条、第六条、第九条、第十五条规定，中方决定对英斯图公司、哈德森技术公司、萨罗尼克科技公司、雷神加拿大公司、雷神澳大利亚公司、爱尔康公司、国际海洋工程公司等7家后附《反制清单》列明的企业及相关高级管理人员采取以下反制措施：\n\n一、冻结在我国境内的动产、不动产和其他各类财产；\n二、禁止我国境内的组织、个人与其进行有关交易、合作等活动。\n\n本决定自2024年12月27日起施行。\n","language":"zh-CN"}""" ;\n  ammitto:group_id <https://www.ammitto.org/group/cn/16> ;\n  ammitto:legal_citations """{"legal_instrument_id":"https://www.ammitto.org/legal-instrument/cn/npc-anti-foreign-sanctions-law","articles":["第三条","第四条","第五条","第六条","第九条","第十五条"],"citation_type":"legal_basis"}""" ;\n  ammitto:raw_source_data """{"source_format":"yaml","source_specific_fields":{"cn:list_type":"anti_sanctions","cn:sanction_list":"反制裁清单","cn:chinese_name":"哈德森技术公司","cn:english_name":"Hudson Technologies Co."}}""" .
<https://www.ammitto.org/entry/cn/anti-sanction-list/16-saronic-technologies-inc>
  ammitto:entity_id <https://www.ammitto.org/entity/cn/16-saronic-technologies-inc> ;\n  ammitto:hasAuthority <https://www.ammitto.org/authority/cn> ;\n  ammitto:hasRegime <https://www.ammitto.org/regime/cn_anti_sanctions> ;\n  ammitto:hasEffect """{"effect_type":"asset_freeze","scope":"full","description":[{"value":"冻结在我国境内的动产、不动产和其他各类财产","lang":"zh","script":"Hani","is_primary":true},{"value":"Freeze all assets in China, including movable and immovable property and other types of assets","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasEffect """{"effect_type":"prohibit_transactions","scope":"full","description":[{"value":"禁止我国境内的组织、个人与其进行有关交易、合作等活动","lang":"zh","script":"Hani","is_primary":true},{"value":"Prohibit organizations and individuals in China from engaging in transactions, cooperation or related activities with the entity","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasReason """{"category":"other","description":[{"value":"美国近日再次宣布向中国台湾地区提供大额武器援助并出售武器，美国\"2025财年国防授权法案\"包括多项涉华消极条款，严重违反一个中国原则和中美三个联合公报，严重干涉中国内政，严重损害中国主权和领土完整。","lang":"zh","script":"Hani","is_primary":true},{"value":"The US recently announced providing large-scale weapons assistance and selling weapons to China's Taiwan region, and the US \"2025 National Defense Authorization Act\" includes multiple negative provisions related to China, seriously violating the One-China principle and the three China-US joint communiqués, seriously interfering in China's internal affairs, and seriously damaging China's sovereignty and territorial integrity.","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasPeriod """{"effective_date":"2024-12-27","is_indefinite":false}""" ;\n  ammitto:status "active" ;\n  ammitto:reference_number "16-saronic-technologies-inc" ;\n  ammitto:announcement """{"title":"关于对美国军工企业及高级管理人员采取反制措施的决定","url":"https://www.mfa.gov.cn/web/wjb_673085/zfxxgk_674865/gknrlb/fzcqdcs/202412/t20241227_11520050.shtml","publish_date":"2024-12-27","publish_time":"15:00","document_type":"cn/ministry-of-foreign-affairs-order","document_id":"第16号","signatory":"cn/ministry-of-foreign-affairs","publisher":"cn/ministry-of-foreign-affairs","authority":"cn/ministry-of-foreign-affairs","content":"（2024年12月27日中华人民共和国外交部令第16号公布，自2024年12月27日起施行）\n\n美国近日再次宣布向中国台湾地区提供大额武器援助并出售武器，美国\"2025财年国防授权法案\"包括多项涉华消极条款，严重违反一个中国原则和中美三个联合公报，严重干涉中国内政，严重损害中国主权和领土完整。\n\n依据《中华人民共和国反外国制裁法》第三条、第四条、第五条、第六条、第九条、第十五条规定，中方决定对英斯图公司、哈德森技术公司、萨罗尼克科技公司、雷神加拿大公司、雷神澳大利亚公司、爱尔康公司、国际海洋工程公司等7家后附《反制清单》列明的企业及相关高级管理人员采取以下反制措施：\n\n一、冻结在我国境内的动产、不动产和其他各类财产；\n二、禁止我国境内的组织、个人与其进行有关交易、合作等活动。\n\n本决定自2024年12月27日起施行。\n","language":"zh-CN"}""" ;\n  ammitto:group_id <https://www.ammitto.org/group/cn/16> ;\n  ammitto:legal_citations """{"legal_instrument_id":"https://www.ammitto.org/legal-instrument/cn/npc-anti-foreign-sanctions-law","articles":["第三条","第四条","第五条","第六条","第九条","第十五条"],"citation_type":"legal_basis"}""" ;\n  ammitto:raw_source_data """{"source_format":"yaml","source_specific_fields":{"cn:list_type":"anti_sanctions","cn:sanction_list":"反制裁清单","cn:chinese_name":"萨罗尼克科技公司","cn:english_name":"Saronic Technologies, Inc."}}""" .
<https://www.ammitto.org/entry/cn/anti-sanction-list/16-raytheon-canada>
  ammitto:entity_id <https://www.ammitto.org/entity/cn/16-raytheon-canada> ;\n  ammitto:hasAuthority <https://www.ammitto.org/authority/cn> ;\n  ammitto:hasRegime <https://www.ammitto.org/regime/cn_anti_sanctions> ;\n  ammitto:hasEffect """{"effect_type":"asset_freeze","scope":"full","description":[{"value":"冻结在我国境内的动产、不动产和其他各类财产","lang":"zh","script":"Hani","is_primary":true},{"value":"Freeze all assets in China, including movable and immovable property and other types of assets","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasEffect """{"effect_type":"prohibit_transactions","scope":"full","description":[{"value":"禁止我国境内的组织、个人与其进行有关交易、合作等活动","lang":"zh","script":"Hani","is_primary":true},{"value":"Prohibit organizations and individuals in China from engaging in transactions, cooperation or related activities with the entity","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasReason """{"category":"other","description":[{"value":"美国近日再次宣布向中国台湾地区提供大额武器援助并出售武器，美国\"2025财年国防授权法案\"包括多项涉华消极条款，严重违反一个中国原则和中美三个联合公报，严重干涉中国内政，严重损害中国主权和领土完整。","lang":"zh","script":"Hani","is_primary":true},{"value":"The US recently announced providing large-scale weapons assistance and selling weapons to China's Taiwan region, and the US \"2025 National Defense Authorization Act\" includes multiple negative provisions related to China, seriously violating the One-China principle and the three China-US joint communiqués, seriously interfering in China's internal affairs, and seriously damaging China's sovereignty and territorial integrity.","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasPeriod """{"effective_date":"2024-12-27","is_indefinite":false}""" ;\n  ammitto:status "active" ;\n  ammitto:reference_number "16-raytheon-canada" ;\n  ammitto:announcement """{"title":"关于对美国军工企业及高级管理人员采取反制措施的决定","url":"https://www.mfa.gov.cn/web/wjb_673085/zfxxgk_674865/gknrlb/fzcqdcs/202412/t20241227_11520050.shtml","publish_date":"2024-12-27","publish_time":"15:00","document_type":"cn/ministry-of-foreign-affairs-order","document_id":"第16号","signatory":"cn/ministry-of-foreign-affairs","publisher":"cn/ministry-of-foreign-affairs","authority":"cn/ministry-of-foreign-affairs","content":"（2024年12月27日中华人民共和国外交部令第16号公布，自2024年12月27日起施行）\n\n美国近日再次宣布向中国台湾地区提供大额武器援助并出售武器，美国\"2025财年国防授权法案\"包括多项涉华消极条款，严重违反一个中国原则和中美三个联合公报，严重干涉中国内政，严重损害中国主权和领土完整。\n\n依据《中华人民共和国反外国制裁法》第三条、第四条、第五条、第六条、第九条、第十五条规定，中方决定对英斯图公司、哈德森技术公司、萨罗尼克科技公司、雷神加拿大公司、雷神澳大利亚公司、爱尔康公司、国际海洋工程公司等7家后附《反制清单》列明的企业及相关高级管理人员采取以下反制措施：\n\n一、冻结在我国境内的动产、不动产和其他各类财产；\n二、禁止我国境内的组织、个人与其进行有关交易、合作等活动。\n\n本决定自2024年12月27日起施行。\n","language":"zh-CN"}""" ;\n  ammitto:group_id <https://www.ammitto.org/group/cn/16> ;\n  ammitto:legal_citations """{"legal_instrument_id":"https://www.ammitto.org/legal-instrument/cn/npc-anti-foreign-sanctions-law","articles":["第三条","第四条","第五条","第六条","第九条","第十五条"],"citation_type":"legal_basis"}""" ;\n  ammitto:raw_source_data """{"source_format":"yaml","source_specific_fields":{"cn:list_type":"anti_sanctions","cn:sanction_list":"反制裁清单","cn:chinese_name":"雷神加拿大公司","cn:english_name":"Raytheon Canada"}}""" .
<https://www.ammitto.org/entry/cn/anti-sanction-list/16-raytheon-australia>
  ammitto:entity_id <https://www.ammitto.org/entity/cn/16-raytheon-australia> ;\n  ammitto:hasAuthority <https://www.ammitto.org/authority/cn> ;\n  ammitto:hasRegime <https://www.ammitto.org/regime/cn_anti_sanctions> ;\n  ammitto:hasEffect """{"effect_type":"asset_freeze","scope":"full","description":[{"value":"冻结在我国境内的动产、不动产和其他各类财产","lang":"zh","script":"Hani","is_primary":true},{"value":"Freeze all assets in China, including movable and immovable property and other types of assets","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasEffect """{"effect_type":"prohibit_transactions","scope":"full","description":[{"value":"禁止我国境内的组织、个人与其进行有关交易、合作等活动","lang":"zh","script":"Hani","is_primary":true},{"value":"Prohibit organizations and individuals in China from engaging in transactions, cooperation or related activities with the entity","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasReason """{"category":"other","description":[{"value":"美国近日再次宣布向中国台湾地区提供大额武器援助并出售武器，美国\"2025财年国防授权法案\"包括多项涉华消极条款，严重违反一个中国原则和中美三个联合公报，严重干涉中国内政，严重损害中国主权和领土完整。","lang":"zh","script":"Hani","is_primary":true},{"value":"The US recently announced providing large-scale weapons assistance and selling weapons to China's Taiwan region, and the US \"2025 National Defense Authorization Act\" includes multiple negative provisions related to China, seriously violating the One-China principle and the three China-US joint communiqués, seriously interfering in China's internal affairs, and seriously damaging China's sovereignty and territorial integrity.","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasPeriod """{"effective_date":"2024-12-27","is_indefinite":false}""" ;\n  ammitto:status "active" ;\n  ammitto:reference_number "16-raytheon-australia" ;\n  ammitto:announcement """{"title":"关于对美国军工企业及高级管理人员采取反制措施的决定","url":"https://www.mfa.gov.cn/web/wjb_673085/zfxxgk_674865/gknrlb/fzcqdcs/202412/t20241227_11520050.shtml","publish_date":"2024-12-27","publish_time":"15:00","document_type":"cn/ministry-of-foreign-affairs-order","document_id":"第16号","signatory":"cn/ministry-of-foreign-affairs","publisher":"cn/ministry-of-foreign-affairs","authority":"cn/ministry-of-foreign-affairs","content":"（2024年12月27日中华人民共和国外交部令第16号公布，自2024年12月27日起施行）\n\n美国近日再次宣布向中国台湾地区提供大额武器援助并出售武器，美国\"2025财年国防授权法案\"包括多项涉华消极条款，严重违反一个中国原则和中美三个联合公报，严重干涉中国内政，严重损害中国主权和领土完整。\n\n依据《中华人民共和国反外国制裁法》第三条、第四条、第五条、第六条、第九条、第十五条规定，中方决定对英斯图公司、哈德森技术公司、萨罗尼克科技公司、雷神加拿大公司、雷神澳大利亚公司、爱尔康公司、国际海洋工程公司等7家后附《反制清单》列明的企业及相关高级管理人员采取以下反制措施：\n\n一、冻结在我国境内的动产、不动产和其他各类财产；\n二、禁止我国境内的组织、个人与其进行有关交易、合作等活动。\n\n本决定自2024年12月27日起施行。\n","language":"zh-CN"}""" ;\n  ammitto:group_id <https://www.ammitto.org/group/cn/16> ;\n  ammitto:legal_citations """{"legal_instrument_id":"https://www.ammitto.org/legal-instrument/cn/npc-anti-foreign-sanctions-law","articles":["第三条","第四条","第五条","第六条","第九条","第十五条"],"citation_type":"legal_basis"}""" ;\n  ammitto:raw_source_data """{"source_format":"yaml","source_specific_fields":{"cn:list_type":"anti_sanctions","cn:sanction_list":"反制裁清单","cn:chinese_name":"雷神澳大利亚公司","cn:english_name":"Raytheon Australia"}}""" .
<https://www.ammitto.org/entry/cn/anti-sanction-list/16-aerkomm-inc>
  ammitto:entity_id <https://www.ammitto.org/entity/cn/16-aerkomm-inc> ;\n  ammitto:hasAuthority <https://www.ammitto.org/authority/cn> ;\n  ammitto:hasRegime <https://www.ammitto.org/regime/cn_anti_sanctions> ;\n  ammitto:hasEffect """{"effect_type":"asset_freeze","scope":"full","description":[{"value":"冻结在我国境内的动产、不动产和其他各类财产","lang":"zh","script":"Hani","is_primary":true},{"value":"Freeze all assets in China, including movable and immovable property and other types of assets","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasEffect """{"effect_type":"prohibit_transactions","scope":"full","description":[{"value":"禁止我国境内的组织、个人与其进行有关交易、合作等活动","lang":"zh","script":"Hani","is_primary":true},{"value":"Prohibit organizations and individuals in China from engaging in transactions, cooperation or related activities with the entity","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasReason """{"category":"other","description":[{"value":"美国近日再次宣布向中国台湾地区提供大额武器援助并出售武器，美国\"2025财年国防授权法案\"包括多项涉华消极条款，严重违反一个中国原则和中美三个联合公报，严重干涉中国内政，严重损害中国主权和领土完整。","lang":"zh","script":"Hani","is_primary":true},{"value":"The US recently announced providing large-scale weapons assistance and selling weapons to China's Taiwan region, and the US \"2025 National Defense Authorization Act\" includes multiple negative provisions related to China, seriously violating the One-China principle and the three China-US joint communiqués, seriously interfering in China's internal affairs, and seriously damaging China's sovereignty and territorial integrity.","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasPeriod """{"effective_date":"2024-12-27","is_indefinite":false}""" ;\n  ammitto:status "active" ;\n  ammitto:reference_number "16-aerkomm-inc" ;\n  ammitto:announcement """{"title":"关于对美国军工企业及高级管理人员采取反制措施的决定","url":"https://www.mfa.gov.cn/web/wjb_673085/zfxxgk_674865/gknrlb/fzcqdcs/202412/t20241227_11520050.shtml","publish_date":"2024-12-27","publish_time":"15:00","document_type":"cn/ministry-of-foreign-affairs-order","document_id":"第16号","signatory":"cn/ministry-of-foreign-affairs","publisher":"cn/ministry-of-foreign-affairs","authority":"cn/ministry-of-foreign-affairs","content":"（2024年12月27日中华人民共和国外交部令第16号公布，自2024年12月27日起施行）\n\n美国近日再次宣布向中国台湾地区提供大额武器援助并出售武器，美国\"2025财年国防授权法案\"包括多项涉华消极条款，严重违反一个中国原则和中美三个联合公报，严重干涉中国内政，严重损害中国主权和领土完整。\n\n依据《中华人民共和国反外国制裁法》第三条、第四条、第五条、第六条、第九条、第十五条规定，中方决定对英斯图公司、哈德森技术公司、萨罗尼克科技公司、雷神加拿大公司、雷神澳大利亚公司、爱尔康公司、国际海洋工程公司等7家后附《反制清单》列明的企业及相关高级管理人员采取以下反制措施：\n\n一、冻结在我国境内的动产、不动产和其他各类财产；\n二、禁止我国境内的组织、个人与其进行有关交易、合作等活动。\n\n本决定自2024年12月27日起施行。\n","language":"zh-CN"}""" ;\n  ammitto:group_id <https://www.ammitto.org/group/cn/16> ;\n  ammitto:legal_citations """{"legal_instrument_id":"https://www.ammitto.org/legal-instrument/cn/npc-anti-foreign-sanctions-law","articles":["第三条","第四条","第五条","第六条","第九条","第十五条"],"citation_type":"legal_basis"}""" ;\n  ammitto:raw_source_data """{"source_format":"yaml","source_specific_fields":{"cn:list_type":"anti_sanctions","cn:sanction_list":"反制裁清单","cn:chinese_name":"爱尔康公司","cn:english_name":"Aerkomm Inc."}}""" .
<https://www.ammitto.org/entry/cn/anti-sanction-list/16-oceaneering-international-inc>
  ammitto:entity_id <https://www.ammitto.org/entity/cn/16-oceaneering-international-inc> ;\n  ammitto:hasAuthority <https://www.ammitto.org/authority/cn> ;\n  ammitto:hasRegime <https://www.ammitto.org/regime/cn_anti_sanctions> ;\n  ammitto:hasEffect """{"effect_type":"asset_freeze","scope":"full","description":[{"value":"冻结在我国境内的动产、不动产和其他各类财产","lang":"zh","script":"Hani","is_primary":true},{"value":"Freeze all assets in China, including movable and immovable property and other types of assets","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasEffect """{"effect_type":"prohibit_transactions","scope":"full","description":[{"value":"禁止我国境内的组织、个人与其进行有关交易、合作等活动","lang":"zh","script":"Hani","is_primary":true},{"value":"Prohibit organizations and individuals in China from engaging in transactions, cooperation or related activities with the entity","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasReason """{"category":"other","description":[{"value":"美国近日再次宣布向中国台湾地区提供大额武器援助并出售武器，美国\"2025财年国防授权法案\"包括多项涉华消极条款，严重违反一个中国原则和中美三个联合公报，严重干涉中国内政，严重损害中国主权和领土完整。","lang":"zh","script":"Hani","is_primary":true},{"value":"The US recently announced providing large-scale weapons assistance and selling weapons to China's Taiwan region, and the US \"2025 National Defense Authorization Act\" includes multiple negative provisions related to China, seriously violating the One-China principle and the three China-US joint communiqués, seriously interfering in China's internal affairs, and seriously damaging China's sovereignty and territorial integrity.","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasPeriod """{"effective_date":"2024-12-27","is_indefinite":false}""" ;\n  ammitto:status "active" ;\n  ammitto:reference_number "16-oceaneering-international-inc" ;\n  ammitto:announcement """{"title":"关于对美国军工企业及高级管理人员采取反制措施的决定","url":"https://www.mfa.gov.cn/web/wjb_673085/zfxxgk_674865/gknrlb/fzcqdcs/202412/t20241227_11520050.shtml","publish_date":"2024-12-27","publish_time":"15:00","document_type":"cn/ministry-of-foreign-affairs-order","document_id":"第16号","signatory":"cn/ministry-of-foreign-affairs","publisher":"cn/ministry-of-foreign-affairs","authority":"cn/ministry-of-foreign-affairs","content":"（2024年12月27日中华人民共和国外交部令第16号公布，自2024年12月27日起施行）\n\n美国近日再次宣布向中国台湾地区提供大额武器援助并出售武器，美国\"2025财年国防授权法案\"包括多项涉华消极条款，严重违反一个中国原则和中美三个联合公报，严重干涉中国内政，严重损害中国主权和领土完整。\n\n依据《中华人民共和国反外国制裁法》第三条、第四条、第五条、第六条、第九条、第十五条规定，中方决定对英斯图公司、哈德森技术公司、萨罗尼克科技公司、雷神加拿大公司、雷神澳大利亚公司、爱尔康公司、国际海洋工程公司等7家后附《反制清单》列明的企业及相关高级管理人员采取以下反制措施：\n\n一、冻结在我国境内的动产、不动产和其他各类财产；\n二、禁止我国境内的组织、个人与其进行有关交易、合作等活动。\n\n本决定自2024年12月27日起施行。\n","language":"zh-CN"}""" ;\n  ammitto:group_id <https://www.ammitto.org/group/cn/16> ;\n  ammitto:legal_citations """{"legal_instrument_id":"https://www.ammitto.org/legal-instrument/cn/npc-anti-foreign-sanctions-law","articles":["第三条","第四条","第五条","第六条","第九条","第十五条"],"citation_type":"legal_basis"}""" ;\n  ammitto:raw_source_data """{"source_format":"yaml","source_specific_fields":{"cn:list_type":"anti_sanctions","cn:sanction_list":"反制裁清单","cn:chinese_name":"国际海洋工程公司","cn:english_name":"Oceaneering International, Inc."}}""" .
<https://www.ammitto.org/entry/cn/anti-sanction-list/17-ishihara-ping>
  ammitto:entity_id <https://www.ammitto.org/entity/cn/17-ishihara-ping> ;\n  ammitto:hasAuthority <https://www.ammitto.org/authority/cn> ;\n  ammitto:hasRegime <https://www.ammitto.org/regime/cn_anti_sanctions> ;\n  ammitto:hasEffect """{"effect_type":"asset_freeze","scope":"full","description":[{"value":"冻结其在我国境内的动产、不动产及其他各类财产","lang":"zh","script":"Hani","is_primary":true},{"value":"Freeze all assets in China, including movable and immovable property and other types of assets","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasEffect """{"effect_type":"prohibit_transactions","scope":"full","description":[{"value":"禁止我国境内的组织、个人与其进行有关交易、合作等活动","lang":"zh","script":"Hani","is_primary":true},{"value":"Prohibit organizations and individuals in China from engaging in transactions, cooperation or related activities with the entity with the individual","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasEffect """{"effect_type":"visa_ban","scope":"full","description":[{"value":"对其本人及直系亲属不予签发签证、不准入境（包括香港、澳门）","lang":"zh","script":"Hani","is_primary":true},{"value":"Visa ban and entry prohibition for the individual and immediate family (including Hong Kong and Macao)","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasReason """{"category":"other","description":[{"value":"长期在台湾、钓鱼岛、历史、涉疆、涉藏、涉港等问题上散布谬论，公然参拜靖国神社，严重违背中日四个政治文件精神和一个中国原则，严重干涉中国内政，严重损害中国主权和领土完整。","lang":"zh","script":"Hani","is_primary":true},{"value":"Long-term dissemination of fallacies on issues such as Taiwan, Diaoyu Islands, history, Xinjiang, Tibet, and Hong Kong, openly visiting the Yasukuni Shrine, seriously violating the spirit of the four political documents between China and Japan and the One-China principle, seriously interfering in China's internal affairs, and seriously damaging China's sovereignty and territorial integrity.","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasPeriod """{"effective_date":"2025-09-08","is_indefinite":false}""" ;\n  ammitto:status "active" ;\n  ammitto:reference_number "17-ishihara-ping" ;\n  ammitto:announcement """{"title":"关于对石平采取反制措施的决定","url":"https://www.mfa.gov.cn/web/wjb_673085/zfxxgk_674865/gknrlb/fzcqdcs/202509/t20250908_11704050.shtml","publish_date":"2025-09-08","publish_time":"10:00","document_type":"cn/ministry-of-foreign-affairs-order","document_id":"第17号","signatory":"cn/ministry-of-foreign-affairs","publisher":"cn/ministry-of-foreign-affairs","authority":"cn/ministry-of-foreign-affairs","content":"（2025年9月8日中华人民共和国外交部令第17号公布，自2025年9月8日起施行）\n\n日本参议员石平长期在台湾、钓鱼岛、历史、涉疆、涉藏、涉港等问题上散布谬论，公然参拜靖国神社，严重违背中日四个政治文件精神和一个中国原则，严重干涉中国内政，严重损害中国主权和领土完整。依据《中华人民共和国反外国制裁法》第三条、第四条、第五条、第六条、第九条、第十五条规定，中方决定对石平采取以下反制措施：\n\n一、冻结其在我国境内的动产、不动产及其他各类财产；\n二、禁止我国境内的组织、个人与其进行有关交易、合作等活动；\n三、对其本人及直系亲属不予签发签证、不准入境（包括香港、澳门）。\n\n本决定自2025年9月8日起施行。\n","language":"zh-CN"}""" ;\n  ammitto:legal_citations """{"legal_instrument_id":"https://www.ammitto.org/legal-instrument/cn/npc-anti-foreign-sanctions-law","articles":["第三条","第四条","第五条","第六条","第九条","第十五条"],"citation_type":"legal_basis"}""" ;\n  ammitto:raw_source_data """{"source_format":"yaml","source_specific_fields":{"cn:list_type":"anti_sanctions","cn:sanction_list":"反制裁清单","cn:chinese_name":"石平","cn:english_name":"Ishihara Ping"}}""" .
<https://www.ammitto.org/entry/cn/anti-sanction-list/18-iwasaki-shigeru>
  ammitto:entity_id <https://www.ammitto.org/entity/cn/18-iwasaki-shigeru> ;\n  ammitto:hasAuthority <https://www.ammitto.org/authority/cn> ;\n  ammitto:hasRegime <https://www.ammitto.org/regime/cn_anti_sanctions> ;\n  ammitto:hasEffect """{"effect_type":"asset_freeze","scope":"full","description":[{"value":"冻结其在我国境内的动产、不动产和其它各类财产","lang":"zh","script":"Hani","is_primary":true},{"value":"Freeze all assets in China, including movable and immovable property and other types of assets","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasEffect """{"effect_type":"prohibit_transactions","scope":"full","description":[{"value":"禁止我国境内组织、个人与其进行有关交易、合作等活动","lang":"zh","script":"Hani","is_primary":true},{"value":"Prohibit organizations and individuals in China from engaging in transactions, cooperation or related activities with the entity with the individual","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasEffect """{"effect_type":"visa_ban","scope":"full","description":[{"value":"对其不予签发签证、不准入境（包括香港、澳门）","lang":"zh","script":"Hani","is_primary":true},{"value":"Visa ban and entry prohibition (including Hong Kong and Macao)","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasReason """{"category":"other","description":[{"value":"公然同\"台独\"分裂势力勾连，严重违背一个中国原则和中日四个政治文件精神，严重干涉中国内政，严重损害中国主权和领土完整。","lang":"zh","script":"Hani","is_primary":true},{"value":"Openly colluding with \"Taiwan independence\" separatist forces, seriously violating the One-China principle and the spirit of the four China-Japan political documents, seriously interfering in China's internal affairs, and seriously damaging China's sovereignty and territorial integrity.","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasPeriod """{"effective_date":"2025-12-15","is_indefinite":false}""" ;\n  ammitto:status "active" ;\n  ammitto:reference_number "18-iwasaki-shigeru" ;\n  ammitto:announcement """{"title":"关于对岩崎茂采取反制措施的决定","url":"https://www.mfa.gov.cn/web/wjb_673085/zfxxgk_674865/gknrlb/fzcqdcs/202512/t20251215_11772517.shtml","publish_date":"2025-12-15","publish_time":"09:39","document_type":"cn/ministry-of-foreign-affairs-order","document_id":"第18号","signatory":"cn/ministry-of-foreign-affairs","publisher":"cn/ministry-of-foreign-affairs","authority":"cn/ministry-of-foreign-affairs","content":"（2025年12月15日中华人民共和国外交部令第18号公布，自2025年12月15日起施行）\n\n日本自卫队前统合幕僚长岩崎茂公然同\"台独\"分裂势力勾连，严重违背一个中国原则和中日四个政治文件精神，严重干涉中国内政，严重损害中国主权和领土完整。依据《中华人民共和国反外国制裁法》第三条、第四条、第五条、第六条、第九条、第十五条规定，中方决定对岩崎茂采取以下反制措施：\n\n一、冻结其在我国境内的动产、不动产和其它各类财产；\n二、禁止我国境内组织、个人与其进行有关交易、合作等活动；\n三、对其不予签发签证、不准入境（包括香港、澳门）。\n\n本决定自2025年12月15日起施行。\n","language":"zh-CN"}""" ;\n  ammitto:legal_citations """{"legal_instrument_id":"https://www.ammitto.org/legal-instrument/cn/npc-anti-foreign-sanctions-law","articles":["第三条","第四条","第五条","第六条","第九条","第十五条"],"citation_type":"legal_basis"}""" ;\n  ammitto:raw_source_data """{"source_format":"yaml","source_specific_fields":{"cn:list_type":"anti_sanctions","cn:sanction_list":"反制裁清单","cn:chinese_name":"岩崎茂","cn:english_name":"Iwasaki Shigeru"}}""" .
<https://www.ammitto.org/entry/cn/anti-sanction-list/19-northrop-grumman-systems-corpor>
  ammitto:entity_id <https://www.ammitto.org/entity/cn/19-northrop-grumman-systems-corpor> ;\n  ammitto:hasAuthority <https://www.ammitto.org/authority/cn> ;\n  ammitto:hasRegime <https://www.ammitto.org/regime/cn_anti_sanctions> ;\n  ammitto:hasEffect """{"effect_type":"asset_freeze","scope":"full","description":[{"value":"冻结在我国境内的动产、不动产和其他各类财产","lang":"zh","script":"Hani","is_primary":true},{"value":"Freeze all assets in China, including movable and immovable property and other types of assets","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasEffect """{"effect_type":"prohibit_transactions","scope":"full","description":[{"value":"禁止我国境内的组织、个人与其进行有关交易、合作等活动","lang":"zh","script":"Hani","is_primary":true},{"value":"Prohibit organizations and individuals in China from engaging in transactions, cooperation or related activities with the entity","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasReason """{"category":"other","description":[{"value":"美国近日宣布向中国台湾地区大规模出售武器，严重违反一个中国原则和中美三个联合公报，严重干涉中国内政，严重损害中国主权和领土完整。","lang":"zh","script":"Hani","is_primary":true},{"value":"The US recently announced large-scale arms sales to China's Taiwan region, seriously violating the One-China principle and the three China-US joint communiqués, seriously interfering in China's internal affairs, and seriously damaging China's sovereignty and territorial integrity.","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasPeriod """{"effective_date":"2025-12-26","is_indefinite":false}""" ;\n  ammitto:status "active" ;\n  ammitto:reference_number "19-northrop-grumman-systems-corpor" ;\n  ammitto:announcement """{"title":"关于对美国军工相关企业及高级管理人员采取反制措施的决定","url":"https://www.mfa.gov.cn/web/wjb_673085/zfxxgk_674865/gknrlb/fzcqdcs/202512/t20251226_11787617.shtml","publish_date":"2025-12-26","publish_time":"17:00","document_type":"cn/ministry-of-foreign-affairs-order","document_id":"第19号","signatory":"cn/ministry-of-foreign-affairs","publisher":"cn/ministry-of-foreign-affairs","authority":"cn/ministry-of-foreign-affairs","content":"（2025年12月26日中华人民共和国外交部令第19号公布，自2025年12月26日起施行）\n\n美国近日宣布向中国台湾地区大规模出售武器，严重违反一个中国原则和中美三个联合公报，严重干涉中国内政，严重损害中国主权和领土完整。依据《中华人民共和国反外国制裁法》第三条、第四条、第五条、第六条、第九条、第十五条规定，中方决定对以下美国军工相关企业及高级管理人员采取反制措施：\n\n一、对诺斯罗普·格鲁曼系统公司、L3哈里斯海事服务公司、波音密苏里州圣路易斯市分公司、吉布斯与考克斯公司、先进声学概念有限责任公司、VSE公司、塞拉技术服务公司、红猫控股公司、蒂尔无人机公司、侦察艇有限责任公司、高点航空技术公司、伊庇鲁斯公司、迪德罗恩公司、I领域公司、蓝力技术公司、潜航技术公司、万拓公司、英特磊公司、菱形力量公司、拉撒路人工智能公司等20家后附《反制清单》列明的企业，冻结在我国境内的动产、不动产和其他各类财产；禁止我国境内的组织、个人与其进行有关交易、合作等活动。\n\n二、对帕尔默·卢基（安杜里尔公司创始人）、约翰·坎蒂伦（L3哈里斯技术公司副总裁、L3哈里斯海事服务公司副总裁兼首席会计官）、迈克尔·卡诺维尔（先进声学概念有限责任公司总裁兼首席执行官）、约翰·库默（VSE公司总裁兼首席执行官）、米奇·麦克唐纳（蒂尔无人机公司总裁）、安舒曼·罗伊（菱形力量公司创始人兼首席执行官）、丹·斯穆特（万拓公司总裁兼首席执行官）、阿迪亚·德瓦拉孔达（迪德罗恩公司首席执行官）、安·伍德（高点航空技术公司总裁）、杰伊·霍夫利奇（侦察艇有限责任公司联合创始人兼首席执行官）等10名后附《反制清单》列明的企业高级管理人员，冻结在我国境内的动产、不动产和其他各类财产；禁止我国境内的组织、个人与其本人进行有关交易、合作等活动；对其本人不予签发签证、不准入境（包括香港、澳门）。\n\n本决定自2025年12月26日起施行。\n","language":"zh-CN"}""" ;\n  ammitto:group_id <https://www.ammitto.org/group/cn/19> ;\n  ammitto:legal_citations """{"legal_instrument_id":"https://www.ammitto.org/legal-instrument/cn/npc-anti-foreign-sanctions-law","articles":["第三条","第四条","第五条","第六条","第九条","第十五条"],"citation_type":"legal_basis"}""" ;\n  ammitto:raw_source_data """{"source_format":"yaml","source_specific_fields":{"cn:list_type":"anti_sanctions","cn:sanction_list":"反制裁清单","cn:chinese_name":"诺斯罗普·格鲁曼系统公司","cn:english_name":"Northrop Grumman Systems Corporation"}}""" .
<https://www.ammitto.org/entry/cn/anti-sanction-list/19-l3harris-maritime-services>
  ammitto:entity_id <https://www.ammitto.org/entity/cn/19-l3harris-maritime-services> ;\n  ammitto:hasAuthority <https://www.ammitto.org/authority/cn> ;\n  ammitto:hasRegime <https://www.ammitto.org/regime/cn_anti_sanctions> ;\n  ammitto:hasEffect """{"effect_type":"asset_freeze","scope":"full","description":[{"value":"冻结在我国境内的动产、不动产和其他各类财产","lang":"zh","script":"Hani","is_primary":true},{"value":"Freeze all assets in China, including movable and immovable property and other types of assets","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasEffect """{"effect_type":"prohibit_transactions","scope":"full","description":[{"value":"禁止我国境内的组织、个人与其进行有关交易、合作等活动","lang":"zh","script":"Hani","is_primary":true},{"value":"Prohibit organizations and individuals in China from engaging in transactions, cooperation or related activities with the entity","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasReason """{"category":"other","description":[{"value":"美国近日宣布向中国台湾地区大规模出售武器，严重违反一个中国原则和中美三个联合公报，严重干涉中国内政，严重损害中国主权和领土完整。","lang":"zh","script":"Hani","is_primary":true},{"value":"The US recently announced large-scale arms sales to China's Taiwan region, seriously violating the One-China principle and the three China-US joint communiqués, seriously interfering in China's internal affairs, and seriously damaging China's sovereignty and territorial integrity.","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasPeriod """{"effective_date":"2025-12-26","is_indefinite":false}""" ;\n  ammitto:status "active" ;\n  ammitto:reference_number "19-l3harris-maritime-services" ;\n  ammitto:announcement """{"title":"关于对美国军工相关企业及高级管理人员采取反制措施的决定","url":"https://www.mfa.gov.cn/web/wjb_673085/zfxxgk_674865/gknrlb/fzcqdcs/202512/t20251226_11787617.shtml","publish_date":"2025-12-26","publish_time":"17:00","document_type":"cn/ministry-of-foreign-affairs-order","document_id":"第19号","signatory":"cn/ministry-of-foreign-affairs","publisher":"cn/ministry-of-foreign-affairs","authority":"cn/ministry-of-foreign-affairs","content":"（2025年12月26日中华人民共和国外交部令第19号公布，自2025年12月26日起施行）\n\n美国近日宣布向中国台湾地区大规模出售武器，严重违反一个中国原则和中美三个联合公报，严重干涉中国内政，严重损害中国主权和领土完整。依据《中华人民共和国反外国制裁法》第三条、第四条、第五条、第六条、第九条、第十五条规定，中方决定对以下美国军工相关企业及高级管理人员采取反制措施：\n\n一、对诺斯罗普·格鲁曼系统公司、L3哈里斯海事服务公司、波音密苏里州圣路易斯市分公司、吉布斯与考克斯公司、先进声学概念有限责任公司、VSE公司、塞拉技术服务公司、红猫控股公司、蒂尔无人机公司、侦察艇有限责任公司、高点航空技术公司、伊庇鲁斯公司、迪德罗恩公司、I领域公司、蓝力技术公司、潜航技术公司、万拓公司、英特磊公司、菱形力量公司、拉撒路人工智能公司等20家后附《反制清单》列明的企业，冻结在我国境内的动产、不动产和其他各类财产；禁止我国境内的组织、个人与其进行有关交易、合作等活动。\n\n二、对帕尔默·卢基（安杜里尔公司创始人）、约翰·坎蒂伦（L3哈里斯技术公司副总裁、L3哈里斯海事服务公司副总裁兼首席会计官）、迈克尔·卡诺维尔（先进声学概念有限责任公司总裁兼首席执行官）、约翰·库默（VSE公司总裁兼首席执行官）、米奇·麦克唐纳（蒂尔无人机公司总裁）、安舒曼·罗伊（菱形力量公司创始人兼首席执行官）、丹·斯穆特（万拓公司总裁兼首席执行官）、阿迪亚·德瓦拉孔达（迪德罗恩公司首席执行官）、安·伍德（高点航空技术公司总裁）、杰伊·霍夫利奇（侦察艇有限责任公司联合创始人兼首席执行官）等10名后附《反制清单》列明的企业高级管理人员，冻结在我国境内的动产、不动产和其他各类财产；禁止我国境内的组织、个人与其本人进行有关交易、合作等活动；对其本人不予签发签证、不准入境（包括香港、澳门）。\n\n本决定自2025年12月26日起施行。\n","language":"zh-CN"}""" ;\n  ammitto:group_id <https://www.ammitto.org/group/cn/19> ;\n  ammitto:legal_citations """{"legal_instrument_id":"https://www.ammitto.org/legal-instrument/cn/npc-anti-foreign-sanctions-law","articles":["第三条","第四条","第五条","第六条","第九条","第十五条"],"citation_type":"legal_basis"}""" ;\n  ammitto:raw_source_data """{"source_format":"yaml","source_specific_fields":{"cn:list_type":"anti_sanctions","cn:sanction_list":"反制裁清单","cn:chinese_name":"L3哈里斯海事服务公司","cn:english_name":"L3Harris Maritime Services"}}""" .
<https://www.ammitto.org/entry/cn/anti-sanction-list/19-boeing-in-st-louis>
  ammitto:entity_id <https://www.ammitto.org/entity/cn/19-boeing-in-st-louis> ;\n  ammitto:hasAuthority <https://www.ammitto.org/authority/cn> ;\n  ammitto:hasRegime <https://www.ammitto.org/regime/cn_anti_sanctions> ;\n  ammitto:hasEffect """{"effect_type":"asset_freeze","scope":"full","description":[{"value":"冻结在我国境内的动产、不动产和其他各类财产","lang":"zh","script":"Hani","is_primary":true},{"value":"Freeze all assets in China, including movable and immovable property and other types of assets","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasEffect """{"effect_type":"prohibit_transactions","scope":"full","description":[{"value":"禁止我国境内的组织、个人与其进行有关交易、合作等活动","lang":"zh","script":"Hani","is_primary":true},{"value":"Prohibit organizations and individuals in China from engaging in transactions, cooperation or related activities with the entity","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasReason """{"category":"other","description":[{"value":"美国近日宣布向中国台湾地区大规模出售武器，严重违反一个中国原则和中美三个联合公报，严重干涉中国内政，严重损害中国主权和领土完整。","lang":"zh","script":"Hani","is_primary":true},{"value":"The US recently announced large-scale arms sales to China's Taiwan region, seriously violating the One-China principle and the three China-US joint communiqués, seriously interfering in China's internal affairs, and seriously damaging China's sovereignty and territorial integrity.","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasPeriod """{"effective_date":"2025-12-26","is_indefinite":false}""" ;\n  ammitto:status "active" ;\n  ammitto:reference_number "19-boeing-in-st-louis" ;\n  ammitto:announcement """{"title":"关于对美国军工相关企业及高级管理人员采取反制措施的决定","url":"https://www.mfa.gov.cn/web/wjb_673085/zfxxgk_674865/gknrlb/fzcqdcs/202512/t20251226_11787617.shtml","publish_date":"2025-12-26","publish_time":"17:00","document_type":"cn/ministry-of-foreign-affairs-order","document_id":"第19号","signatory":"cn/ministry-of-foreign-affairs","publisher":"cn/ministry-of-foreign-affairs","authority":"cn/ministry-of-foreign-affairs","content":"（2025年12月26日中华人民共和国外交部令第19号公布，自2025年12月26日起施行）\n\n美国近日宣布向中国台湾地区大规模出售武器，严重违反一个中国原则和中美三个联合公报，严重干涉中国内政，严重损害中国主权和领土完整。依据《中华人民共和国反外国制裁法》第三条、第四条、第五条、第六条、第九条、第十五条规定，中方决定对以下美国军工相关企业及高级管理人员采取反制措施：\n\n一、对诺斯罗普·格鲁曼系统公司、L3哈里斯海事服务公司、波音密苏里州圣路易斯市分公司、吉布斯与考克斯公司、先进声学概念有限责任公司、VSE公司、塞拉技术服务公司、红猫控股公司、蒂尔无人机公司、侦察艇有限责任公司、高点航空技术公司、伊庇鲁斯公司、迪德罗恩公司、I领域公司、蓝力技术公司、潜航技术公司、万拓公司、英特磊公司、菱形力量公司、拉撒路人工智能公司等20家后附《反制清单》列明的企业，冻结在我国境内的动产、不动产和其他各类财产；禁止我国境内的组织、个人与其进行有关交易、合作等活动。\n\n二、对帕尔默·卢基（安杜里尔公司创始人）、约翰·坎蒂伦（L3哈里斯技术公司副总裁、L3哈里斯海事服务公司副总裁兼首席会计官）、迈克尔·卡诺维尔（先进声学概念有限责任公司总裁兼首席执行官）、约翰·库默（VSE公司总裁兼首席执行官）、米奇·麦克唐纳（蒂尔无人机公司总裁）、安舒曼·罗伊（菱形力量公司创始人兼首席执行官）、丹·斯穆特（万拓公司总裁兼首席执行官）、阿迪亚·德瓦拉孔达（迪德罗恩公司首席执行官）、安·伍德（高点航空技术公司总裁）、杰伊·霍夫利奇（侦察艇有限责任公司联合创始人兼首席执行官）等10名后附《反制清单》列明的企业高级管理人员，冻结在我国境内的动产、不动产和其他各类财产；禁止我国境内的组织、个人与其本人进行有关交易、合作等活动；对其本人不予签发签证、不准入境（包括香港、澳门）。\n\n本决定自2025年12月26日起施行。\n","language":"zh-CN"}""" ;\n  ammitto:group_id <https://www.ammitto.org/group/cn/19> ;\n  ammitto:legal_citations """{"legal_instrument_id":"https://www.ammitto.org/legal-instrument/cn/npc-anti-foreign-sanctions-law","articles":["第三条","第四条","第五条","第六条","第九条","第十五条"],"citation_type":"legal_basis"}""" ;\n  ammitto:raw_source_data """{"source_format":"yaml","source_specific_fields":{"cn:list_type":"anti_sanctions","cn:sanction_list":"反制裁清单","cn:chinese_name":"波音密苏里州圣路易斯市分公司","cn:english_name":"Boeing in St. Louis"}}""" .
