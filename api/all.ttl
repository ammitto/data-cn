产；禁止我国境内的组织、个人与其本人进行有关交易、合作等活动；对其本人不予签发签证、不准入境（包括香港、澳门）。\n\n本决定自2024年7月12日起施行。\n\n附件：反制清单\n\n外交部\n2024年7月12日\n","language":"zh-CN"}""" ;\n  ammitto:group_id <https://www.ammitto.org/group/cn/10> ;\n  ammitto:legal_citations """{"legal_instrument_id":"https://www.ammitto.org/legal-instrument/cn/npc-anti-foreign-sanctions-law","articles":["第三条","第四条","第五条","第六条","第九条","第十五条"],"citation_type":"legal_basis"}""" ;\n  ammitto:raw_source_data """{"source_format":"yaml","source_specific_fields":{"cn:list_type":"anti_sanctions","cn:sanction_list":"反制裁清单","cn:chinese_name":"AEVEX航天公司","cn:english_name":"AEVEX Aerospace"}}""" .
