o:legal_citations """{"legal_instrument_id":"https://www.ammitto.org/legal-instrument/cn/npc-anti-foreign-sanctions-law","citation_type":"legal_basis"}""" ;\n  ammitto:legal_citations """{"legal_instrument_id":"https://www.ammitto.org/legal-instrument/cn/mofcom-unreliable-entity-list-provisions","articles":["第二条","第八条","第十条"],"citation_type":"legal_basis"}""" ;\n  ammitto:raw_source_data """{"source_format":"yaml","source_specific_fields":{"cn:list_type":"unreliable_entity","cn:sanction_list":"不可靠实体清单","cn:chinese_name":"宇航环境公司","cn:english_name":"AeroVironment, Inc."}}""" .
