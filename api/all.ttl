  ammitto:entity_id <https://www.ammitto.org/entity/cn/20251-lockheed-martin-aeronautics> ;\n  ammitto:hasAuthority <https://www.ammitto.org/authority/cn> ;\n  ammitto:hasRegime <https://www.ammitto.org/regime/cn_unreliable_entity> ;\n  ammitto:hasEffect """{"effect_type":"prohibit_import_export","scope":"full","description":[{"value":"禁止上述企业从事与中国有关的进出口活动","lang":"zh","script":"Hani","is_primary":true},{"value":"Prohibit import and export activities related to China","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasEffect """{"effect_type":"prohibit_investment_new","scope":"full","description":[{"value":"禁止上述企业在中国境内新增投资","lang":"zh","script":"Hani","is_primary":true},{"value":"Prohibit new investment activities in China","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasEffect """{"effect_type":"entry_ban","scope":"full","description":[{"value":"禁止上述企业高级管理人员入境","lang":"zh","script":"Hani","is_primary":true},{"value":"Entry ban for senior executives","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasEffect """{"effect_type":"visa_ban","scope":"full","description":[{"value":"不批准并取消上述企业高级管理人员在中国境内工作许可、停留以及居留资格","lang":"zh","script":"Hani","is_primary":true},{"value":"Visa ban and cancellation of work permit, stay and residence qualifications in China for senior executives","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasReason """{"category":"other","description":[{"value":"参与对台湾地区军售","lang":"zh","script":"Hani","is_primary":true},{"value":"Participating in arms sales to Taiwan region","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasPeriod """{"effective_date":"2025-01-02","is_indefinite":false}""" ;\n  ammitto:status "active" ;\n  ammitto:reference_number "20251-lockheed-martin-aeronautics" ;\n  ammitto:announcement """{"title":"不可靠实体清单工作机制关于对洛克希德·马丁导弹与火控公司等10家美国企业采取不可靠实体清单措施的公告","url":"https://www.mofcom.gov.cn/zwgk/zcfb/art/2025/art_c164b1339d694766938f75c1f83bddf8.html","publish_date":"2025-01-02","publish_time":"16:00","document_type":"cn/unreliable-entity-list-working-mechanism-announcement","document_id":"〔2025〕1号","signatory":"cn/unreliable-entity-list-working-mechanism","publisher":"cn/ministry-of-commerce-industry-security-and-import-export-control","authority":"cn/unreliable-entity-list-working-mechanism","content":"为维护国家主权、安全和发展利益，根据《中华人民共和国对外贸易法》《中华人民共和国国家安全法》《中华人民共和国反外国制裁法》等有关法律，不可靠实体清单工作机制依据《不可靠实体清单规定》第二条、第八条和第十条等有关规定，决定将参与对台湾地区军售的洛克希德·马丁导弹与火控公司（Lockheed Martin Missiles and Fire Control）、洛克希德·马丁航空公司（Lockheed Martin Aeronautics）、洛克希德·马丁导弹系统集成实验室（Lockheed Martin Missile System Integration Lab)、洛克希德·马丁先进技术实验室（Lockheed Martin Advanced Technology Laboratories)、洛克希德·马丁风险投资公司（Lockheed Martin Ventures)、标枪合资公司（Raytheon/Lockheed Martin Javelin Joint Venture）、雷神导弹系统公司（Raytheon Missile Systems）、通用动力军械与战术系统公司（General Dynamics Ordnance and Tactical Systems）、通用动力信息技术公司（General Dynamics Information Technology）、通用动力任务系统公司（General Dynamics Mission Systems）列入不可靠实体清单，并采取以下处理措施：\n\n一、禁止上述企业从事与中国有关的进出口活动；\n二、禁止上述企业在中国境内新增投资；\n三、禁止上述企业高级管理人员入境；\n四、不批准并取消上述企业高级管理人员在中国境内工作许可、停留或者居留资格。\n\n本公告未尽事宜，按《不可靠实体清单规定》执行。\n本公告自公布之日起实施。\n","language":"zh-CN"}""" ;\n  ammitto:group_id <https://www.ammitto.org/group/cn/20251> ;\n  ammitto:legal_citations """{"legal_instrument_id":"https://www.ammitto.org/legal-instrument/cn/npc-foreign-trade-law-2025","citation_type":"legal_basis"}""" ;\n  ammitto:legal_citations """{"legal_instrument_id":"https://www.ammitto.org/legal-instrument/cn/npc-national-security-law-2015","citation_type":"legal_basis"}""" ;\n  ammitto:legal_citations """{"legal_instrument_id":"https://www.ammitto.org/legal-instrument/cn/npc-anti-foreign-sanctions-law","citation_type":"legal_basis"}""" ;\n  ammitto:legal_citations """{"legal_instrument_id":"https://www.ammitto.org/legal-instrument/cn/mofcom-unreliable-entity-list-provisions","articles":["第二条","第八条","第十条"],"citation_type":"legal_basis"}""" ;\n  ammitto:raw_source_data """{"source_format":"yaml","source_specific_fields":{"cn:list_type":"unreliable_entity","cn:sanction_list":"不可靠实体清单","cn:chinese_name":"洛克希德·马丁航空公司","cn:english_name":"Lockheed Martin Aeronautics"}}""" .
<https://www.ammitto.org/entry/cn/unreliable-entity-list/20251-lockheed-martin-missile-system>
  ammitto:entity_id <https://www.ammitto.org/entity/cn/20251-lockheed-martin-missile-system> ;\n  ammitto:hasAuthority <https://www.ammitto.org/authority/cn> ;\n  ammitto:hasRegime <https://www.ammitto.org/regime/cn_unreliable_entity> ;\n  ammitto:hasEffect """{"effect_type":"prohibit_import_export","scope":"full","description":[{"value":"禁止上述企业从事与中国有关的进出口活动","lang":"zh","script":"Hani","is_primary":true},{"value":"Prohibit import and export activities related to China","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasEffect """{"effect_type":"prohibit_investment_new","scope":"full","description":[{"value":"禁止上述企业在中国境内新增投资","lang":"zh","script":"Hani","is_primary":true},{"value":"Prohibit new investment activities in China","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasEffect """{"effect_type":"entry_ban","scope":"full","description":[{"value":"禁止上述企业高级管理人员入境","lang":"zh","script":"Hani","is_primary":true},{"value":"Entry ban for senior executives","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasEffect """{"effect_type":"visa_ban","scope":"full","description":[{"value":"不批准并取消上述企业高级管理人员在中国境内工作许可、停留以及居留资格","lang":"zh","script":"Hani","is_primary":true},{"value":"Visa ban and cancellation of work permit, stay and residence qualifications in China for senior executives","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasReason """{"category":"other","description":[{"value":"参与对台湾地区军售","lang":"zh","script":"Hani","is_primary":true},{"value":"Participating in arms sales to Taiwan region","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasPeriod """{"effective_date":"2025-01-02","is_indefinite":false}""" ;\n  ammitto:status "active" ;\n  ammitto:reference_number "20251-lockheed-martin-missile-system" ;\n  ammitto:announcement """{"title":"不可靠实体清单工作机制关于对洛克希德·马丁导弹与火控公司等10家美国企业采取不可靠实体清单措施的公告","url":"https://www.mofcom.gov.cn/zwgk/zcfb/art/2025/art_c164b1339d694766938f75c1f83bddf8.html","publish_date":"2025-01-02","publish_time":"16:00","document_type":"cn/unreliable-entity-list-working-mechanism-announcement","document_id":"〔2025〕1号","signatory":"cn/unreliable-entity-list-working-mechanism","publisher":"cn/ministry-of-commerce-industry-security-and-import-export-control","authority":"cn/unreliable-entity-list-working-mechanism","content":"为维护国家主权、安全和发展利益，根据《中华人民共和国对外贸易法》《中华人民共和国国家安全法》《中华人民共和国反外国制裁法》等有关法律，不可靠实体清单工作机制依据《不可靠实体清单规定》第二条、第八条和第十条等有关规定，决定将参与对台湾地区军售的洛克希德·马丁导弹与火控公司（Lockheed Martin Missiles and Fire Control）、洛克希德·马丁航空公司（Lockheed Martin Aeronautics）、洛克希德·马丁导弹系统集成实验室（Lockheed Martin Missile System Integration Lab)、洛克希德·马丁先进技术实验室（Lockheed Martin Advanced Technology Laboratories)、洛克希德·马丁风险投资公司（Lockheed Martin Ventures)、标枪合资公司（Raytheon/Lockheed Martin Javelin Joint Venture）、雷神导弹系统公司（Raytheon Missile Systems）、通用动力军械与战术系统公司（General Dynamics Ordnance and Tactical Systems）、通用动力信息技术公司（General Dynamics Information Technology）、通用动力任务系统公司（General Dynamics Mission Systems）列入不可靠实体清单，并采取以下处理措施：\n\n一、禁止上述企业从事与中国有关的进出口活动；\n二、禁止上述企业在中国境内新增投资；\n三、禁止上述企业高级管理人员入境；\n四、不批准并取消上述企业高级管理人员在中国境内工作许可、停留或者居留资格。\n\n本公告未尽事宜，按《不可靠实体清单规定》执行。\n本公告自公布之日起实施。\n","language":"zh-CN"}""" ;\n  ammitto:group_id <https://www.ammitto.org/group/cn/20251> ;\n  ammitto:legal_citations """{"legal_instrument_id":"https://www.ammitto.org/legal-instrument/cn/npc-foreign-trade-law-2025","citation_type":"legal_basis"}""" ;\n  ammitto:legal_citations """{"legal_instrument_id":"https://www.ammitto.org/legal-instrument/cn/npc-national-security-law-2015","citation_type":"legal_basis"}""" ;\n  ammitto:legal_citations """{"legal_instrument_id":"https://www.ammitto.org/legal-instrument/cn/npc-anti-foreign-sanctions-law","citation_type":"legal_basis"}""" ;\n  ammitto:legal_citations """{"legal_instrument_id":"https://www.ammitto.org/legal-instrument/cn/mofcom-unreliable-entity-list-provisions","articles":["第二条","第八条","第十条"],"citation_type":"legal_basis"}""" ;\n  ammitto:raw_source_data """{"source_format":"yaml","source_specific_fields":{"cn:list_type":"unreliable_entity","cn:sanction_list":"不可靠实体清单","cn:chinese_name":"洛克希德·马丁导弹系统集成实验室","cn:english_name":"Lockheed Martin Missile System Integration Lab"}}""" .
