  ammitto:entity_id <https://www.ammitto.org/entity/cn/19-aaditya-devarakonda> ;\n  ammitto:hasAuthority <https://www.ammitto.org/authority/cn> ;\n  ammitto:hasRegime <https://www.ammitto.org/regime/cn_anti_sanctions> ;\n  ammitto:hasEffect """{"effect_type":"asset_freeze","scope":"full","description":[{"value":"冻结在我国境内的动产、不动产和其他各类财产","lang":"zh","script":"Hani","is_primary":true},{"value":"Freeze all assets in China, including movable and immovable property and other types of assets","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasEffect """{"effect_type":"prohibit_transactions","scope":"full","description":[{"value":"禁止我国境内的组织、个人与其本人进行有关交易、合作等活动","lang":"zh","script":"Hani","is_primary":true},{"value":"Prohibit organizations and individuals in China from engaging in transactions, cooperation or related activities with the entity","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasEffect """{"effect_type":"visa_ban","scope":"full","description":[{"value":"对其本人不予签发签证、不准入境（包括香港、澳门）","lang":"zh","script":"Hani","is_primary":true},{"value":"Visa ban and entry prohibition (including Hong Kong and Macao)","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasReason """{"category":"other","description":[{"value":"美国近日宣布向中国台湾地区大规模出售武器，严重违反一个中国原则和中美三个联合公报，严重干涉中国内政，严重损害中国主权和领土完整。","lang":"zh","script":"Hani","is_primary":true},{"value":"The US recently announced large-scale arms sales to China's Taiwan region, seriously violating the One-China principle and the three China-US joint communiqués, seriously interfering in China's internal affairs, and seriously damaging China's sovereignty and territorial integrity.","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasPeriod """{"effective_date":"2025-12-26","is_indefinite":false}""" ;\n  ammitto:status "active" ;\n  ammitto:reference_number "19-aaditya-devarakonda" ;\n  ammitto:announcement """{"title":"关于对美国军工相关企业及高级管理人员采取反制措施的决定","url":"https://www.mfa.gov.cn/web/wjb_673085/zfxxgk_674865/gknrlb/fzcqdcs/202512/t20251226_11787617.shtml","publish_date":"2025-12-26","publish_time":"17:00","document_type":"cn/ministry-of-foreign-affairs-order","document_id":"第19号","signatory":"cn/ministry-of-foreign-affairs","publisher":"cn/ministry-of-foreign-affairs","authority":"cn/ministry-of-foreign-affairs","content":"（2025年12月26日中华人民共和国外交部令第19号公布，自2025年12月26日起施行）\n\n美国近日宣布向中国台湾地区大规模出售武器，严重违反一个中国原则和中美三个联合公报，严重干涉中国内政，严重损害中国主权和领土完整。依据《中华人民共和国反外国制裁法》第三条、第四条、第五条、第六条、第九条、第十五条规定，中方决定对以下美国军工相关企业及高级管理人员采取反制措施：\n\n一、对诺斯罗普·格鲁曼系统公司、L3哈里斯海事服务公司、波音密苏里州圣路易斯市分公司、吉布斯与考克斯公司、先进声学概念有限责任公司、VSE公司、塞拉技术服务公司、红猫控股公司、蒂尔无人机公司、侦察艇有限责任公司、高点航空技术公司、伊庇鲁斯公司、迪德罗恩公司、I领域公司、蓝力技术公司、潜航技术公司、万拓公司、英特磊公司、菱形力量公司、拉撒路人工智能公司等20家后附《反制清单》列明的企业，冻结在我国境内的动产、不动产和其他各类财产；禁止我国境内的组织、个人与其进行有关交易、合作等活动。\n\n二、对帕尔默·卢基（安杜里尔公司创始人）、约翰·坎蒂伦（L3哈里斯技术公司副总裁、L3哈里斯海事服务公司副总裁兼首席会计官）、迈克尔·卡诺维尔（先进声学概念有限责任公司总裁兼首席执行官）、约翰·库默（VSE公司总裁兼首席执行官）、米奇·麦克唐纳（蒂尔无人机公司总裁）、安舒曼·罗伊（菱形力量公司创始人兼首席执行官）、丹·斯穆特（万拓公司总裁兼首席执行官）、阿迪亚·德瓦拉孔达（迪德罗恩公司首席执行官）、安·伍德（高点航空技术公司总裁）、杰伊·霍夫利奇（侦察艇有限责任公司联合创始人兼首席执行官）等10名后附《反制清单》列明的企业高级管理人员，冻结在我国境内的动产、不动产和其他各类财产；禁止我国境内的组织、个人与其本人进行有关交易、合作等活动；对其本人不予签发签证、不准入境（包括香港、澳门）。\n\n本决定自2025年12月26日起施行。\n","language":"zh-CN"}""" ;\n  ammitto:group_id <https://www.ammitto.org/group/cn/19> ;\n  ammitto:legal_citations """{"legal_instrument_id":"https://www.ammitto.org/legal-instrument/cn/npc-anti-foreign-sanctions-law","articles":["第三条","第四条","第五条","第六条","第九条","第十五条"],"citation_type":"legal_basis"}""" ;\n  ammitto:raw_source_data """{"source_format":"yaml","source_specific_fields":{"cn:list_type":"anti_sanctions","cn:sanction_list":"反制裁清单","cn:chinese_name":"阿迪亚·德瓦拉孔达","cn:english_name":"Aaditya Devarakonda"}}""" .
<https://www.ammitto.org/entry/cn/anti-sanction-list/19-ann-wood>
  ammitto:entity_id <https://www.ammitto.org/entity/cn/19-ann-wood> ;\n  ammitto:hasAuthority <https://www.ammitto.org/authority/cn> ;\n  ammitto:hasRegime <https://www.ammitto.org/regime/cn_anti_sanctions> ;\n  ammitto:hasEffect """{"effect_type":"asset_freeze","scope":"full","description":[{"value":"冻结在我国境内的动产、不动产和其他各类财产","lang":"zh","script":"Hani","is_primary":true},{"value":"Freeze all assets in China, including movable and immovable property and other types of assets","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasEffect """{"effect_type":"prohibit_transactions","scope":"full","description":[{"value":"禁止我国境内的组织、个人与其本人进行有关交易、合作等活动","lang":"zh","script":"Hani","is_primary":true},{"value":"Prohibit organizations and individuals in China from engaging in transactions, cooperation or related activities with the entity","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasEffect """{"effect_type":"visa_ban","scope":"full","description":[{"value":"对其本人不予签发签证、不准入境（包括香港、澳门）","lang":"zh","script":"Hani","is_primary":true},{"value":"Visa ban and entry prohibition (including Hong Kong and Macao)","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasReason """{"category":"other","description":[{"value":"美国近日宣布向中国台湾地区大规模出售武器，严重违反一个中国原则和中美三个联合公报，严重干涉中国内政，严重损害中国主权和领土完整。","lang":"zh","script":"Hani","is_primary":true},{"value":"The US recently announced large-scale arms sales to China's Taiwan region, seriously violating the One-China principle and the three China-US joint communiqués, seriously interfering in China's internal affairs, and seriously damaging China's sovereignty and territorial integrity.","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasPeriod """{"effective_date":"2025-12-26","is_indefinite":false}""" ;\n  ammitto:status "active" ;\n  ammitto:reference_number "19-ann-wood" ;\n  ammitto:announcement """{"title":"关于对美国军工相关企业及高级管理人员采取反制措施的决定","url":"https://www.mfa.gov.cn/web/wjb_673085/zfxxgk_674865/gknrlb/fzcqdcs/202512/t20251226_11787617.shtml","publish_date":"2025-12-26","publish_time":"17:00","document_type":"cn/ministry-of-foreign-affairs-order","document_id":"第19号","signatory":"cn/ministry-of-foreign-affairs","publisher":"cn/ministry-of-foreign-affairs","authority":"cn/ministry-of-foreign-affairs","content":"（2025年12月26日中华人民共和国外交部令第19号公布，自2025年12月26日起施行）\n\n美国近日宣布向中国台湾地区大规模出售武器，严重违反一个中国原则和中美三个联合公报，严重干涉中国内政，严重损害中国主权和领土完整。依据《中华人民共和国反外国制裁法》第三条、第四条、第五条、第六条、第九条、第十五条规定，中方决定对以下美国军工相关企业及高级管理人员采取反制措施：\n\n一、对诺斯罗普·格鲁曼系统公司、L3哈里斯海事服务公司、波音密苏里州圣路易斯市分公司、吉布斯与考克斯公司、先进声学概念有限责任公司、VSE公司、塞拉技术服务公司、红猫控股公司、蒂尔无人机公司、侦察艇有限责任公司、高点航空技术公司、伊庇鲁斯公司、迪德罗恩公司、I领域公司、蓝力技术公司、潜航技术公司、万拓公司、英特磊公司、菱形力量公司、拉撒路人工智能公司等20家后附《反制清单》列明的企业，冻结在我国境内的动产、不动产和其他各类财产；禁止我国境内的组织、个人与其进行有关交易、合作等活动。\n\n二、对帕尔默·卢基（安杜里尔公司创始人）、约翰·坎蒂伦（L3哈里斯技术公司副总裁、L3哈里斯海事服务公司副总裁兼首席会计官）、迈克尔·卡诺维尔（先进声学概念有限责任公司总裁兼首席执行官）、约翰·库默（VSE公司总裁兼首席执行官）、米奇·麦克唐纳（蒂尔无人机公司总裁）、安舒曼·罗伊（菱形力量公司创始人兼首席执行官）、丹·斯穆特（万拓公司总裁兼首席执行官）、阿迪亚·德瓦拉孔达（迪德罗恩公司首席执行官）、安·伍德（高点航空技术公司总裁）、杰伊·霍夫利奇（侦察艇有限责任公司联合创始人兼首席执行官）等10名后附《反制清单》列明的企业高级管理人员，冻结在我国境内的动产、不动产和其他各类财产；禁止我国境内的组织、个人与其本人进行有关交易、合作等活动；对其本人不予签发签证、不准入境（包括香港、澳门）。\n\n本决定自2025年12月26日起施行。\n","language":"zh-CN"}""" ;\n  ammitto:group_id <https://www.ammitto.org/group/cn/19> ;\n  ammitto:legal_citations """{"legal_instrument_id":"https://www.ammitto.org/legal-instrument/cn/npc-anti-foreign-sanctions-law","articles":["第三条","第四条","第五条","第六条","第九条","第十五条"],"citation_type":"legal_basis"}""" ;\n  ammitto:raw_source_data """{"source_format":"yaml","source_specific_fields":{"cn:list_type":"anti_sanctions","cn:sanction_list":"反制裁清单","cn:chinese_name":"安·伍德","cn:english_name":"Ann Wood"}}""" .
<https://www.ammitto.org/entry/cn/anti-sanction-list/19-jay-hoflich>
  ammitto:entity_id <https://www.ammitto.org/entity/cn/19-jay-hoflich> ;\n  ammitto:hasAuthority <https://www.ammitto.org/authority/cn> ;\n  ammitto:hasRegime <https://www.ammitto.org/regime/cn_anti_sanctions> ;\n  ammitto:hasEffect """{"effect_type":"asset_freeze","scope":"full","description":[{"value":"冻结在我国境内的动产、不动产和其他各类财产","lang":"zh","script":"Hani","is_primary":true},{"value":"Freeze all assets in China, including movable and immovable property and other types of assets","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasEffect """{"effect_type":"prohibit_transactions","scope":"full","description":[{"value":"禁止我国境内的组织、个人与其本人进行有关交易、合作等活动","lang":"zh","script":"Hani","is_primary":true},{"value":"Prohibit organizations and individuals in China from engaging in transactions, cooperation or related activities with the entity","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasEffect """{"effect_type":"visa_ban","scope":"full","description":[{"value":"对其本人不予签发签证、不准入境（包括香港、澳门）","lang":"zh","script":"Hani","is_primary":true},{"value":"Visa ban and entry prohibition (including Hong Kong and Macao)","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasReason """{"category":"other","description":[{"value":"美国近日宣布向中国台湾地区大规模出售武器，严重违反一个中国原则和中美三个联合公报，严重干涉中国内政，严重损害中国主权和领土完整。","lang":"zh","script":"Hani","is_primary":true},{"value":"The US recently announced large-scale arms sales to China's Taiwan region, seriously violating the One-China principle and the three China-US joint communiqués, seriously interfering in China's internal affairs, and seriously damaging China's sovereignty and territorial integrity.","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasPeriod """{"effective_date":"2025-12-26","is_indefinite":false}""" ;\n  ammitto:status "active" ;\n  ammitto:reference_number "19-jay-hoflich" ;\n  ammitto:announcement """{"title":"关于对美国军工相关企业及高级管理人员采取反制措施的决定","url":"https://www.mfa.gov.cn/web/wjb_673085/zfxxgk_674865/gknrlb/fzcqdcs/202512/t20251226_11787617.shtml","publish_date":"2025-12-26","publish_time":"17:00","document_type":"cn/ministry-of-foreign-affairs-order","document_id":"第19号","signatory":"cn/ministry-of-foreign-affairs","publisher":"cn/ministry-of-foreign-affairs","authority":"cn/ministry-of-foreign-affairs","content":"（2025年12月26日中华人民共和国外交部令第19号公布，自2025年12月26日起施行）\n\n美国近日宣布向中国台湾地区大规模出售武器，严重违反一个中国原则和中美三个联合公报，严重干涉中国内政，严重损害中国主权和领土完整。依据《中华人民共和国反外国制裁法》第三条、第四条、第五条、第六条、第九条、第十五条规定，中方决定对以下美国军工相关企业及高级管理人员采取反制措施：\n\n一、对诺斯罗普·格鲁曼系统公司、L3哈里斯海事服务公司、波音密苏里州圣路易斯市分公司、吉布斯与考克斯公司、先进声学概念有限责任公司、VSE公司、塞拉技术服务公司、红猫控股公司、蒂尔无人机公司、侦察艇有限责任公司、高点航空技术公司、伊庇鲁斯公司、迪德罗恩公司、I领域公司、蓝力技术公司、潜航技术公司、万拓公司、英特磊公司、菱形力量公司、拉撒路人工智能公司等20家后附《反制清单》列明的企业，冻结在我国境内的动产、不动产和其他各类财产；禁止我国境内的组织、个人与其进行有关交易、合作等活动。\n\n二、对帕尔默·卢基（安杜里尔公司创始人）、约翰·坎蒂伦（L3哈里斯技术公司副总裁、L3哈里斯海事服务公司副总裁兼首席会计官）、迈克尔·卡诺维尔（先进声学概念有限责任公司总裁兼首席执行官）、约翰·库默（VSE公司总裁兼首席执行官）、米奇·麦克唐纳（蒂尔无人机公司总裁）、安舒曼·罗伊（菱形力量公司创始人兼首席执行官）、丹·斯穆特（万拓公司总裁兼首席执行官）、阿迪亚·德瓦拉孔达（迪德罗恩公司首席执行官）、安·伍德（高点航空技术公司总裁）、杰伊·霍夫利奇（侦察艇有限责任公司联合创始人兼首席执行官）等10名后附《反制清单》列明的企业高级管理人员，冻结在我国境内的动产、不动产和其他各类财产；禁止我国境内的组织、个人与其本人进行有关交易、合作等活动；对其本人不予签发签证、不准入境（包括香港、澳门）。\n\n本决定自2025年12月26日起施行。\n","language":"zh-CN"}""" ;\n  ammitto:group_id <https://www.ammitto.org/group/cn/19> ;\n  ammitto:legal_citations """{"legal_instrument_id":"https://www.ammitto.org/legal-instrument/cn/npc-anti-foreign-sanctions-law","articles":["第三条","第四条","第五条","第六条","第九条","第十五条"],"citation_type":"legal_basis"}""" ;\n  ammitto:raw_source_data """{"source_format":"yaml","source_specific_fields":{"cn:list_type":"anti_sanctions","cn:sanction_list":"反制裁清单","cn:chinese_name":"杰伊·霍夫利奇","cn:english_name":"Jay Hoflich"}}""" .
<https://www.ammitto.org/entry/cn/anti-sanction-list/1-general-dynamics>
  ammitto:entity_id <https://www.ammitto.org/entity/cn/1-general-dynamics> ;\n  ammitto:hasAuthority <https://www.ammitto.org/authority/cn> ;\n  ammitto:hasRegime <https://www.ammitto.org/regime/cn_anti_sanctions> ;\n  ammitto:hasEffect """{"effect_type":"prohibit_export_dual_use_items","scope":"full","description":[{"value":"禁止向上述28家美国实体出口两用物项；正在开展的相关出口活动应当立即停止","lang":"zh","script":"Hani","is_primary":true},{"value":"Prohibit the export of dual-use items to the above 28 US entities; ongoing related export activities should be immediately ceased","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasEffect """{"effect_type":"export_license_requirement","scope":"full","description":[{"value":"特殊情况下确需出口的，出口经营者应当向商务部提出申请","lang":"zh","script":"Hani","is_primary":true},{"value":"In special circumstances where export is necessary, exporters should apply to the Ministry of Commerce for approval","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasReason """{"category":"other","description":[{"value":"为维护国家安全和利益，履行防扩散等国际义务","lang":"zh","script":"Hani","is_primary":true},{"value":"To safeguard national security and interests, and to fulfill\ninternational non-proliferation obligations","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasPeriod """{"effective_date":"2025-01-02","is_indefinite":false}""" ;\n  ammitto:status "active" ;\n  ammitto:reference_number "1-general-dynamics" ;\n  ammitto:announcement """{"title":"公布将28家美国实体列入出口管制管控名单","url":"https://www.mofcom.gov.cn/zwgk/zcfb/art/2025/art_1ee79b1b7f21444ebf4797c0ff8500fd.html","publish_date":"2025-01-02","publish_time":"16:00","document_type":"cn/ministry-of-commerce-announcement","document_id":"第1号","signatory":"cn/ministry-of-commerce","publisher":"cn/ministry-of-commerce","authority":"cn/ministry-of-commerce","content":"根据《中华人民共和国出口管制法》和《中华人民共和国两用物项出口管制条例》等法\n律法规有关规定，为维护国家安全和利益，履行防扩散等国际义务，决定将通用动力公\n司等28家美国实体列入出口管制管控名单（见附件），并采取以下措施：\n\n一、禁止向上述28家美国实体出口两用物项；正在开展的相关出口活动应当立即停止。\n二、特殊情况下确需出口的，出口经营者应当向商务部提出申请。\n\n本公告自公布之日起正式实施。\n\n附件：出口管制管控名单（2025年1月2日）\n\n商务部\n2025年1月2日\n\n附件\n出口管制管控名单\n（2025年1月2日）\n\n1. 通用动力公司（General Dynamics）\n2. L3哈里斯公司（L3 Harris Technologies）\n3. 英特磊公司（Intelligent Epitaxy Technology）\n4. 可利尔阿莱恩公司（Clear Align LLC）\n5. 波音防务、空间与安全集团（Boeing Defense, Space & Security）\n6. 洛克希德·马丁公司（Lockheed Martin Corporation）\n7. 雷神导弹与防务公司（Raytheon Missiles & Defense）\n8. 洛克希德·马丁导弹与火控公司（Lockheed Martin Missiles and Fire Control）\n9. 洛克希德·马丁航空公司（Lockheed Martin Aeronautics）\n10. 标枪合资公司（Raytheon/Lockheed Martin Javelin Joint Venture）\n11. 雷神导弹系统公司（Raytheon Missile Systems）\n12. 通用动力军械与战术系统公司（General Dynamics Ordnance and Tactical Systems）\n13. 通用动力信息技术公司（General Dynamics Information Technology）\n14. 通用动力任务系统公司（General Dynamics Mission Systems）\n15. 海岸间电子公司（Inter-Coastal Electronics）\n16. 系统研究与模拟公司（System Studies & Simulation）\n17. 铁山解决方案公司（IronMountain Solutions）\n18. 应用技术集团（Applied Technologies Group）\n19. 阿克西恩特公司（Axient）\n20. 洛克希德·马丁导弹系统集成实验室（Lockheed Martin Missile System Integration Lab）\n21. 洛克希德·马丁先进技术实验室（Lockheed Martin Advanced Technology Laboratories）\n22. 洛克希德·马丁风险投资公司（Lockheed Martin Ventures）\n23. 安杜里尔公司（Anduril Industries）\n24. 海上战术系统公司（Maritime Tactical Systems）\n25. 环太平洋防务公司（Pacific Rim Defense）\n26. AEVEX航天公司（AEVEX Aerospace）\n27. LKD航天公司（LKD Aerospace）\n28. 顶峰科技公司（Summit Technologies Inc.）\n","language":"zh-CN"}""" ;\n  ammitto:group_id <https://www.ammitto.org/group/cn/1> ;\n  ammitto:legal_citations """{"legal_instrument_id":"https://www.ammitto.org/legal-instrument/cn/npc-export-control-law","citation_type":"legal_basis"}""" ;\n  ammitto:legal_citations """{"legal_instrument_id":"https://www.ammitto.org/legal-instrument/cn/mofcom-dual-use-export-control-regulation","citation_type":"legal_basis"}""" ;\n  ammitto:raw_source_data """{"source_format":"yaml","source_specific_fields":{"cn:list_type":"anti_sanctions","cn:sanction_list":"反制裁清单","cn:chinese_name":"通用动力公司","cn:english_name":"General Dynamics"}}""" .
<https://www.ammitto.org/entry/cn/anti-sanction-list/1-l3-harris-technologies>
  ammitto:entity_id <https://www.ammitto.org/entity/cn/1-l3-harris-technologies> ;\n  ammitto:hasAuthority <https://www.ammitto.org/authority/cn> ;\n  ammitto:hasRegime <https://www.ammitto.org/regime/cn_anti_sanctions> ;\n  ammitto:hasEffect """{"effect_type":"prohibit_export_dual_use_items","scope":"full","description":[{"value":"禁止向上述28家美国实体出口两用物项；正在开展的相关出口活动应当立即停止","lang":"zh","script":"Hani","is_primary":true},{"value":"Prohibit the export of dual-use items to the above 28 US entities; ongoing related export activities should be immediately ceased","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasEffect """{"effect_type":"export_license_requirement","scope":"full","description":[{"value":"特殊情况下确需出口的，出口经营者应当向商务部提出申请","lang":"zh","script":"Hani","is_primary":true},{"value":"In special circumstances where export is necessary, exporters should apply to the Ministry of Commerce for approval","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasReason """{"category":"other","description":[{"value":"为维护国家安全和利益，履行防扩散等国际义务","lang":"zh","script":"Hani","is_primary":true},{"value":"To safeguard national security and interests, and to fulfill\ninternational non-proliferation obligations","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasPeriod """{"effective_date":"2025-01-02","is_indefinite":false}""" ;\n  ammitto:status "active" ;\n  ammitto:reference_number "1-l3-harris-technologies" ;\n  ammitto:announcement """{"title":"公布将28家美国实体列入出口管制管控名单","url":"https://www.mofcom.gov.cn/zwgk/zcfb/art/2025/art_1ee79b1b7f21444ebf4797c0ff8500fd.html","publish_date":"2025-01-02","publish_time":"16:00","document_type":"cn/ministry-of-commerce-announcement","document_id":"第1号","signatory":"cn/ministry-of-commerce","publisher":"cn/ministry-of-commerce","authority":"cn/ministry-of-commerce","content":"根据《中华人民共和国出口管制法》和《中华人民共和国两用物项出口管制条例》等法\n律法规有关规定，为维护国家安全和利益，履行防扩散等国际义务，决定将通用动力公\n司等28家美国实体列入出口管制管控名单（见附件），并采取以下措施：\n\n一、禁止向上述28家美国实体出口两用物项；正在开展的相关出口活动应当立即停止。\n二、特殊情况下确需出口的，出口经营者应当向商务部提出申请。\n\n本公告自公布之日起正式实施。\n\n附件：出口管制管控名单（2025年1月2日）\n\n商务部\n2025年1月2日\n\n附件\n出口管制管控名单\n（2025年1月2日）\n\n1. 通用动力公司（General Dynamics）\n2. L3哈里斯公司（L3 Harris Technologies）\n3. 英特磊公司（Intelligent Epitaxy Technology）\n4. 可利尔阿莱恩公司（Clear Align LLC）\n5. 波音防务、空间与安全集团（Boeing Defense, Space & Security）\n6. 洛克希德·马丁公司（Lockheed Martin Corporation）\n7. 雷神导弹与防务公司（Raytheon Missiles & Defense）\n8. 洛克希德·马丁导弹与火控公司（Lockheed Martin Missiles and Fire Control）\n9. 洛克希德·马丁航空公司（Lockheed Martin Aeronautics）\n10. 标枪合资公司（Raytheon/Lockheed Martin Javelin Joint Venture）\n11. 雷神导弹系统公司（Raytheon Missile Systems）\n12. 通用动力军械与战术系统公司（General Dynamics Ordnance and Tactical Systems）\n13. 通用动力信息技术公司（General Dynamics Information Technology）\n14. 通用动力任务系统公司（General Dynamics Mission Systems）\n15. 海岸间电子公司（Inter-Coastal Electronics）\n16. 系统研究与模拟公司（System Studies & Simulation）\n17. 铁山解决方案公司（IronMountain Solutions）\n18. 应用技术集团（Applied Technologies Group）\n19. 阿克西恩特公司（Axient）\n20. 洛克希德·马丁导弹系统集成实验室（Lockheed Martin Missile System Integration Lab）\n21. 洛克希德·马丁先进技术实验室（Lockheed Martin Advanced Technology Laboratories）\n22. 洛克希德·马丁风险投资公司（Lockheed Martin Ventures）\n23. 安杜里尔公司（Anduril Industries）\n24. 海上战术系统公司（Maritime Tactical Systems）\n25. 环太平洋防务公司（Pacific Rim Defense）\n26. AEVEX航天公司（AEVEX Aerospace）\n27. LKD航天公司（LKD Aerospace）\n28. 顶峰科技公司（Summit Technologies Inc.）\n","language":"zh-CN"}""" ;\n  ammitto:group_id <https://www.ammitto.org/group/cn/1> ;\n  ammitto:legal_citations """{"legal_instrument_id":"https://www.ammitto.org/legal-instrument/cn/npc-export-control-law","citation_type":"legal_basis"}""" ;\n  ammitto:legal_citations """{"legal_instrument_id":"https://www.ammitto.org/legal-instrument/cn/mofcom-dual-use-export-control-regulation","citation_type":"legal_basis"}""" ;\n  ammitto:raw_source_data """{"source_format":"yaml","source_specific_fields":{"cn:list_type":"anti_sanctions","cn:sanction_list":"反制裁清单","cn:chinese_name":"L3哈里斯公司","cn:english_name":"L3 Harris Technologies"}}""" .
