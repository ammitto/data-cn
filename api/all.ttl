158.html","publish_date":"2024-05-20","publish_time":"09:00","document_type":"cn/unreliable-entity-list-working-mechanism-announcement","document_id":"〔2024〕1号","signatory":"cn/unreliable-entity-list-working-mechanism","publisher":"cn/ministry-of-commerce-industry-security-and-import-export-control","authority":"cn/unreliable-entity-list-working-mechanism","content":"为维护国家主权、安全和发展利益，根据《中华人民共和国对外贸易法》《中华人民共和国国家安全法》等有关法律，不可靠实体清单工作机制依据《不可靠实体清单规定》第二条、第八条和第十条等有关规定，决定将参与对台湾地区军售的美国通用原子航空系统公司（General Atomics Aeronautical Systems）、美国通用动力陆地系统公司（General Dynamics Land Systems）列入不可靠实体清单，并采取以下处理措施：\n\n（一）禁止上述企业从事与中国有关的进出口活动；\n（二）禁止上述企业在中国境内新增投资；\n（三）禁止上述企业高级管理人员入境；\n（四）不批准并取消上述企业高级管理人员在中国境内工作许可、停留或者居留资格。\n\n本公告未尽事宜，按《不可靠实体清单规定》执行。\n本公告自公布之日起实施。\n","language":"zh-CN"}""" ;\n  ammitto:group_id <https://www.ammitto.org/group/cn/20241> ;\n  ammitto:legal_citations """{"legal_instrument_id":"https://www.ammitto.org/legal-instrument/cn/npc-foreign-trade-law-2025","citation_type":"legal_basis"}""" ;\n  ammitto:legal_citations """{"legal_instrument_id":"https://www.ammitto.org/legal-instrument/cn/npc-national-security-law-2015","citation_type":"legal_basis"}""" ;\n  ammitto:legal_citations """{"legal_instrument_id":"https://www.ammitto.org/legal-instrument/cn/mofcom-unreliable-entity-list-provisions","articles":["第二条","第八条","第十条"],"citation_type":"legal_basis"}""" ;\n  ammitto:raw_source_data """{"source_format":"yaml","source_specific_fields":{"cn:list_type":"unreliable_entity","cn:sanction_list":"不可靠实体清单","cn:chinese_name":"通用动力陆地系统公司","cn:english_name":"General Dynamics Land Systems"}}""" .
<https://www.ammitto.org/entry/cn/unreliable-entity-list/20242-boeing-defense-space-securit>
  ammitto:entity_id <https://www.ammitto.org/entity/cn/20242-boeing-defense-space-securit> ;\n  ammitto:hasAuthority <https://www.ammitto.org/authority/cn> ;\n  ammitto:hasRegime <https://www.ammitto.org/regime/cn_unreliable_entity> ;\n  ammitto:hasEffect """{"effect_type":"prohibit_import_export","scope":"full","description":[{"value":"禁止上述企业从事与中国有关的进出口活动","lang":"zh","script":"Hani","is_primary":true},{"value":"Prohibit import and export activities related to China","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasEffect """{"effect_type":"prohibit_investment_new","scope":"full","description":[{"value":"禁止上述企业在中国境内新增投资","lang":"zh","script":"Hani","is_primary":true},{"value":"Prohibit new investment activities in China","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasEffect """{"effect_type":"entry_ban","scope":"full","description":[{"value":"禁止上述企业高级管理人员入境","lang":"zh","script":"Hani","is_primary":true},{"value":"Entry ban for senior executives","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasEffect """{"effect_type":"visa_ban","scope":"full","description":[{"value":"不批准并取消上述企业高级管理人员在中国境内工作许可、停留以及居留资格","lang":"zh","script":"Hani","is_primary":true},{"value":"Visa ban and cancellation of work permit, stay and residence qualifications in China for senior executives","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasEffect """{"effect_type":"fine","scope":"full","description":[{"value":"对上述企业处以罚款，金额为《不可靠实体清单规定》实施以来对台军售合同金额的两倍。上述企业应当自本公告公布之日起15日内，按照相关法律法规办理缴款。若逾期不履行本决定，不可靠实体清单工作机制将依法采取加处罚款等措施","lang":"zh","script":"Hani","is_primary":true},{"value":"Impose a fine on the above enterprise, amounting to twice the amount of the arms sales contract to Taiwan since the implementation of the Unreliable Entity List Regulations. The above enterprise shall, within 15 days from the date of publication of this announcement, make the payment in accordance with relevant laws and regulations. If it fails to comply with this decision within the time limit, the Unreliable Entity List Mechanism will take additional measures such as imposing additional fines in accordance with the law.","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasReason """{"category":"other","description":[{"value":"参与对台湾地区军售","lang":"zh","script":"Hani","is_primary":true},{"value":"Participating in arms sales to Taiwan region","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasPeriod """{"effective_date":"2024-05-20","is_indefinite":false}""" ;\n  ammitto:status "active" ;\n  ammitto:reference_number "20242-boeing-defense-space-securit" ;\n  ammitto:announcement """{"title":"不可靠实体清单工作机制关于将波音防务、空间与安全集团列入不可靠实体清单的公告","url":"https://aqygzj.mofcom.gov.cn/flzc/gzjgfxwj/art/2024/art_41f74ffdff914c6dafb548617919d1dd.html","publish_date":"2024-05-20","publish_time":"09:00","document_type":"cn/unreliable-entity-list-working-mechanism-announcement","document_id":"〔2024〕2号","signatory":"cn/unreliable-entity-list-working-mechanism","publisher":"cn/ministry-of-commerce-industry-security-and-import-export-control","authority":"cn/unreliable-entity-list-working-mechanism","content":"为维护国家主权、安全和发展利益，根据《中华人民共和国对外贸易法》《中华人民共和国国家安全法》等有关法律，不可靠实体清单工作机制依据《不可靠实体清单规定》第二条、第八条和第十条等有关规定，决定将参与对台湾地区军售的美国波音防务、空间与安全集团（Boeing Defense, Space & Security）列入不可靠实体清单，并采取以下处理措施：\n\n一、禁止上述企业从事与中国有关的进出口活动；\n二、禁止上述企业在中国境内新增投资；\n三、禁止上述企业高级管理人员入境；\n四、不批准并取消上述企业高级管理人员在中国境内工作许可、停留或者居留资格；\n五、对上述企业处以罚款，金额为《不可靠实体清单规定》实施以来对台军售合同金额的两倍。上述企业应当自本公告公布之日起15日内，按照相关法律法规办理缴款。若逾期不履行本决定，不可靠实体清单工作机制将依法采取加处罚款等措施。\n\n本公告未尽事宜，按《不可靠实体清单规定》执行。\n本公告自公布之日起实施。\n","language":"zh-CN"}""" ;\n  ammitto:legal_citations """{"legal_instrument_id":"https://www.ammitto.org/legal-instrument/cn/npc-foreign-trade-law-2025","citation_type":"legal_basis"}""" ;\n  ammitto:legal_citations """{"legal_instrument_id":"https://www.ammitto.org/legal-instrument/cn/npc-national-security-law-2015","citation_type":"legal_basis"}""" ;\n  ammitto:legal_citations """{"legal_instrument_id":"https://www.ammitto.org/legal-instrument/cn/mofcom-unreliable-entity-list-provisions","articles":["第二条","第八条","第十条"],"citation_type":"legal_basis"}""" ;\n  ammitto:raw_source_data """{"source_format":"yaml","source_specific_fields":{"cn:list_type":"unreliable_entity","cn:sanction_list":"不可靠实体清单","cn:chinese_name":"波音防务、空间与安全集团","cn:english_name":"Boeing Defense, Space & Security"}}""" .
<https://www.ammitto.org/entry/cn/unreliable-entity-list/20243-pvh-corp>
  ammitto:entity_id <https://www.ammitto.org/entity/cn/20243-pvh-corp> ;\n  ammitto:hasAuthority <https://www.ammitto.org/authority/cn> ;\n  ammitto:hasRegime <https://www.ammitto.org/regime/cn_unreliable_entity> ;\n  ammitto:hasEffect """{"effect_type":"investigation","scope":"full","description":[{"value":"启动不可靠实体清单调查","lang":"zh","script":"Hani","is_primary":true},{"value":"Investigation launched under unreliable entity list","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasEffect """{"effect_type":"provide_information","scope":"full","description":[{"value":"美国PVH集团应在本公告公布之日起30天内向不可靠实体清单工作机制办公室提供说明近3年内是否存在对涉疆产品采取歧视性措施等问题的书面材料及证明资料以及调查机关需要的其他资料。","lang":"zh","script":"Hani","is_primary":true},{"value":"PVH Corp. should provide written materials and evidence to the Unreliable Entity List Working Mechanism Office within 30 days from the date of this announcement, regarding whether discriminatory measures have been taken against Xinjiang-related products in the past three years, as well as other materials needed by the investigation authorities.","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasEffect """{"effect_type":"allow_statement","scope":"full","description":[{"value":"调查期间，美国PVH集团可向不可靠实体清单工作机制办公室陈述、申辩。","lang":"zh","script":"Hani","is_primary":true},{"value":"During the investigation, PVH Corp. can make statements and defenses to the Unreliable Entity List Working Mechanism Office.","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasEffect """{"effect_type":"cooperate_investigation","scope":"full","description":[{"value":"不可靠实体清单工作机制办公室依法采取询问当事人、查阅或者复制相关文件、资料以及其他必要的方式，对PVH集团开展调查，PVH集团及有关企业应予以配合。","lang":"zh","script":"Hani","is_primary":true},{"value":"The Unreliable Entity List Working Mechanism Office will conduct the investigation by asking the parties involved, reviewing or copying relevant documents and materials, and other necessary means in accordance with the law. PVH Corp. and related enterprises should cooperate.","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasEffect """{"effect_type":"report_violation","scope":"full","description":[{"value":"调查期间，任何单位和个人可向不可靠实体清单工作机制办公室反映美国PVH集团违反正常的市场交易原则，针对涉疆产品，中断与中国企业、其他组织或者个人的正常交易、采取歧视性措施等情况，并应提供相关证据。","lang":"zh","script":"Hani","is_primary":true},{"value":"During the investigation, any unit and individual can report to the Unreliable Entity List Working Mechanism Office about PVH Corp.'s violation of normal market transaction principles, such as disrupting normal transactions with Chinese enterprises, other organizations or individuals, taking discriminatory measures against Xinjiang-related products, etc., and should provide relevant evidence.","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasReason """{"category":"other","description":[{"value":"针对涉疆产品涉嫌违反正常的市场交易原则，中断与中国企业、其他组织或者个人的正常交易、采取歧视性措施","lang":"zh","script":"Hani","is_primary":true},{"value":"Potentially violating normal market transaction principles by taking discriminatory measures against Xinjiang-related products, disrupting normal transactions with Chinese enterprises, other organizations or individuals","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasPeriod """{"effective_date":"2024-09-24","is_indefinite":false}""" ;\n  ammitto:status "active" ;\n  ammitto:reference_number "20243-pvh-corp" ;\n  ammitto:announcement """{"title":"不可靠实体清单工作机制关于对美国PVH集团启动不可靠实体清单调查的公告","url":"https://aqygzj.mofcom.gov.cn/flzc/gzjgfxwj/art/2024/art_f5ac8919a05743f78a3c25f3d0c138f5.html","publish_date":"2024-09-24","publish_time":"16:00","document_type":"cn/unreliable-entity-list-working-mechanism-announcement","document_id":"〔2024〕3号","signatory":"cn/unreliable-entity-list-working-mechanism","publisher":"cn/ministry-of-commerce-industry-security-and-import-export-control","authority":"cn/unreliable-entity-list-working-mechanism","content":"为维护国家主权、安全和发展利益，根据《中华人民共和国对外贸易法》《中华人民共和国国家安全法》《中华人民共和国反外国制裁法》等有关法律，不可靠实体清单工作机制依据《不可靠实体清单规定》第二条、第五条和第六条等有关规定，根据有关机构的建议、举报，决定对美国PVH集团针对涉疆产品涉嫌违反正常的市场交易原则，中断与中国企业、其他组织或者个人的正常交易、采取歧视性措施等问题启动调查。\n\n一、美国PVH集团应在本公告公布之日起30天内向不可靠实体清单工作机制办公室提供说明近3年内是否存在对涉疆产品采取歧视性措施等问题的书面材料及证明资料以及调查机关需要的其他资料。\n二、调查期间，美国PVH集团可向不可靠实体清单工作机制办公室陈述、申辩。\n三、不可靠实体清单工作机制办公室依法采取询问当事人、查阅或者复制相关文件、资料以及其他必要的方式，对PVH集团开展调查，PVH集团及有关企业应予以配合。\n四、调查期间，任何单位和个人可向不可靠实体清单工作机制办公室反映美国PVH集团违反正常的市场交易原则，针对涉疆产品，中断与中国企业、其他组织或者个人的正常交易、采取歧视性措施等情况，并应提供相关证据。\n\n不可靠实体清单工作机制办公室联系方式：\n\n地址：北京市东城区东长安街2号\n邮编：100731\n电子邮箱：agjasc@mofcom.gov.cn\n","language":"zh-CN"}""" ;\n  ammitto:legal_citations """{"legal_instrument_id":"https://www.ammitto.org/legal-instrument/cn/npc-foreign-trade-law-2025","citation_type":"legal_basis"}""" ;\n  ammitto:legal_citations """{"legal_instrument_id":"https://www.ammitto.org/legal-instrument/cn/npc-national-security-law-2015","citation_type":"legal_basis"}""" ;\n  ammitto:legal_citations """{"legal_instrument_id":"https://www.ammitto.org/legal-instrument/cn/npc-anti-foreign-sanctions-law","citation_type":"legal_basis"}""" ;\n  ammitto:legal_citations """{"legal_instrument_id":"https://www.ammitto.org/legal-instrument/cn/mofcom-unreliable-entity-list-provisions","articles":["第二条","第五条","第六条"],"citation_type":"legal_basis"}""" ;\n  ammitto:raw_source_data """{"source_format":"yaml","source_specific_fields":{"cn:list_type":"unreliable_entity","cn:sanction_list":"不可靠实体清单","cn:chinese_name":"PVH集团","cn:english_name":"PVH Corp."}}""" .
<https://www.ammitto.org/entry/cn/unreliable-entity-list/20251-lockheed-martin-missiles-and-fi>
  ammitto:entity_id <https://www.ammitto.org/entity/cn/20251-lockheed-martin-missiles-and-fi> ;\n  ammitto:hasAuthority <https://www.ammitto.org/authority/cn> ;\n  ammitto:hasRegime <https://www.ammitto.org/regime/cn_unreliable_entity> ;\n  ammitto:hasEffect """{"effect_type":"prohibit_import_export","scope":"full","description":[{"value":"禁止上述企业从事与中国有关的进出口活动","lang":"zh","script":"Hani","is_primary":true},{"value":"Prohibit import and export activities related to China","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasEffect """{"effect_type":"prohibit_investment_new","scope":"full","description":[{"value":"禁止上述企业在中国境内新增投资","lang":"zh","script":"Hani","is_primary":true},{"value":"Prohibit new investment activities in China","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasEffect """{"effect_type":"entry_ban","scope":"full","description":[{"value":"禁止上述企业高级管理人员入境","lang":"zh","script":"Hani","is_primary":true},{"value":"Entry ban for senior executives","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasEffect """{"effect_type":"visa_ban","scope":"full","description":[{"value":"不批准并取消上述企业高级管理人员在中国境内工作许可、停留以及居留资格","lang":"zh","script":"Hani","is_primary":true},{"value":"Visa ban and cancellation of work permit, stay and residence qualifications in China for senior executives","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasReason """{"category":"other","description":[{"value":"参与对台湾地区军售","lang":"zh","script":"Hani","is_primary":true},{"value":"Participating in arms sales to Taiwan region","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasPeriod """{"effective_date":"2025-01-02","is_indefinite":false}""" ;\n  ammitto:status "active" ;\n  ammitto:reference_number "20251-lockheed-martin-missiles-and-fi" ;\n  ammitto:announcement """{"title":"不可靠实体清单工作机制关于对洛克希德·马丁导弹与火控公司等10家美国企业采取不可靠实体清单措施的公告","url":"https://www.mofcom.gov.cn/zwgk/zcfb/art/2025/art_c164b1339d694766938f75c1f83bddf8.html","publish_date":"2025-01-02","publish_time":"16:00","document_type":"cn/unreliable-entity-list-working-mechanism-announcement","document_id":"〔2025〕1号","signatory":"cn/unreliable-entity-list-working-mechanism","publisher":"cn/ministry-of-commerce-industry-security-and-import-export-control","authority":"cn/unreliable-entity-list-working-mechanism","content":"为维护国家主权、安全和发展利益，根据《中华人民共和国对外贸易法》《中华人民共和国国家安全法》《中华人民共和国反外国制裁法》等有关法律，不可靠实体清单工作机制依据《不可靠实体清单规定》第二条、第八条和第十条等有关规定，决定将参与对台湾地区军售的洛克希德·马丁导弹与火控公司（Lockheed Martin Missiles and Fire Control）、洛克希德·马丁航空公司（Lockheed Martin Aeronautics）、洛克希德·马丁导弹系统集成实验室（Lockheed Martin Missile System Integration Lab)、洛克希德·马丁先进技术实验室（Lockheed Martin Advanced Technology Laboratories)、洛克希德·马丁风险投资公司（Lockheed Martin Ventures)、标枪合资公司（Raytheon/Lockheed Martin Javelin Joint Venture）、雷神导弹系统公司（Raytheon Missile Systems）、通用动力军械与战术系统公司（General Dynamics Ordnance and Tactical Systems）、通用动力信息技术公司（General Dynamics Information Technology）、通用动力任务系统公司（General Dynamics Mission Systems）列入不可靠实体清单，并采取以下处理措施：\n\n一、禁止上述企业从事与中国有关的进出口活动；\n二、禁止上述企业在中国境内新增投资；\n三、禁止上述企业高级管理人员入境；\n四、不批准并取消上述企业高级管理人员在中国境内工作许可、停留或者居留资格。\n\n本公告未尽事宜，按《不可靠实体清单规定》执行。\n本公告自公布之日起实施。\n","language":"zh-CN"}""" ;\n  ammitto:group_id <https://www.ammitto.org/group/cn/20251> ;\n  ammitto:legal_citations """{"legal_instrument_id":"https://www.ammitto.org/legal-instrument/cn/npc-foreign-trade-law-2025","citation_type":"legal_basis"}""" ;\n  ammitto:legal_citations """{"legal_instrument_id":"https://www.ammitto.org/legal-instrument/cn/npc-national-security-law-2015","citation_type":"legal_basis"}""" ;\n  ammitto:legal_citations """{"legal_instrument_id":"https://www.ammitto.org/legal-instrument/cn/npc-anti-foreign-sanctions-law","citation_type":"legal_basis"}""" ;\n  ammitto:legal_citations """{"legal_instrument_id":"https://www.ammitto.org/legal-instrument/cn/mofcom-unreliable-entity-list-provisions","articles":["第二条","第八条","第十条"],"citation_type":"legal_basis"}""" ;\n  ammitto:raw_source_data """{"source_format":"yaml","source_specific_fields":{"cn:list_type":"unreliable_entity","cn:sanction_list":"不可靠实体清单","cn:chinese_name":"洛克希德·马丁导弹与火控公司","cn:english_name":"Lockheed Martin Missiles and Fire Control"}}""" .
