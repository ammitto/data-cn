/web/wjb_673085/zfxxgk_674865/gknrlb/fzcqdcs/202412/t20241217_11494912.shtml","publish_date":"2024-10-10","publish_time":"17:00","document_type":"cn/ministry-of-foreign-affairs-order","document_id":"第13号","signatory":"cn/ministry-of-foreign-affairs","publisher":"cn/ministry-of-foreign-affairs","authority":"cn/ministry-of-foreign-affairs","content":"（2024年10月10日中华人民共和国外交部令第13号公布，自2024年10月10日起施行）\n\n美国近日宣布向中国台湾地区提供大额武器援助，严重违反一个中国原则和中美三个联合公报，严重干涉中国内政，严重损害中国主权和领土完整。依据《中华人民共和国反外国制裁法》第三条、第四条、第五条、第六条、第九条、第十五条规定，中方决定对以下美国军工企业及高级管理人员采取反制措施：\n\n一、对边缘自治运营公司、亨廷顿·英格尔斯工业公司、斯凯迪奥公司等3家后附《反制清单》列明的企业，冻结在我国境内的动产、不动产和其他各类财产；禁止我国境内的组织、个人与其进行有关交易、合作等活动。\n\n二、对史蒂文·鲁德（摇杆舵公司创始人）、詹姆斯·伊克斯（内华达山脉公司副总裁）、大卫·萨顿（洛克希德·马丁公司亚洲区主任）、朴英泰（宇航环境公司副总裁）、帕特里克·扬科夫斯基（诺斯罗普·格鲁曼公司印太项目主任）、约翰·普维斯（边缘自治运营公司前首席执行官）、乔什·布伦加特（边缘自治运营公司首席运营官）、克里斯托弗·卡斯特纳（亨廷顿·英格尔斯工业公司总裁、首席执行官）、亚当·布赖（斯凯迪奥公司联合创始人、首席执行官）、汤姆·莫斯（斯凯迪奥公司亚太区总经理）等10名后附《反制清单》列明的企业高级管理人员，冻结在我国境内的动产、不动产和其他各类财产；禁止我国境内的组织、个人与其本人进行有关交易、合作等活动；对其本人不予签发签证、不准入境（包括香港、澳门）。\n\n本决定自2024年10月10日起施行。\n","language":"zh-CN"}""" ;\n  ammitto:group_id <https://www.ammitto.org/group/cn/13> ;\n  ammitto:legal_citations """{"legal_instrument_id":"https://www.ammitto.org/legal-instrument/cn/npc-anti-foreign-sanctions-law","articles":["第三条","第四条","第五条","第六条","第九条","第十五条"],"citation_type":"legal_basis"}""" ;\n  ammitto:raw_source_data """{"source_format":"yaml","source_specific_fields":{"cn:list_type":"anti_sanctions","cn:sanction_list":"反制裁清单","cn:chinese_name":"汤姆·莫斯","cn:english_name":"Tom Moss"}}""" .
<https://www.ammitto.org/entry/cn/anti-sanction-list/14-teledyne-brown-engineering-inc>
  ammitto:entity_id <https://www.ammitto.org/entity/cn/14-teledyne-brown-engineering-inc> ;\n  ammitto:hasAuthority <https://www.ammitto.org/authority/cn> ;\n  ammitto:hasRegime <https://www.ammitto.org/regime/cn_anti_sanctions> ;\n  ammitto:hasEffect """{"effect_type":"asset_freeze","scope":"full","description":[{"value":"冻结在我国境内的动产、不动产和其他各类财产","lang":"zh","script":"Hani","is_primary":true},{"value":"Freeze all assets in China, including movable and immovable property and other types of assets","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasEffect """{"effect_type":"prohibit_transactions","scope":"full","description":[{"value":"禁止我国境内的组织、个人与其进行有关交易、合作等活动","lang":"zh","script":"Hani","is_primary":true},{"value":"Prohibit organizations and individuals in China from engaging in transactions, cooperation or related activities with the entity","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasReason """{"category":"other","description":[{"value":"美国近日再次宣布向中国台湾地区出售武器，严重违反一个中国原则和中美三个联合公报，严重干涉中国内政，严重损害中国主权和领土完整。","lang":"zh","script":"Hani","is_primary":true},{"value":"The US recently announced again the sale of weapons to China's Taiwan region, seriously violating the One-China principle and the three China-US joint communiqués, seriously interfering in China's internal affairs, and seriously damaging China's sovereignty and territorial integrity.","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasPeriod """{"effective_date":"2024-12-05","is_indefinite":false}""" ;\n  ammitto:status "active" ;\n  ammitto:reference_number "14-teledyne-brown-engineering-inc" ;\n  ammitto:announcement """{"title":"关于对美国军工企业及高级管理人员采取反制措施的决定","url":"https://www.mfa.gov.cn/web/wjb_673085/zfxxgk_674865/gknrlb/fzcqdcs/202412/t20241217_11495202.shtml","publish_date":"2024-12-05","publish_time":"15:00","document_type":"cn/ministry-of-foreign-affairs-order","document_id":"第14号","signatory":"cn/ministry-of-foreign-affairs","publisher":"cn/ministry-of-foreign-affairs","authority":"cn/ministry-of-foreign-affairs","content":"（2024年12月5日中华人民共和国外交部令第14号公布，自2024年12月5日起施行）\n\n美国近日再次宣布向中国台湾地区出售武器，严重违反一个中国原则和中美三个联合公报，严重干涉中国内政，严重损害中国主权和领土完整。依据《中华人民共和国反外国制裁法》第三条、第四条、第五条、第六条、第九条、第十五条规定，中方决定对以下美国军工企业及高级管理人员采取反制措施：\n\n一、对特励达·布朗工程公司、BRINC无人机公司、急速飞行公司、红色六方案公司、护盾人工智能公司、赛尼克斯公司、火风暴实验室公司、奎托斯无人机系统公司、浩劫人工智能公司、尼罗斯科技公司、赛博勒克斯公司、多莫战术通信公司、Group W公司等13家后附《反制清单》列明的企业，冻结在我国境内的动产、不动产和其他各类财产；禁止我国境内的组织、个人与其进行有关交易、合作等活动。\n\n二、对芭芭拉·博尔戈诺维（雷神公司海军力量战略业务部总裁）、杰拉德·许贝尔（雷神公司海军力量战略业务部副总裁）、查尔斯·伍德伯恩（贝宜陆上和武器系统公司首席执行官）、理查德·克劳福德（联合技术系统运营公司创始人、首席执行官）、安珀·多兰（数据链路解决方案有限责任公司总监）、布莱克·雷斯尼克（BRINC无人机公司创始人、首席执行官）等6名后附《反制清单》列明的企业高级管理人员，冻结在我国境内的动产、不动产和其他各类财产；禁止我国境内的组织、个人与其本人进行有关交易、合作等活动；对其本人不予签发签证、不准入境（包括香港、澳门）。\n\n本决定自2024年12月5日起施行。\n","language":"zh-CN"}""" ;\n  ammitto:group_id <https://www.ammitto.org/group/cn/14> ;\n  ammitto:legal_citations """{"legal_instrument_id":"https://www.ammitto.org/legal-instrument/cn/npc-anti-foreign-sanctions-law","articles":["第三条","第四条","第五条","第六条","第九条","第十五条"],"citation_type":"legal_basis"}""" ;\n  ammitto:raw_source_data """{"source_format":"yaml","source_specific_fields":{"cn:list_type":"anti_sanctions","cn:sanction_list":"反制裁清单","cn:chinese_name":"特励达·布朗工程公司","cn:english_name":"Teledyne Brown Engineering, Inc."}}""" .
<https://www.ammitto.org/entry/cn/anti-sanction-list/14-brinc-drones-inc>
  ammitto:entity_id <https://www.ammitto.org/entity/cn/14-brinc-drones-inc> ;\n  ammitto:hasAuthority <https://www.ammitto.org/authority/cn> ;\n  ammitto:hasRegime <https://www.ammitto.org/regime/cn_anti_sanctions> ;\n  ammitto:hasEffect """{"effect_type":"asset_freeze","scope":"full","description":[{"value":"冻结在我国境内的动产、不动产和其他各类财产","lang":"zh","script":"Hani","is_primary":true},{"value":"Freeze all assets in China, including movable and immovable property and other types of assets","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasEffect """{"effect_type":"prohibit_transactions","scope":"full","description":[{"value":"禁止我国境内的组织、个人与其进行有关交易、合作等活动","lang":"zh","script":"Hani","is_primary":true},{"value":"Prohibit organizations and individuals in China from engaging in transactions, cooperation or related activities with the entity","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasReason """{"category":"other","description":[{"value":"美国近日再次宣布向中国台湾地区出售武器，严重违反一个中国原则和中美三个联合公报，严重干涉中国内政，严重损害中国主权和领土完整。","lang":"zh","script":"Hani","is_primary":true},{"value":"The US recently announced again the sale of weapons to China's Taiwan region, seriously violating the One-China principle and the three China-US joint communiqués, seriously interfering in China's internal affairs, and seriously damaging China's sovereignty and territorial integrity.","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasPeriod """{"effective_date":"2024-12-05","is_indefinite":false}""" ;\n  ammitto:status "active" ;\n  ammitto:reference_number "14-brinc-drones-inc" ;\n  ammitto:announcement """{"title":"关于对美国军工企业及高级管理人员采取反制措施的决定","url":"https://www.mfa.gov.cn/web/wjb_673085/zfxxgk_674865/gknrlb/fzcqdcs/202412/t20241217_11495202.shtml","publish_date":"2024-12-05","publish_time":"15:00","document_type":"cn/ministry-of-foreign-affairs-order","document_id":"第14号","signatory":"cn/ministry-of-foreign-affairs","publisher":"cn/ministry-of-foreign-affairs","authority":"cn/ministry-of-foreign-affairs","content":"（2024年12月5日中华人民共和国外交部令第14号公布，自2024年12月5日起施行）\n\n美国近日再次宣布向中国台湾地区出售武器，严重违反一个中国原则和中美三个联合公报，严重干涉中国内政，严重损害中国主权和领土完整。依据《中华人民共和国反外国制裁法》第三条、第四条、第五条、第六条、第九条、第十五条规定，中方决定对以下美国军工企业及高级管理人员采取反制措施：\n\n一、对特励达·布朗工程公司、BRINC无人机公司、急速飞行公司、红色六方案公司、护盾人工智能公司、赛尼克斯公司、火风暴实验室公司、奎托斯无人机系统公司、浩劫人工智能公司、尼罗斯科技公司、赛博勒克斯公司、多莫战术通信公司、Group W公司等13家后附《反制清单》列明的企业，冻结在我国境内的动产、不动产和其他各类财产；禁止我国境内的组织、个人与其进行有关交易、合作等活动。\n\n二、对芭芭拉·博尔戈诺维（雷神公司海军力量战略业务部总裁）、杰拉德·许贝尔（雷神公司海军力量战略业务部副总裁）、查尔斯·伍德伯恩（贝宜陆上和武器系统公司首席执行官）、理查德·克劳福德（联合技术系统运营公司创始人、首席执行官）、安珀·多兰（数据链路解决方案有限责任公司总监）、布莱克·雷斯尼克（BRINC无人机公司创始人、首席执行官）等6名后附《反制清单》列明的企业高级管理人员，冻结在我国境内的动产、不动产和其他各类财产；禁止我国境内的组织、个人与其本人进行有关交易、合作等活动；对其本人不予签发签证、不准入境（包括香港、澳门）。\n\n本决定自2024年12月5日起施行。\n","language":"zh-CN"}""" ;\n  ammitto:group_id <https://www.ammitto.org/group/cn/14> ;\n  ammitto:legal_citations """{"legal_instrument_id":"https://www.ammitto.org/legal-instrument/cn/npc-anti-foreign-sanctions-law","articles":["第三条","第四条","第五条","第六条","第九条","第十五条"],"citation_type":"legal_basis"}""" ;\n  ammitto:raw_source_data """{"source_format":"yaml","source_specific_fields":{"cn:list_type":"anti_sanctions","cn:sanction_list":"反制裁清单","cn:chinese_name":"BRINC无人机公司","cn:english_name":"BRINC Drones, Inc."}}""" .
<https://www.ammitto.org/entry/cn/anti-sanction-list/14-rapid-flight-llc>
  ammitto:entity_id <https://www.ammitto.org/entity/cn/14-rapid-flight-llc> ;\n  ammitto:hasAuthority <https://www.ammitto.org/authority/cn> ;\n  ammitto:hasRegime <https://www.ammitto.org/regime/cn_anti_sanctions> ;\n  ammitto:hasEffect """{"effect_type":"asset_freeze","scope":"full","description":[{"value":"冻结在我国境内的动产、不动产和其他各类财产","lang":"zh","script":"Hani","is_primary":true},{"value":"Freeze all assets in China, including movable and immovable property and other types of assets","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasEffect """{"effect_type":"prohibit_transactions","scope":"full","description":[{"value":"禁止我国境内的组织、个人与其进行有关交易、合作等活动","lang":"zh","script":"Hani","is_primary":true},{"value":"Prohibit organizations and individuals in China from engaging in transactions, cooperation or related activities with the entity","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasReason """{"category":"other","description":[{"value":"美国近日再次宣布向中国台湾地区出售武器，严重违反一个中国原则和中美三个联合公报，严重干涉中国内政，严重损害中国主权和领土完整。","lang":"zh","script":"Hani","is_primary":true},{"value":"The US recently announced again the sale of weapons to China's Taiwan region, seriously violating the One-China principle and the three China-US joint communiqués, seriously interfering in China's internal affairs, and seriously damaging China's sovereignty and territorial integrity.","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasPeriod """{"effective_date":"2024-12-05","is_indefinite":false}""" ;\n  ammitto:status "active" ;\n  ammitto:reference_number "14-rapid-flight-llc" ;\n  ammitto:announcement """{"title":"关于对美国军工企业及高级管理人员采取反制措施的决定","url":"https://www.mfa.gov.cn/web/wjb_673085/zfxxgk_674865/gknrlb/fzcqdcs/202412/t20241217_11495202.shtml","publish_date":"2024-12-05","publish_time":"15:00","document_type":"cn/ministry-of-foreign-affairs-order","document_id":"第14号","signatory":"cn/ministry-of-foreign-affairs","publisher":"cn/ministry-of-foreign-affairs","