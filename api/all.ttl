  ammitto:entity_id <https://www.ammitto.org/entity/cn/20255-huntington-ingalls-industries-i> ;\n  ammitto:hasAuthority <https://www.ammitto.org/authority/cn> ;\n  ammitto:hasRegime <https://www.ammitto.org/regime/cn_unreliable_entity> ;\n  ammitto:hasEffect """{"effect_type":"prohibit_import_export","scope":"full","description":[{"value":"禁止上述企业从事与中国有关的进出口活动","lang":"zh","script":"Hani","is_primary":true},{"value":"Prohibit import and export activities related to China","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasEffect """{"effect_type":"prohibit_investment_new","scope":"full","description":[{"value":"禁止上述企业在中国境内新增投资","lang":"zh","script":"Hani","is_primary":true},{"value":"Prohibit new investment activities in China","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasReason """{"category":"other","description":[{"value":"为维护国家主权、安全和发展利益","lang":"zh","script":"Hani","is_primary":true},{"value":"To safeguard national sovereignty, security and development interests","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasPeriod """{"effective_date":"2025-03-04","is_indefinite":false}""" ;\n  ammitto:status "active" ;\n  ammitto:reference_number "20255-huntington-ingalls-industries-i" ;\n  ammitto:announcement """{"title":"不可靠实体清单工作机制关于将特科姆公司等10家美国企业列入不可靠实体清单的公告","url":"https://www.mofcom.gov.cn/zwgk/zcfb/art/2025/art_beb25dc3bf9447f9ba7a34b25cca8f64.html","publish_date":"2025-03-04","publish_time":"13:01","document_type":"cn/unreliable-entity-list-working-mechanism-announcement","document_id":"〔2025〕5号","signatory":"cn/unreliable-entity-list-working-mechanism","publisher":"cn/ministry-of-commerce-industry-security-and-import-export-control","authority":"cn/unreliable-entity-list-working-mechanism","content":"为维护国家主权、安全和发展利益，根据《中华人民共和国对外贸易法》《中华人民共和国国家安全法》《中华人民共和国反外国制裁法》等有关法律，不可靠实体清单工作机制依据《不可靠实体清单规定》第二条、第八条和第十条等有关规定，决定将特科姆公司等10家实体列入不可靠实体清单，并采取以下处理措施：\n\n一、禁止上述企业从事与中国有关的进出口活动；\n二、禁止上述企业在中国境内新增投资。\n\n本公告未尽事宜，按《不可靠实体清单规定》执行。\n本公告自公布之日起实施。\n","language":"zh-CN"}""" ;\n  ammitto:group_id <https://www.ammitto.org/group/cn/20255> ;\n  ammitto:legal_citations """{"legal_instrument_id":"https://www.ammitto.org/legal-instrument/cn/npc-foreign-trade-law-2025","citation_type":"legal_basis"}""" ;\n  ammitto:legal_citations """{"legal_instrument_id":"https://www.ammitto.org/legal-instrument/cn/npc-national-security-law-2015","citation_type":"legal_basis"}""" ;\n  ammitto:legal_citations """{"legal_instrument_id":"https://www.ammitto.org/legal-instrument/cn/npc-anti-foreign-sanctions-law","citation_type":"legal_basis"}""" ;\n  ammitto:legal_citations """{"legal_instrument_id":"https://www.ammitto.org/legal-instrument/cn/mofcom-unreliable-entity-list-provisions","articles":["第二条","第八条","第十条"],"citation_type":"legal_basis"}""" ;\n  ammitto:raw_source_data """{"source_format":"yaml","source_specific_fields":{"cn:list_type":"unreliable_entity","cn:sanction_list":"不可靠实体清单","cn:chinese_name":"亨廷顿·英格尔斯工业公司","cn:english_name":"Huntington Ingalls Industries Inc."}}""" .
