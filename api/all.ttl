  ammitto:entity_id <https://www.ammitto.org/entity/cn/202535-jong-shyn-shipbuilding-co-ltd> ;\n  ammitto:hasAuthority <https://www.ammitto.org/authority/cn> ;\n  ammitto:hasRegime <https://www.ammitto.org/regime/cn_export_control> ;\n  ammitto:hasEffect """{"effect_type":"prohibit_export_dual_use_items","scope":"full","description":[{"value":"禁止向上述台湾地区实体出口两用物项；正在开展的相关出口活动应当立即停止","lang":"zh","script":"Hani","is_primary":true},{"value":"Prohibit the export of dual-use items to the above Taiwan entity; ongoing related export activities should be immediately ceased","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasEffect """{"effect_type":"export_license_requirement","scope":"full","description":[{"value":"特殊情况下确需出口的，出口经营者应当向商务部提出申请","lang":"zh","script":"Hani","is_primary":true},{"value":"In special circumstances where export is necessary, exporters should apply to the Ministry of Commerce for approval","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasReason """{"category":"other","description":[{"value":"为维护国家安全和利益，履行防扩散等国际义务","lang":"zh","script":"Hani","is_primary":true},{"value":"To safeguard national security and interests, and to fulfill international obligations such as non-proliferation","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasPeriod """{"effective_date":"2025-07-09","is_indefinite":false}""" ;\n  ammitto:status "active" ;\n  ammitto:reference_number "202535-jong-shyn-shipbuilding-co-ltd" ;\n  ammitto:announcement """{"title":"公布将8家台湾地区实体列入出口管制管控名单","url":"https://www.mofcom.gov.cn/zwgk/zcfb/art/2025/art_53c6b5ab958841dfb90b77c00f8602cf.html","publish_date":"2025-07-09","document_type":"cn/ministry-of-commerce-announcement","document_id":"2025年第35号","signatory":"cn/ministry-of-commerce","publisher":"cn/ministry-of-commerce","authority":"cn/ministry-of-commerce","content":"根据《中华人民共和国出口管制法》和《中华人民共和国两用物项出口管制条例》等法律法规有关规定，为维护国家安全和利益，履行防扩散等国际义务，决定将汉翔航空工业股份有限公司等8家台湾地区实体列入出口管制管控名单（见附件），并采取以下措施：\n\n一、禁止向上述8家台湾地区实体出口两用物项；正在开展的相关出口活动应当立即停止。\n二、特殊情况下确需出口的，出口经营者应当向商务部提出申请。\n\n本公告自公布之日起正式实施。\n","language":"zh-CN"}""" ;\n  ammitto:group_id <https://www.ammitto.org/group/cn/202535> ;\n  ammitto:legal_citations """{"legal_instrument_id":"https://www.ammitto.org/legal-instrument/cn/npc-export-control-law","citation_type":"legal_basis"}""" ;\n  ammitto:legal_citations """{"legal_instrument_id":"https://www.ammitto.org/legal-instrument/cn/mofcom-dual-use-export-control-regulation","citation_type":"legal_basis"}""" ;\n  ammitto:raw_source_data """{"source_format":"yaml","source_specific_fields":{"cn:list_type":"export_control","cn:sanction_list":"出口管制管控名单","cn:chinese_name":"中信造船股份有限公司","cn:english_name":"Jong Shyn Shipbuilding Co., Ltd."}}""" .
