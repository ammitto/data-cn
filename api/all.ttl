<https://www.ammitto.org/entry/cn/anti-sanction-list/4-unknown>
  ammitto:entity_id <https://www.ammitto.org/entity/cn/4-unknown> ;\n  ammitto:hasAuthority <https://www.ammitto.org/authority/cn> ;\n  ammitto:hasRegime <https://www.ammitto.org/regime/cn_anti_sanctions> ;\n  ammitto:hasEffect """{"effect_type":"asset_freeze","scope":"full","description":[{"value":"冻结在我国境内的动产、不动产和其他各类财产","lang":"zh","script":"Hani","is_primary":true},{"value":"Freeze all assets in China, including movable and immovable property and other types of assets","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasEffect """{"effect_type":"prohibit_transactions","scope":"full","description":[{"value":"禁止我国境内的组织、个人与其进行有关交易活动","lang":"zh","script":"Hani","is_primary":true},{"value":"Prohibit transactions with Chinese organizations and individuals","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasEffect """{"effect_type":"entry_ban","scope":"full","description":[{"value":"对其本人及直系亲属不予签发签证、不准入境","lang":"zh","script":"Hani","is_primary":true},{"value":"Visa ban for the individual and their immediate family members","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasReason """{"category":"other","description":[{"value":"美方借口所谓“西藏人权”问题，对两名中方官员进行非法制裁","lang":"zh","script":"Hani","is_primary":true},{"value":"The US imposed illegal sanctions on two Chinese officials under the pretext of \"Tibet human rights\" issues.","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasPeriod """{"effective_date":"2022-12-23","is_indefinite":false}""" ;\n  ammitto:status "active" ;\n  ammitto:reference_number "4-unknown" ;\n  ammitto:announcement """{"title":"关于对余茂春、托德·斯坦恩采取反制裁措施的决定","url":"https://www.mfa.gov.cn/web/wjb_673085/zfxxgk_674865/gknrlb/fzcqdcs/202212/t20221222_10993979.shtml","publish_date":"2022-12-23","publish_time":"08:00","document_type":"cn/ministry-of-foreign-affairs-order","document_id":"第4号","signatory":"王毅","signatory_title":"部长","publisher":"cn/ministry-of-foreign-affairs","authority":"cn/ministry-of-foreign-affairs","content":"现公布《关于对余茂春、托德·斯坦恩采取反制裁措施的决定》，自2022年12月23日起施行。\n\n部长 王毅\n\n2022年12月23日\n\n12月9日，美方借口所谓“西藏人权”问题，对两名中方官员进行非法制裁。依据《中华人\n民共和国反外国制裁法》第四条、第五条、第六条规定，中方决定对余茂春、托德·斯坦\n恩等后附《反制裁清单》列明的个人采取以下反制裁措施：\n\n一、冻结在我国境内的动产、不动产和其他各类财产；\n二、禁止我国境内的组织、个人与其进行有关交易活动；\n三、对其本人及直系亲属不予签发签证、不准入境。\n\n本决定自2022年12月23日起施行。\n\n附件：反制裁清单\n\n外交部\n2022年12月23日\n\n附件\n反制裁清单\n\n一、余茂春，男\n二、托德·斯坦恩（Todd Stein），男\n","language":"zh-CN"}""" ;\n  ammitto:group_id <https://www.ammitto.org/group/cn/4> ;\n  ammitto:legal_citations """{"legal_instrument_id":"https://www.ammitto.org/legal-instrument/cn/npc-anti-foreign-sanctions-law","articles":["第四条","第五条","第六条"],"citation_type":"legal_basis"}""" ;\n  ammitto:raw_source_data """{"source_format":"yaml","source_specific_fields":{"cn:list_type":"anti_sanctions","cn:sanction_list":"反制裁清单","cn:chinese_name":"余茂春"}}""" .
<https://www.ammitto.org/entry/cn/anti-sanction-list/4-todd-stein>
  ammitto:entity_id <https://www.ammitto.org/entity/cn/4-todd-stein> ;\n  ammitto:hasAuthority <https://www.ammitto.org/authority/cn> ;\n  ammitto:hasRegime <https://www.ammitto.org/regime/cn_anti_sanctions> ;\n  ammitto:hasEffect """{"effect_type":"asset_freeze","scope":"full","description":[{"value":"冻结在我国境内的动产、不动产和其他各类财产","lang":"zh","script":"Hani","is_primary":true},{"value":"Freeze all assets in China, including movable and immovable property and other types of assets","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasEffect """{"effect_type":"prohibit_transactions","scope":"full","description":[{"value":"禁止我国境内的组织、个人与其进行有关交易活动","lang":"zh","script":"Hani","is_primary":true},{"value":"Prohibit transactions with Chinese organizations and individuals","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasEffect """{"effect_type":"entry_ban","scope":"full","description":[{"value":"对其本人及直系亲属不予签发签证、不准入境","lang":"zh","script":"Hani","is_primary":true},{"value":"Visa ban for the individual and their immediate family members","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasReason """{"category":"other","description":[{"value":"美方借口所谓“西藏人权”问题，对两名中方官员进行非法制裁","lang":"zh","script":"Hani","is_primary":true},{"value":"The US imposed illegal sanctions on two Chinese officials under the pretext of \"Tibet human rights\" issues.","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasPeriod """{"effective_date":"2022-12-23","is_indefinite":false}""" ;\n  ammitto:status "active" ;\n  ammitto:reference_number "4-todd-stein" ;\n  ammitto:announcement """{"title":"关于对余茂春、托德·斯坦恩采取反制裁措施的决定","url":"https://www.mfa.gov.cn/web/wjb_673085/zfxxgk_674865/gknrlb/fzcqdcs/202212/t20221222_10993979.shtml","publish_date":"2022-12-23","publish_time":"08:00","document_type":"cn/ministry-of-foreign-affairs-order","document_id":"第4号","signatory":"王毅","signatory_title":"部长","publisher":"cn/ministry-of-foreign-affairs","authority":"cn/ministry-of-foreign-affairs","content":"现公布《关于对余茂春、托德·斯坦恩采取反制裁措施的决定》，自2022年12月23日起施行。\n\n部长 王毅\n\n2022年12月23日\n\n12月9日，美方借口所谓“西藏人权”问题，对两名中方官员进行非法制裁。依据《中华人\n民共和国反外国制裁法》第四条、第五条、第六条规定，中方决定对余茂春、托德·斯坦\n恩等后附《反制裁清单》列明的个人采取以下反制裁措施：\n\n一、冻结在我国境内的动产、不动产和其他各类财产；\n二、禁止我国境内的组织、个人与其进行有关交易活动；\n三、对其本人及直系亲属不予签发签证、不准入境。\n\n本决定自2022年12月23日起施行。\n\n附件：反制裁清单\n\n外交部\n2022年12月23日\n\n附件\n反制裁清单\n\n一、余茂春，男\n二、托德·斯坦恩（Todd Stein），男\n","language":"zh-CN"}""" ;\n  ammitto:group_id <https://www.ammitto.org/group/cn/4> ;\n  ammitto:legal_citations """{"legal_instrument_id":"https://www.ammitto.org/legal-instrument/cn/npc-anti-foreign-sanctions-law","articles":["第四条","第五条","第六条"],"citation_type":"legal_basis"}""" ;\n  ammitto:raw_source_data """{"source_format":"yaml","source_specific_fields":{"cn:list_type":"anti_sanctions","cn:sanction_list":"反制裁清单","cn:chinese_name":"托德·斯坦恩","cn:english_name":"Todd Stein"}}""" .
<https://www.ammitto.org/entry/cn/anti-sanction-list/1-hudson-institute>
  ammitto:entity_id <https://www.ammitto.org/entity/cn/1-hudson-institute> ;\n  ammitto:hasAuthority <https://www.ammitto.org/authority/cn> ;\n  ammitto:hasRegime <https://www.ammitto.org/regime/cn_anti_sanctions> ;\n  ammitto:hasEffect """{"effect_type":"prohibit_transactions","scope":"full","description":[{"value":"严格限制我国境内的高校、机构等组织和个人与其进行有关交易、交流、合作等活动。","lang":"zh","script":"Hani","is_primary":true},{"value":"Strictly restrict Chinese universities, institutions, and individuals from engaging in relevant transactions, exchanges, and cooperation with them.","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasReason """{"category":"other","description":[{"value":"美方不顾中方反复交涉和坚决反对，执意允许台湾地区领导人蔡英文于2023年3月29日\n至31日和4月4日至6日“过境”窜美从事政治活动。美国哈德逊研究所、里根图书馆为蔡\n英文在美从事“台独”分裂活动提供平台和便利，严重违反一个中国原则和中美三个联合\n公报规定，严重损害中方主权和领土完整。","lang":"zh","script":"Hani","is_primary":true},{"value":"The US allowed Taiwan's leader Tsai Ing-wen to \"transit\" through the\nUS for political activities from March 29 to 31 and April 4 to 6,\ndespite repeated Chinese protests and strong opposition. The Hudson\nInstitute and the Reagan Library provided platforms and convenience\nfor Tsai Ing-wen's \"Taiwan independence\" activities in the US,\nseriously violating the One-China principle and the three China-US\njoint communiqués, seriously damaging China's sovereignty and\nterritorial integrity.","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasPeriod """{"effective_date":"2023-04-07","is_indefinite":false}""" ;\n  ammitto:status "active" ;\n  ammitto:reference_number "1-hudson-institute" ;\n  ammitto:announcement """{"title":"关于对美国哈德逊研究所、里根图书馆及其负责人采取反制措施的决定","url":"https://www.mfa.gov.cn/web/wjb_673085/zfxxgk_674865/gknrlb/fzcqdcs/202304/t20230407_11055802.shtml","publish_date":"2023-04-07","publish_time":"10:55","document_type":"cn/ministry-of-foreign-affairs-order","document_id":"第1号","signatory":"秦刚","signatory_title":"部长","publisher":"cn/ministry-of-foreign-affairs","authority":"cn/ministry-of-foreign-affairs","content":"现公布《关于对美国哈德逊研究所、里根图书馆及其负责人采取反制措施的决定》，自2023年4月7日起施行。\n\n部长 秦刚\n\n2023年4月7日\n\n关于对美国哈德逊研究所、里根图书馆及其负责人采取反制措施的决定\n\n美方不顾中方反复交涉和坚决反对，执意允许台湾地区领导人蔡英文于2023年3月29日\n至31日和4月4日至6日“过境”窜美从事政治活动。美国哈德逊研究所、里根图书馆为蔡\n英文在美从事“台独”分裂活动提供平台和便利，严重违反一个中国原则和中美三个联合\n公报规定，严重损害中方主权和领土完整。\n\n依据《中华人民共和国反外国制裁法》第四条、第五条、第六条、第十五条规定，中方\n决定对美国哈德逊研究所、里根图书馆及其负责人等后附《反制清单》列明的机构和个\n人采取以下反制措施：\n\n一、对哈德逊研究所、里根图书馆等2家机构：\n\n严格限制我国境内的高校、机构等组织和个人与其进行有关交易、交流、合作等活动。\n\n二、对哈德逊研究所董事会主席萨拉·斯特恩、所长约翰·瓦特斯，负责里根图书馆日常\n维护的里根基金会前执行主任约翰·希布斯奇、首席行政官乔安妮·德雷克等4名个人：\n\n（一）冻结在我国境内的动产、不动产和其他各类财产；\n\n（二）禁止我国境内的组织、个人与其进行有关交易、合作等活动；\n\n（三）对其本人不予签发签证、不准入境。\n\n本决定自2023年4月7日起施行。\n\n附件：反制清单\n外交部\n2023年4月7日\n\n附件\n反制清单\n\n一、哈德逊研究所\n\n二、里根图书馆\n\n三、哈德逊研究所董事会主席萨拉·斯特恩（Sarah May Stern），女\n\n四、哈德逊研究所所长约翰·瓦特斯（John P. Walters），男\n\n五、里根基金会前执行主任约翰·希布斯奇（John Heubusch），男\n\n六、里根基金会首席行政官乔安妮·德雷克（Joanne M. Drake），女\n","language":"zh-CN"}""" ;\n  ammitto:group_id <https://www.ammitto.org/group/cn/1> ;\n  ammitto:legal_citations """{"legal_instrument_id":"https://www.ammitto.org/legal-instrument/cn/npc-anti-foreign-sanctions-law","articles":["第四条","第五条","第六条"],"citation_type":"legal_basis"}""" ;\n  ammitto:raw_source_data """{"source_format":"yaml","source_specific_fields":{"cn:list_type":"anti_sanctions","cn:sanction_list":"反制裁清单","cn:chinese_name":"哈德逊研究所","cn:english_name":"Hudson Institute"}}""" .
<https://www.ammitto.org/entry/cn/anti-sanction-list/1-reagan-library>
  ammitto:entity_id <https://www.ammitto.org/entity/cn/1-reagan-library> ;\n  ammitto:hasAuthority <https://www.ammitto.org/authority/cn> ;\n  ammitto:hasRegime <https://www.ammitto.org/regime/cn_anti_sanctions> ;\n  ammitto:hasEffect """{"effect_type":"prohibit_transactions","scope":"full","description":[{"value":"严格限制我国境内的高校、机构等组织和个人与其进行有关交易、交流、合作等活动。","lang":"zh","script":"Hani","is_primary":true},{"value":"Strictly restrict Chinese universities, institutions, and individuals from engaging in relevant transactions, exchanges, and cooperation with them.","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasReason """{"category":"other","description":[{"value":"美方不顾中方反复交涉和坚决反对，执意允许台湾地区领导人蔡英文于2023年3月29日\n至31日和4月4日至6日“过境”窜美从事政治活动。美国哈德逊研究所、里根图书馆为蔡\n英文在美从事“台独”分裂活动提供平台和便利，严重违反一个中国原则和中美三个联合\n公报规定，严重损害中方主权和领土完整。","lang":"zh","script":"Hani","is_primary":true},{"value":"The US allowed Taiwan's leader Tsai Ing-wen to \"transit\" through the\nUS for political activities from March 29 to 31 and April 4 to 6,\ndespite repeated Chinese protests and strong opposition. The Hudson\nInstitute and the Reagan Library provided platforms and convenience\nfor Tsai Ing-wen's \"Taiwan independence\" activities in the US,\nseriously violating the One-China principle and the three China-US\njoint communiqués, seriously damaging China's sovereignty and\nterritorial integrity.","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasPeriod """{"effective_date":"2023-04-07","is_indefinite":false}""" ;\n  ammitto:status "active" ;\n  ammitto:reference_number "1-reagan-library" ;\n  ammitto:announcement """{"title":"关于对美国哈德逊研究所、里根图书馆及其负责人采取反制措施的决定","url":"https://www.mfa.gov.cn/web/wjb_673085/zfxxgk_674865/gknrlb/fzcqdcs/202304/t20230407_11055802.shtml","publish_date":"2023-04-07","publish_time":"10:55","document_type":"cn/ministry-of-foreign-affairs-order","document_id":"第1号","signatory":"秦刚","signatory_title":"部长","publisher":"cn/ministry-of-foreign-affairs","authority":"cn/ministry-of-foreign-affairs","content":"现公布《关于对美国哈德逊研究所、里根图书馆及其负责人采取反制措施的决定》，自2023年4月7日起施行。\n\n部长 秦刚\n\n2023年4月7日\n\n关于对美国哈德逊研究所、里根图书馆及其负责人采取反制措施的决定\n\n美方不顾中方反复交涉和坚决反对，执意允许台湾地区领导人蔡英文于2023年3月29日\n至31日和4月4日至6日“过境”窜美从事政治活动。美国哈德逊研究所、里根图书馆为蔡\n英文在美从事“台独”分裂活动提供平台和便利，严重违反一个中国原则和中美三个联合\n公报规定，严重损害中方主权和领土完整。\n\n依据《中华人民共和国反外国制裁法》第四条、第五条、第六条、第十五条规定，中方\n决定对美国哈德逊研究所、里根图书馆及其负责人等后附《反制清单》列明的机构和个\n人采取以下反制措施：\n\n一、对哈德逊研究所、里根图书馆等2家机构：\n\n严格限制我国境内的高校、机构等组织和个人与其进行有关交易、交流、合作等活动。\n\n二、对哈德逊研究所董事会主席萨拉·斯特恩、所长约翰·瓦特斯，负责里根图书馆日常\n维护的里根基金会前执行主任约翰·希布斯奇、首席行政官乔安妮·德雷克等4名个人：\n\n（一）冻结在我国境内的动产、不动产和其他各类财产；\n\n（二）禁止我国境内的组织、个人与其进行有关交易、合作等活动；\n\n（三）对其本人不予签发签证、不准入境。\n\n本决定自2023年4月7日起施行。\n\n附件：反制清单\n外交部\n2023年4月7日\n\n附件\n反制清单\n\n一、哈德逊研究所\n\n二、里根图书馆\n\n三、哈德逊研究所董事会主席萨拉·斯特恩（Sarah May Stern），女\n\n四、哈德逊研究所所长约翰·瓦特斯（John P. Walters），男\n\n五、里根基金会前执行主任约翰·希布斯奇（John Heubusch），男\n\n六、里根基金会首席行政官乔安妮·德雷克（Joanne M. Drake），女\n","language":"zh-CN"}""" ;\n  ammitto:group_id <https://www.ammitto.org/group/cn/1> ;\n  ammitto:legal_citations """{"legal_instrument_id":"https://www.ammitto.org/legal-instrument/cn/npc-anti-foreign-sanctions-law","articles":["第四条","第五条","第六条"],"citation_type":"legal_basis"}""" ;\n  ammitto:raw_source_data """{"source_format":"yaml","source_specific_fields":{"cn:list_type":"anti_sanctions","cn:sanction_list":"反制裁清单","cn:chinese_name":"里根图书馆","cn:english_name":"Reagan Library"}}""" .
<https://www.ammitto.org/entry/cn/anti-sanction-list/1-sarah-may-stern>
  ammitto:entity_id <https://www.ammitto.org/entity/cn/1-sarah-may-stern> ;\n  ammitto:hasAuthority <https://www.ammitto.org/authority/cn> ;\n  ammitto:hasRegime <https://www.ammitto.org/regime/cn_anti_sanctions> ;\n  ammitto:hasEffect """{"effect_type":"asset_freeze","scope":"full","description":[{"value":"冻结在我国境内的动产、不动产和其他各类财产","lang":"zh","script":"Hani","is_primary":true},{"value":"Freeze all assets in China, including movable and immovable property and other types of assets","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasEffect """{"effect_type":"prohibit_transactions","scope":"full","description":[{"value":"禁止我国境内的组织、个人与其进行有关交易、合作等活动","lang":"zh","script":"Hani","is_primary":true},{"value":"Prohibit transactions, cooperation, and other activities with Chinese organizations and individuals","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasEffect """{"effect_type":"entry_ban","scope":"full","description":[{"value":"对其本人不予签发签证、不准入境。","lang":"zh","script":"Hani","is_primary":true},{"value":"Visa ban for the individual, prohibiting entry","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasReason """{"category":"other","description":[{"value":"美方不顾中方反复交涉和坚决反对，执意允许台湾地区领导人蔡英文于2023年3月29日\n至31日和4月4日至6日“过境”窜美从事政治活动。美国哈德逊研究所、里根图书馆为蔡\n英文在美从事“台独”分裂活动提供平台和便利，严重违反一个中国原则和中美三个联合\n公报规定，严重损害中方主权和领土完整。","lang":"zh","script":"Hani","is_primary":true},{"value":"The US allowed Taiwan's leader Tsai Ing-wen to \"transit\" through the\nUS for political activities from March 29 to 31 and April 4 to 6,\ndespite repeated Chinese protests and strong opposition. The Hudson\nInstitute and the Reagan Library provided platforms and convenience\nfor Tsai Ing-wen's \"Taiwan independence\" activities in the US,\nseriously violating the One-China principle and the three China-US\njoint communiqués, seriously damaging China's sovereignty and\nterritorial integrity.","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasPeriod """{"effective_date":"2023-04-07","is_indefinite":false}""" ;\n  ammitto:status "active" ;\n  ammitto:reference_number "1-sarah-may-stern" ;\n  ammitto:announcement """{"title":"关于对美国哈德逊研究所、里根图书馆及其负责人采取反制措施的决定","url":"https://www.mfa.gov.cn/web/wjb_673085/zfxxgk_674865/gknrlb/fzcqdcs/202304/t20230407_11055802.shtml","publish_date":"2023-04-07","publish_time":"10:55","document_type":"cn/ministry-of-foreign-affairs-order","document_id":"第1号","signatory":"秦刚","signatory_title":"部长","publisher":"cn/ministry-of-foreign-affairs","authority":"cn/ministry-of-foreign-affairs","content":"现公布《关于对美国哈德逊研究所、里根图书馆及其负责人采取反制措施的决定》，自2023年4月7日起施行。\n\n部长 秦刚\n\n2023年4月7日\n\n关于对美国哈德逊研究所、里根图书馆及其负责人采取反制措施的决定\n\n美方不顾中方反复交涉和坚决反对，执意允许台湾地区领导人蔡英文于2023年3月29日\n至31日和4月4日至6日“过境”窜美从事政治活动。美国哈德逊研究所、里根图书馆为蔡\n英文在美从事“台独”分裂活动提供平台和便利，严重违反一个中国原则和中美三个联合\n公报规定，严重损害中方主权和领土完整。\n\n依据《中华人民共和国反外国制裁法》第四条、第五条、第六条、第十五条规定，中方\n决定对美国哈德逊研究所、里根图书馆及其负责人等后附《反制清单》列明的机构和个\n人采取以下反制措施：\n\n一、对哈德逊研究所、里根图书馆等2家机构：\n\n严格限制我国境内的高校、机构等组织和个人与其进行有关交易、交流、合作等活动。\n\n二、对哈德逊研究所董事会主席萨拉·斯特恩、所长约翰·瓦特斯，负责里根图书馆日常\n维护的里根基金会前执行主任约翰·希布斯奇、首席行政官乔安妮·德雷克等4名个人：\n\n（一）冻结在我国境内的动产、不动产和其他各类财产；\n\n（二）禁止我国境内的组织、个人与其进行有关交易、合作等活动；\n\n（三）对其本人不予签发签证、不准入境。\n\n本决定自2023年4月7日起施行。\n\n附件：反制清单\n外交部\n2023年4月7日\n\n附件\n反制清单\n\n一、哈德逊研究所\n\n二、里根图书馆\n\n三、哈德逊研究所董事会主席萨拉·斯特恩（Sarah May Stern），女\n\n四、哈德逊研究所所长约翰·瓦特斯（John P. Walters），男\n\n五、里根基金会前执行主任约翰·希布斯奇（John Heubusch），男\n\n六、里根基金会首席行政官乔安妮·德雷克（Joanne M. Drake），女\n","language":"zh-CN"}""" ;\n  ammitto:group_id <https://www.ammitto.org/group/cn/1> ;\n  ammitto:legal_citations """{"legal_instrument_id":"https://www.ammitto.org/legal-instrument/cn/npc-anti-foreign-sanctions-law","articles":["第四条","第五条","第六条"],"citation_type":"legal_basis"}""" ;\n  ammitto:raw_source_data """{"source_format":"yaml","source_specific_fields":{"cn:list_type":"anti_sanctions","cn:sanction_list":"反制裁清单","cn:chinese_name":"萨拉·斯特恩","cn:english_name":"Sarah May Stern"}}""" .
<https://www.ammitto.org/entry/cn/anti-sanction-list/1-john-p-walters>
  ammitto:entity_id <https://www.ammitto.org/entity/cn/1-john-p-walters> ;\n  ammitto:hasAuthority <https://www.ammitto.org/authority/cn> ;\n  ammitto:hasRegime <https://www.ammitto.org/regime/cn_anti_sanctions> ;\n  ammitto:hasEffect """{"effect_type":"asset_freeze","scope":"full","description":[{"value":"冻结在我国境内的动产、不动产和其他各类财产","lang":"zh","script":"Hani","is_primary":true},{"value":"Freeze all assets in China, including movable and immovable property and other types of assets","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasEffect """{"effect_type":"prohibit_transactions","scope":"full","description":[{"value":"禁止我国境内的组织、个人与其进行有关交易、合作等活动","lang":"zh","script":"Hani","is_primary":true},{"value":"Prohibit transactions, cooperation, and other activities with Chinese organizations and individuals","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasEffect """{"effect_type":"entry_ban","scope":"full","description":[{"value":"对其本人不予签发签证、不准入境。","lang":"zh","script":"Hani","is_primary":true},{"value":"Visa ban for the individual, prohibiting entry","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasReason """{"category":"other","description":[{"value":"美方不顾中方反复交涉和坚决反对，执意允许台湾地区领导人蔡英文于2023年3月29日\n至31日和4月4日至6日“过境”窜美从事政治活动。美国哈德逊研究所、里根图书馆为蔡\n英文在美从事“台独”分裂活动提供平台和便利，严重违反一个中国原则和中美三个联合\n公报规定，严重损害中方主权和领土完整。","lang":"zh","script":"Hani","is_primary":true},{"value":"The US allowed Taiwan's leader Tsai Ing-wen to \"transit\" through the\nUS for political activities from March 29 to 31 and April 4 to 6,\ndespite repeated Chinese protests and strong opposition. The Hudson\nInstitute and the Reagan Library provided platforms and convenience\nfor Tsai Ing-wen's \"Taiwan independence\" activities in the US,\nseriously violating the One-China principle and the three China-US\njoint communiqués, seriously damaging China's sovereignty and\nterritorial integrity.","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasPeriod """{"effective_date":"2023-04-07","is_indefinite":false}""" ;\n  ammitto:status "active" ;\n  ammitto:reference_number "1-john-p-walters" ;\n  ammitto:announcement """{"title":"关于对美国哈德逊研究所、里根图书馆及其负责人采取反制措施的决定","url":"https://www.mfa.gov.cn/web/wjb_673085/zfxxgk_674865/gknrlb/fzcqdcs/202304/t20230407_11055802.shtml","publish_date":"2023-04-07","publish_time":"10:55","document_type":"cn/ministry-of-foreign-affairs-order","document_id":"第1号","signatory":"秦刚","signatory_title":"部长","publisher":"cn/ministry-of-foreign-affairs","authority":"cn/ministry-of-foreign-affairs","content":"现公布《关于对美国哈德逊研究所、里根图书馆及其负责人采取反制措施的决定》，自2023年4月7日起施行。\n\n部长 秦刚\n\n2023年4月7日\n\n关于对美国哈德逊研究所、里根图书馆及其负责人采取反制措施的决定\n\n美方不顾中方反复交涉和坚决反对，执意允许台湾地区领导人蔡英文于2023年3月29日\n至31日和4月4日至6日“过境”窜美从事政治活动。美国哈德逊研究所、里根图书馆为蔡\n英文在美从事“台独”分裂活动提供平台和便利，严重违反一个中国原则和中美三个联合\n公报规定，严重损害中方主权和领土完整。\n\n依据《中华人民共和国反外国制裁法》第四条、第五条、第六条、第十五条规定，中方\n决定对美国哈德逊研究所、里根图书馆及其负责人等后附《反制清单》列明的机构和个\n人采取以下反制措施：\n\n一、对哈德逊研究所、里根图书馆等2家机构：\n\n严格限制我国境内的高校、机构等组织和个人与其进行有关交易、交流、合作等活动。\n\n二、对哈德逊研究所董事会主席萨拉·斯特恩、所长约翰·瓦特斯，负责里根图书馆日常\n维护的里根基金会前执行主任约翰·希布斯奇、首席行政官乔安妮·德雷克等4名个人：\n\n（一）冻结在我国境内的动产、不动产和其他各类财产；\n\n（二）禁止我国境内的组织、个人与其进行有关交易、合作等活动；\n\n（三）对其本人不予签发签证、不准入境。\n\n本决定自2023年4月7日起施行。\n\n附件：反制清单\n外交部\n2023年4月7日\n\n附件\n反制清单\n\n一、哈德逊研究所\n\n二、里根图书馆\n\n三、哈德逊研究所董事会主席萨拉·斯特恩（Sarah May Stern），女\n\n四、哈德逊研究所所长约翰·瓦特斯（John P. Walters），男\n\n五、里根基金会前执行主任约翰·希布斯奇（John Heubusch），男\n\n六、里根基金会首席行政官乔安妮·德雷克（Joanne M. Drake），女\n","language":"zh-CN"}""" ;\n  ammitto:group_id <https://www.ammitto.org/group/cn/1> ;\n  ammitto:legal_citations """{"legal_instrument_id":"https://www.ammitto.org/legal-instrument/cn/npc-anti-foreign-sanctions-law","articles":["第四条","第五条","第六条"],"citation_type":"legal_basis"}""" ;\n  ammitto:raw_source_data """{"source_format":"yaml","source_specific_fields":{"cn:list_type":"anti_sanctions","cn:sanction_list":"反制裁清单","cn:chinese_name":"约翰·瓦特斯","cn:english_name":"John P. Walters"}}""" .
<https://www.ammitto.org/entry/cn/anti-sanction-list/1-john-heubusch>
  ammitto:entity_id <https://www.ammitto.org/entity/cn/1-john-heubusch> ;\n  ammitto:hasAuthority <https://www.ammitto.org/authority/cn> ;\n  ammitto:hasRegime <https://www.ammitto.org/regime/cn_anti_sanctions> ;\n  ammitto:hasEffect """{"effect_type":"asset_freeze","scope":"full","description":[{"value":"冻结在我国境内的动产、不动产和其他各类财产","lang":"zh","script":"Hani","is_primary":true},{"value":"Freeze all assets in China, including movable and immovable property and other types of assets","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasEffect """{"effect_type":"prohibit_transactions","scope":"full","description":[{"value":"禁止我国境内的组织、个人与其进行有关交易、合作等活动","lang":"zh","script":"Hani","is_primary":true},{"value":"Prohibit transactions, cooperation, and other activities with Chinese organizations and individuals","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasEffect """{"effect_type":"entry_ban","scope":"full","description":[{"value":"对其本人不予签发签证、不准入境。","lang":"zh","script":"Hani","is_primary":true},{"value":"Visa ban for the individual, prohibiting entry","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasReason """{"category":"other","description":[{"value":"美方不顾中方反复交涉和坚决反对，执意允许台湾地区领导人蔡英文于2023年3月29日\n至31日和4月4日至6日“过境”窜美从事政治活动。美国哈德逊研究所、里根图书馆为蔡\n英文在美从事“台独”分裂活动提供平台和便利，严重违反一个中国原则和中美三个联合\n公报规定，严重损害中方主权和领土完整。","lang":"zh","script":"Hani","is_primary":true},{"value":"The US allowed Taiwan's leader Tsai Ing-wen to \"transit\" through the\nUS for political activities from March 29 to 31 and April 4 to 6,\ndespite repeated Chinese protests and strong opposition. The Hudson\nInstitute and the Reagan Library provided platforms and convenience\nfor Tsai Ing-wen's \"Taiwan independence\" activities in the US,\nseriously violating the One-China principle and the three China-US\njoint communiqués, seriously damaging China's sovereignty and\nterritorial integrity.","lang":"en","script":"Latn","is_primary":false}]}""" ;\n  ammitto:hasPeriod """{"effective_date":"2023-04-07","is_indefinite":false}""" ;\n  ammitto:status "active" ;\n  ammitto:reference_number "1-john-heubusch" ;\n  ammitto:announcement """{"title":"关于对美国哈德逊研究所、里根图书馆及其负责人采取反制措施的决定","url":"https://www.mfa.gov.cn/web/wjb_673085/zfxxgk_674865/gknrlb/fzcqdcs/202304/t20230407_11055802.shtml","publish_date":"2023-04-07","publish_time":"10:55","document_type":"cn/ministry-of-foreign-affairs-order","document_id":"第1号","signatory":"秦刚","signatory_title":"部长","publisher":"cn/ministry-of-foreign-affairs","authority":"cn/ministry-of-foreign-affairs","content":"现公布《关于对美国哈德逊研究所、里根图书馆及其负责人采取反制措施的决定》，自2023年4月7日起施行。\n\n部长 秦刚\n\n2023年4月7日\n\n关于对美国哈德逊研究所、里根图书馆及其负责人采取反制措施的决定\n\n美方不顾中方反复交涉和坚决反对，执意允许台湾地区领导人蔡英文于2023年3月29日\n至31日和4月4日至6日“过境”窜美从事政治活动。美国哈德逊研究所、里根图书馆为蔡\n英文在美从事“台独”分裂活动提供平台和便利，严重违反一个中国原则和中美三个联合\n公报规定，严重损害中方主权和领土完整。\n\n依据《中华人民共和国反外国制裁法》第四条、第五条、第六条、第十五条规定，中方\n决定对美国哈德逊研究所、里根图书馆及其负责人等后附《反制清单》列明的机构和个\n人采取以下反制措施：\n\n一、对哈德逊研究所、里根图书馆等2家机构：\n\n严格限制我国境内的高校、机构等组织和个人与其进行有关交易、交流、合作等活动。\n\n二、对哈德逊研究所董事会主席萨拉·斯特恩、所长约翰·瓦特斯，负责里根图书馆日常\n维护的里根基金会前执行主任约翰·希布斯奇、首席行政官乔安妮·德雷克等4名个人：\n\n（一）冻结在我国境内的动产、不动产和其他各类财产；\n\n（二）禁止我国境内的组织、个人与其进行有关交易、合作等活动；\n\n（三）对其本人不予签发签证、不准入境。\n\n本决定自2023年4月7日起施行。\n\n附件：反制清单\n外交部\n2023年4月7日\n\n附件\n反制清单\n\n一、哈德逊研究所\n\n二、里根图书馆\n\n三、哈德逊研究所董事会主席萨拉·斯特恩（Sarah May Stern），女\n\n四、哈德逊研究所所长约翰·瓦特斯（John P. Walters），男\n\n五、里根基金会前执行主任约翰·希布斯奇（John Heubusch），男\n\n六、里根基金会首席行政官乔安妮·德雷克（Joanne M. Drake），女\n","language":"zh-CN"}""" ;\n  ammitto:group_id <https://www.ammitto.org/group/cn/1> ;\n  ammitto:legal_citations """{"legal_instrument_id":"https://www.ammitto.org/legal-instrument/cn/npc-anti-foreign-sanctions-law","articles":["第四条","第五条","第六条"],"citation_type":"legal_basis"}""" ;\n  ammitto:raw_source_data """{"source_format":"yaml","source_specific_fields":{"cn:list_type":"anti_sanctions","cn:sanction_list":"反制裁清单","cn:chinese_name":"约翰·希布斯奇","cn:english_name":"John Heubusch"}}""" .
