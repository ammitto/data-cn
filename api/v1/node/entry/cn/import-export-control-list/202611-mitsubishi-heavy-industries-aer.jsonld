  },
  "regime": {
    "@id": "https://www.ammitto.org/regime/cn_export_control"
  },
  "effects": [
    {
      "effect_type": "prohibit_export_dual_use_items",
      "scope": "full",
      "description": [
        {
          "value": "禁止出口经营者向名单上实体出口两用物项，禁止境外组织和个人将原产于中华人民共和国的两用物项转移或提供给上述20家实体；正在开展的相关活动应当立即停止。",
          "lang": "zh",
          "script": "Hani",
          "is_primary": true
        },
        {
          "value": "Prohibit the export of dual-use items to the entities on the list by exporters, and prohibit overseas organizations and individuals from transferring or providing dual-use items originating from China to the above 20 entities; ongoing related activities should be immediately ceased.",
          "lang": "en",
          "script": "Latn",
          "is_primary": false
        }
      ]
    },
    {
      "effect_type": "export_license_requirement",
      "scope": "full",
      "description": [
        {
          "value": "特殊情况下确需出口的，出口经营者应当向商务部提出申请",
          "lang": "zh",
          "script": "Hani",
          "is_primary": true
        },
        {
          "value": "In special circumstances where export is necessary, exporters should apply to the Ministry of Commerce for approval",
          "lang": "en",
          "script": "Latn",
          "is_primary": false
        }
      ]
    }
  ],
  "reasons": [
    {
      "category": "other",
      "description": [
        {
          "value": "为维护国家安全和利益，履行防扩散等国际义务",
          "lang": "zh",
          "script": "Hani",
          "is_primary": true
        },
        {
          "value": "To safeguard national security and interests, and to fulfill international obligations such as non-proliferation",
          "lang": "en",
          "script": "Latn",
          "is_primary": false
        }
      ]
    }
  ],
  "period": {
    "effective_date": "2026-02-24",
    "is_indefinite": false
  },
  "status": "active",
  "reference_number": "202611-mitsubishi-heavy-industries-aer",
  "announcement": {
    "title": "公布将20家日本实体列入出口管制管控名单",
    "url": "https://www.mofcom.gov.cn/zwgk/zcfb/art/2026/art_b5159a773124428a9813884015d1b8b3.html",
    "published_date": "2026-02-24",
    "document_type": "cn/ministry-of-commerce-announcement",
    "document_id": "2026年第11号",
    "signatory": "cn/ministry-of-commerce",
    "publisher": "cn/ministry-of-commerce",
    "authority": "cn/ministry-of-commerce",
    "content": "根据《中华人民共和国出口管制法》和《中华人民共和国两用物项出口管制条例》等法律法规有关规定，为维护国家安全和利益，履行防扩散等国际义务，决定将三菱造船株式会社等参与提升日本军事实力的20家日本实体列入出口管制管控名单（见附件），并采取以下措施：\n\n一、禁止出口经营者向上述20家实体出口两用物项，禁止境外组织和个人将原产于中华人民共和国的两用物项转移或提供给上述20家实体；正在开展的相关活动应当立即停止。\n二、特殊情况下确需出口的，出口经营者应当向商务部提出申请。\n\n本公告自公布之日起正式实施。\n",
    "language": "zh-CN"
  },
  "group_id": "https://www.ammitto.org/group/cn/202611",
