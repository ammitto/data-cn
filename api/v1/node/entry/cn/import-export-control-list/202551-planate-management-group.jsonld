  "status": "active",
  "reference_number": "202551-planate-management-group",
  "announcement": {
    "title": "公布将3家美国实体列入出口管制管控名单决定",
    "url": "https://www.mofcom.gov.cn/zwgk/zcfb/art/2025/art_113cfe1ef91740c9a0e92a5a91e779d9.html",
    "published_date": "2025-09-25",
    "document_type": "cn/ministry-of-commerce-announcement",
    "document_id": "2025年第51号",
    "signatory": "cn/ministry-of-commerce",
    "publisher": "cn/ministry-of-commerce",
    "authority": "cn/ministry-of-commerce",
    "content": "根据《中华人民共和国出口管制法》和《中华人民共和国两用物项出口管制条例》等法律法规有关规定，为维护国家安全和利益，履行防扩散等国际义务，决定将亨廷顿·英格尔斯工业公司等3家美国实体列入出口管制管控名单（见附件），并采取以下措施：\n\n一、禁止向上述3家美国实体出口两用物项；正在开展的相关出口活动应当立即停止。\n二、特殊情况下确需出口的，出口经营者应当向商务部提出申请。\n\n本公告自公布之日起正式实施。\n",
    "language": "zh-CN"
  },
  "group_id": "https://www.ammitto.org/group/cn/202551",
