{
  "id": "https://www.ammitto.org/entry/cn/unreliable-entity-list/20243-pvh-corp",
  "entity_id": "https://www.ammitto.org/entity/cn/20243-pvh-corp",
  "authority": {
    "@id": "https://www.ammitto.org/authority/cn"
  },
  "regime": {
    "@id": "https://www.ammitto.org/regime/cn_unreliable_entity"
  },
  "effects": [
    {
      "effect_type": "investigation",
      "scope": "full",
      "description": [
        {
          "value": "启动不可靠实体清单调查",
          "lang": "zh",
          "script": "Hani",
          "is_primary": true
        },
        {
          "value": "Investigation launched under unreliable entity list",
          "lang": "en",
          "script": "Latn",
          "is_primary": false
        }
      ]
    },
    {
      "effect_type": "provide_information",
      "scope": "full",
      "description": [
        {
          "value": "美国PVH集团应在本公告公布之日起30天内向不可靠实体清单工作机制办公室提供说明近3年内是否存在对涉疆产品采取歧视性措施等问题的书面材料及证明资料以及调查机关需要的其他资料。",
          "lang": "zh",
          "script": "Hani",
          "is_primary": true
        },
        {
          "value": "PVH Corp. should provide written materials and evidence to the Unreliable Entity List Working Mechanism Office within 30 days from the date of this announcement, regarding whether discriminatory measures have been taken against Xinjiang-related products in the past three years, as well as other materials needed by the investigation authorities.",
          "lang": "en",
          "script": "Latn",
          "is_primary": false
        }
      ]
    },
    {
      "effect_type": "allow_statement",
      "scope": "full",
      "description": [
        {
          "value": "调查期间，美国PVH集团可向不可靠实体清单工作机制办公室陈述、申辩。",
          "lang": "zh",
          "script": "Hani",
          "is_primary": true
        },
        {
          "value": "During the investigation, PVH Corp. can make statements and defenses to the Unreliable Entity List Working Mechanism Office.",
          "lang": "en",
          "script": "Latn",
          "is_primary": false
        }
      ]
    },
    {
      "effect_type": "cooperate_investigation",
      "scope": "full",
      "description": [
        {
          "value": "不可靠实体清单工作机制办公室依法采取询问当事人、查阅或者复制相关文件、资料以及其他必要的方式，对PVH集团开展调查，PVH集团及有关企业应予以配合。",
          "lang": "zh",
          "script": "Hani",
          "is_primary": true
        },
        {
          "value": "The Unreliable Entity List Working Mechanism Office will conduct the investigation by asking the parties involved, reviewing or copying relevant documents and materials, and other necessary means in accordance with the law. PVH Corp. and related enterprises should cooperate.",
          "lang": "en",
          "script": "Latn",
          "is_primary": false
        }
      ]
    },
    {
      "effect_type": "report_violation",
      "scope": "full",
      "description": [
        {
          "value": "调查期间，任何单位和个人可向不可靠实体清单工作机制办公室反映美国PVH集团违反正常的市场交易原则，针对涉疆产品，中断与中国企业、其他组织或者个人的正常交易、采取歧视性措施等情况，并应提供相关证据。",
          "lang": "zh",
          "script": "Hani",
          "is_primary": true
        },
        {
          "value": "During the investigation, any unit and individual can report to the Unreliable Entity List Working Mechanism Office about PVH Corp.'s violation of normal market transaction principles, such as disrupting normal transactions with Chinese enterprises, other organizations or individuals, taking discriminatory measures against Xinjiang-related products, etc., and should provide relevant evidence.",
          "lang": "en",
          "script": "Latn",
          "is_primary": false
        }
      ]
    }
  ],
  "reasons": [
    {
      "category": "other",
      "description": [
        {
          "value": "针对涉疆产品涉嫌违反正常的市场交易原则，中断与中国企业、其他组织或者个人的正常交易、采取歧视性措施",
          "lang": "zh",
          "script": "Hani",
          "is_primary": true
        },
        {
          "value": "Potentially violating normal market transaction principles by taking discriminatory measures against Xinjiang-related products, disrupting normal transactions with Chinese enterprises, other organizations or individuals",
          "lang": "en",
          "script": "Latn",
          "is_primary": false
        }
      ]
    }
  ],
  "period": {
    "effective_date": "2024-09-24",
    "is_indefinite": false
  },
  "status": "active",
  "reference_number": "20243-pvh-corp",
  "announcement": {
    "title": "不可靠实体清单工作机制关于对美国PVH集团启动不可靠实体清单调查的公告",
    "url": "https://aqygzj.mofcom.gov.cn/flzc/gzjgfxwj/art/2024/art_f5ac8919a05743f78a3c25f3d0c138f5.html",
    "published_date": "2024-09-24",
    "published_time": "16:00",
    "document_type": "cn/unreliable-entity-list-working-mechanism-announcement",
    "document_id": "〔2024〕3号",
    "signatory": "cn/unreliable-entity-list-working-mechanism",
    "publisher": "cn/ministry-of-commerce-industry-security-and-import-export-control",
    "authority": "cn/unreliable-entity-list-working-mechanism",
    "content": "为维护国家主权、安全和发展利益，根据《中华人民共和国对外贸易法》《中华人民共和国国家安全法》《中华人民共和国反外国制裁法》等有关法律，不可靠实体清单工作机制依据《不可靠实体清单规定》第二条、第五条和第六条等有关规定，根据有关机构的建议、举报，决定对美国PVH集团针对涉疆产品涉嫌违反正常的市场交易原则，中断与中国企业、其他组织或者个人的正常交易、采取歧视性措施等问题启动调查。\n\n一、美国PVH集团应在本公告公布之日起30天内向不可靠实体清单工作机制办公室提供说明近3年内是否存在对涉疆产品采取歧视性措施等问题的书面材料及证明资料以及调查机关需要的其他资料。\n二、调查期间，美国PVH集团可向不可靠实体清单工作机制办公室陈述、申辩。\n三、不可靠实体清单工作机制办公室依法采取询问当事人、查阅或者复制相关文件、资料以及其他必要的方式，对PVH集团开展调查，PVH集团及有关企业应予以配合。\n四、调查期间，任何单位和个人可向不可靠实体清单工作机制办公室反映美国PVH集团违反正常的市场交易原则，针对涉疆产品，中断与中国企业、其他组织或者个人的正常交易、采取歧视性措施等情况，并应提供相关证据。\n\n不可靠实体清单工作机制办公室联系方式：\n\n地址：北京市东城区东长安街2号\n邮编：100731\n电子邮箱：agjasc@mofcom.gov.cn\n",
    "language": "zh-CN"
  },
